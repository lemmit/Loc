    "primitive-card":           [{ "from": "@/components/ui/card",   "named": ["Card", "CardContent", "CardHeader", "CardTitle"] }],
    "primitive-badge":          [{ "from": "@/components/ui/badge",  "named": ["Badge"] }],
    "primitive-field":          [
      { "from": "@/components/ui/input", "named": ["Input"] },
      { "from": "@/components/ui/label", "named": ["Label"] }
    ],
    "primitive-toggle":         [
      { "from": "@/components/ui/switch", "named": ["Switch"] },
      { "from": "@/components/ui/label",  "named": ["Label"] }
    ],
    "primitive-number-field":   [
      { "from": "@/components/ui/input", "named": ["Input"] },
      { "from": "@/components/ui/label", "named": ["Label"] }
    ],
    "primitive-password-field": [
      { "from": "@/components/ui/input", "named": ["Input"] },
      { "from": "@/components/ui/label", "named": ["Label"] }
    ],
    "primitive-loader": [{ "from": "lucide-react", "named": ["Loader2"] }],
    "primitive-tabs":   [{ "from": "@/components/ui/tabs", "named": ["Tabs", "TabsContent", "TabsList", "TabsTrigger"] }]
  },
  "shellFiles": {
    "tailwind-config": "tailwind.config.ts",
    "postcss-config": "postcss.config.js",
    "globals-css": "src/globals.css",
    "lib-utils": "src/lib/utils.ts"
  },
  "shellGlobs": {
    "components-ui-*": "src/components/ui/{1}.tsx"
  },
  "helpers": {
    "lucide": {
      "IconPlus": "Plus",
      "IconTrash": "Trash2",
      "IconCheck": "Check",
      "IconX": "X",
      "IconTruckDelivery": "Truck",
      "IconCreditCard": "CreditCard",
      "IconPlayerPlay": "Play",
      "IconPlayerStop": "Square",
      "IconPencil": "Pencil",
      "IconLink": "Link",
      "IconAlertCircle": "AlertCircle",
      "IconAlertTriangle": "AlertTriangle",
      "IconBolt": "Zap",
      "IconLayoutList": "LayoutList"
    }
  }
