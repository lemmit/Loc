<FormField
          control={form.control}
          name="{{path}}"
          render={({ field }) => (
            <FormItem>
              <FormLabel>{{label}}</FormLabel>
              <FormControl>
                <Input
                  type="number"
                  step="1"
                  data-testid="{{testId}}"
                  value={(field.value as number | "") ?? ""}
                  onChange={(e) => field.onChange(e.target.value === "" ? 0 : parseInt(e.target.value, 10) || 0)}
                  onBlur={field.onBlur}
                  ref={field.ref}
                  name={field.name}
                />
              </FormControl>
              <FormMessage />
            </FormItem>
          )}
        />
