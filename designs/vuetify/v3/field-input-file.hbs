<v-file-input label="{{label}}" data-testid="{{testId}}" clearable :placeholder='form.values.{{path}}?.key ?? "Choose file"' @update:model-value="async (f) => { const file = Array.isArray(f) ? f[0] : f; if (!file) { form.values.{{path}} = null; return; } const fd = new FormData(); fd.append('file', file); form.values.{{path}} = (await api.upload('/files', fd)) as typeof form.values.{{path}}; }" :error-messages='form.errors["{{path}}"]' />
