{#snippet {{opCamel}}OpModal(form: LoomForm<{{opPascal}}{{aggregateName}}Request>)}
  <Button{{#unless triggerPrimary}} outline{{/unless}} onclick={() => { {{opCamel}}ModalOpen = true; }} data-testid="{{slug}}-op-{{opName}}">{{triggerLabel}}</Button>
  {#if {{opCamel}}ModalOpen}
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
      <div class="w-full max-w-md rounded-xl border border-gray-200 bg-white p-6 shadow-lg dark:border-gray-700 dark:bg-gray-800" role="dialog" aria-modal="true" aria-labelledby="{{slug}}-op-{{opName}}-title" data-testid="{{slug}}-op-{{opName}}-form">
        <h3 id="{{slug}}-op-{{opName}}-title" class="mb-4 text-lg font-semibold">{{humanOp}}</h3>
        <form onsubmit={(e) => { e.preventDefault(); form.submit(async (vals) => {
          try {
            await {{opCamel}}.mutateAsync(vals);
            toast.success("{{humanOp}} succeeded");
            {{opCamel}}ModalOpen = false;
          } catch (err) {
            const outcome = form.applyServerErrors(err);
            if (outcome.kind === "global") {
              toast.error(outcome.title);
            } else if (outcome.kind === "unhandled") {
              toast.error((err as Error).message);
            }
          }
        }); }}>
          <div class="flex flex-col gap-4">
            {{#if hasParams}}{{#each fieldHtmls}}{{{this}}}
            {{/each}}{{else}}<p class="text-sm text-gray-500">This operation has no parameters.</p>
            {{/if}}<div class="flex justify-end gap-2 pt-2">
              <Button outline onclick={() => { {{opCamel}}ModalOpen = false; }}>Cancel</Button>
              <Button type="submit" disabled={ {{opCamel}}.isPending } data-testid="{{slug}}-op-{{opName}}-submit">{{humanOp}}</Button>
            </div>
          </div>
        </form>
      </div>
    </div>
  {/if}
{/snippet}