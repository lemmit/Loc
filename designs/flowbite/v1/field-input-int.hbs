<div class="flex flex-col gap-2">
          <Label for="{{testId}}">{{label}}</Label>
          <Input id="{{testId}}" type="number" step="1" data-testid="{{testId}}" value={form.values.{{path}} } oninput={(e) => { form.values.{{path}} = (e.currentTarget as HTMLInputElement).value === "" ? 0 : parseInt((e.currentTarget as HTMLInputElement).value, 10) || 0; }} />
          {#if form.errors["{{path}}"]}<Helper color="red">{form.errors["{{path}}"]}</Helper>{/if}
        </div>