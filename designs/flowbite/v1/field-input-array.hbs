{{#if rowFields}}
<div class="flex flex-col gap-2">
          <Label>{{label}}</Label>
          {#each form.values.{{path}} as row, index}
          <div class="flex gap-2 items-end">
            {{#each rowFields}}{{#if (eq template "field-input-int")}}<Input type="number" step="1" placeholder="{{label}}" value={form.values.{{../path}}[index].{{path}} } oninput={(e) => { form.values.{{../path}}[index].{{path}} = (e.currentTarget as HTMLInputElement).value === "" ? 0 : parseInt((e.currentTarget as HTMLInputElement).value, 10) || 0; }} />{{else}}{{#if (eq template "field-input-decimal")}}<Input type="number" step="0.01" placeholder="{{label}}" value={form.values.{{../path}}[index].{{path}} } oninput={(e) => { form.values.{{../path}}[index].{{path}} = Number((e.currentTarget as HTMLInputElement).value) || 0; }} />{{else}}<Input placeholder="{{label}}" bind:value={form.values.{{../path}}[index].{{path}} } />{{/if}}{{/if}}{{/each}}<Button type="button" color="red" size="xs" onclick={() => form.values.{{path}}.splice(index, 1)}>Remove</Button>
          </div>
          {/each}
          <Button type="button" size="xs" onclick={() => form.values.{{path}}.push({{{defaultRowJson}}})}>Add {{elementLabel}}</Button>
        </div>
{{else}}
<div class="flex flex-col gap-2">
          <Label for="{{testId}}">{{label}}</Label>
          <Input id="{{testId}}" data-testid="{{testId}}" placeholder="(arrays not yet supported in forms)" disabled />
        </div>
{{/if}}
