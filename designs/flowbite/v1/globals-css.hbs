  --font-mono: var(--loom-font-family-mono);
}

body {
  background-color: hsl(var(--background));
  color: hsl(var(--foreground));
  font-family: var(--loom-font-family);
}

/* Loom helpers shared with the structural templates. */
.loom-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  white-space: nowrap;
  border-radius: var(--loom-radius);
  font-size: 0.875rem;
  font-weight: 500;
  height: 2.25rem;
  padding: 0 1rem;
  cursor: pointer;
}
.loom-btn:disabled { pointer-events: none; opacity: 0.5; }
.loom-btn-primary { background: var(--loom-primary); color: white; border: 1px solid transparent; }
.loom-btn-outline { background: transparent; border: 1px solid hsl(var(--border)); }
.loom-btn-ghost { background: transparent; border: 1px solid transparent; }
.loom-icon svg { width: 1em; height: 1em; }
.loom-icon-sm svg { width: 0.875em; height: 0.875em; }
