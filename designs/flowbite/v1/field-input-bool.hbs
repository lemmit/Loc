<div class="flex flex-row items-center justify-between rounded-lg border border-gray-200 p-3 dark:border-gray-700">
          <Label for="{{testId}}">{{label}}</Label>
          <Toggle id="{{testId}}" data-testid="{{testId}}" bind:checked={form.values.{{path}} } />
          {#if form.errors["{{path}}"]}<Helper color="red">{form.errors["{{path}}"]}</Helper>{/if}
        </div>