<Label class="flex flex-col gap-2"><span>{{{labelText}}}</span>{{#if hasBind}}<Fileupload onchange={async (e) => { const file = (e.currentTarget as HTMLInputElement).files?.[0]; if (!file) { {{bind}} = null; return; } const fd = new FormData(); fd.append("file", file); {{bind}} = await api.upload("/files", fd); }}{{{testidAttr}}} />{{else}}<Fileupload{{{testidAttr}}} />{{/if}}{{#if hasError}}{#if ( {{{error}}} )}<p class="text-sm text-red-600">{ {{{error}}} }</p>{/if}{{/if}}</Label>
