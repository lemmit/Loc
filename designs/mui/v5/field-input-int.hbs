<Controller
          control={control}
          name="{{path}}"
          render={({ field, fieldState }) => (
            <TextField label="{{label}}" type="number" data-testid="{{testId}}" value={field.value ?? ""} onChange={(e) => field.onChange(e.target.value === "" ? 0 : parseInt(e.target.value, 10) || 0)} error={!!fieldState.error} helperText={fieldState.error?.message} inputProps=\{{ step: 1 }} />
          )}
        />