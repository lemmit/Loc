function {{opPascal}}Modal({ open, onClose, mut }: { open: boolean; onClose: () => void; mut: ReturnType<typeof use{{opPascal}}{{aggregateName}}> }) {
{{#each idHookCalls}}{{{this}}}
{{/each}}  const {{{destructured}}} = useForm<{{opPascal}}Request>({
    resolver: zodResolver({{opPascal}}Request),
    defaultValues: {{{defaultValuesTs}}},
  });
  return (
    <Dialog open={open} onClose={onClose} fullWidth maxWidth="sm">
      <form
        data-testid="{{slug}}-op-{{opName}}-form"
        onSubmit={handleSubmit(async (vals) => {
          try {
            await mut.mutateAsync(vals);
            enqueueSnackbar("{{humanOp}} succeeded", { variant: "success" });
            onClose();
          } catch (e) {
            enqueueSnackbar((e as Error).message, { variant: "error" });
          }
        })}
      >
        <DialogTitle>{{humanOp}}</DialogTitle>
        <DialogContent>
          <Stack gap={2} sx=\{{ pt: 1 }}>
            {{#if hasParams}}{{#each fieldHtmls}}{{{this}}}
            {{/each}}{{else}}<Typography>This operation has no parameters.</Typography>
            {{/if}}
          </Stack>
        </DialogContent>
        <DialogActions>
          <Button onClick={onClose}>Cancel</Button>
          <Button type="submit" variant="contained" disabled={mut.isPending} data-testid="{{slug}}-op-{{opName}}-submit">{{humanOp}}</Button>
        </DialogActions>
      </form>
    </Dialog>
  );
}
