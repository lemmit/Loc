{{#if columns.length}}<Card>
        <CardContent>
          <Stack gap={1}>
            <Stack direction="row" justifyContent="space-between" alignItems="center">
              <Typography variant="h6">{{humanName}}</Typography>
              <Typography variant="body2" color="text.secondary">{ {{{arrayExpr}}}.length === 1 ? "1 item" : {{{arrayExpr}}}.length + " items"}</Typography>
            </Stack>
            <TableContainer component={Paper} variant="outlined">
              <Table size="small" data-testid="{{testId}}">
                <TableHead>
                  <TableRow>
                    {{#each columns}}<TableCell>{{title}}</TableCell>
                    {{/each}}
                  </TableRow>
                </TableHead>
                <TableBody>
                  { {{{arrayExpr}}}.map((row) => (
                    <TableRow key={row.id} data-testid={`{{testId}}-row-${row.id}`}>
                      {{#each columns}}{{> (concat "cell-" kind)}}
                      {{/each}}
                    </TableRow>
                  ))}
                </TableBody>
              </Table>
            </TableContainer>
          </Stack>
        </CardContent>
      </Card>{{else}}<Card><CardContent><Typography variant="h6">{{humanName}}</Typography><Typography variant="body2" color="text.secondary" sx=\{{ mt: 1 }}>{JSON.stringify({{{arrayExpr}}})}</Typography></CardContent></Card>{{/if}}