{{#if hasBind}}<TextField label={{{labelAttr}}} type="file" InputLabelProps=\{{ shrink: true }} onChange={async (e) => { const f = (e.target as HTMLInputElement).files?.[0]; if (!f) { {{setter}}(null); return; } const fd = new FormData(); fd.append("file", f); {{setter}}(await api.upload("/files", fd)); }}{{#if hasError}} error={Boolean( {{{error}}} )} helperText={ {{{error}}} }{{/if}}{{{testidAttr}}} />{{else}}<TextField label={{{labelAttr}}} type="file" InputLabelProps=\{{ shrink: true }}{{#if hasError}} error={Boolean( {{{error}}} )} helperText={ {{{error}}} }{{/if}}{{{testidAttr}}} />{{/if}}
