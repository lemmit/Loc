function {{opPascal}}OpModal({ mut{{#if recordVar}}, record{{/if}} }: { mut: ReturnType<typeof use{{opPascal}}{{aggregateName}}>{{#if recordVar}}; record: {{recordType}}{{/if}} }) {
  const [open, setOpen] = useState(false);
{{#each idTargets}}  const {{this.hookVar}} = useAll{{this.namePlural}}();
{{/each}}  const {{{destructured}}} = useForm<{{opPascal}}{{aggregateName}}Request>({
    resolver: zodResolver({{opPascal}}{{aggregateName}}Request),
    defaultValues: {{{defaultValuesTs}}},
  });{{#each fieldArrays}}
  const { fields: {{this.name}}Fields, append: append{{this.pascal}}, remove: remove{{this.pascal}} } = useFieldArray({ control, name: "{{this.name}}" });{{/each}}
  return (
    <>
      <Button variant="{{#if triggerPrimary}}contained{{else}}outlined{{/if}}" onClick={() => setOpen(true)} data-testid="{{slug}}-op-{{opName}}">{{triggerLabel}}</Button>
      <Dialog open={open} onClose={() => setOpen(false)} fullWidth maxWidth="sm">
        <DialogTitle>{{humanOp}}</DialogTitle>
        <form
