/* Auto-generated.  Do not edit by hand.
   Spartan UI (shadcn-for-Angular) design language, authored as plain CSS so
   the project builds with `ng build` and no Tailwind toolchain.  The token set
   (HSL CSS variables, `--radius`, ring/muted/foreground) mirrors shadcn's
   neutral theme; the `.loom-*` classes shape the closed primitive library into
   that look.  The brand/accent shades projected from the system's
   `theme { … }` block override the primary token. */
:root {
  --background: 0 0% 100%;
  --foreground: 240 10% 3.9%;
  --card: 0 0% 100%;
  --card-foreground: 240 10% 3.9%;
  --primary: 240 5.9% 10%;
  --primary-foreground: 0 0% 98%;
  --secondary: 240 4.8% 95.9%;
  --secondary-foreground: 240 5.9% 10%;
  --muted: 240 4.8% 95.9%;
  --muted-foreground: 240 3.8% 46.1%;
  --accent: 240 4.8% 95.9%;
  --accent-foreground: 240 5.9% 10%;
  --destructive: 0 84.2% 60.2%;
  --destructive-foreground: 0 0% 98%;
  --border: 240 5.9% 90%;
  --input: 240 5.9% 90%;
  --ring: 240 5.9% 10%;
  --radius: 0.5rem;
  --loom-brand: {{brandShades.[6]}};
  --loom-accent: {{accentShades.[6]}};
}
html,
body {
  height: 100%;
}
body {
  margin: 0;
  font-family: {{{fontFamily}}};
  background: hsl(var(--background));
  color: hsl(var(--foreground));
  font-size: 0.875rem;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}
* {
  box-sizing: border-box;
}
h1,
h2,
h3,
h4,
h5,
h6 {
  font-weight: 600;
  letter-spacing: -0.01em;
  margin: 0;
}
.loom-stack {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.loom-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0.5rem;
}
.loom-toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
}
.loom-container {
  max-width: 64rem;
  margin: 0 auto;
  width: 100%;
}
.loom-paper {
  padding: 1rem;
  border: 1px solid hsl(var(--border));
  border-radius: var(--radius);
  background: hsl(var(--card));
}
.loom-card {
  border: 1px solid hsl(var(--border));
  border-radius: var(--radius);
  background: hsl(var(--card));
  color: hsl(var(--card-foreground));
  box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
}
.loom-card-title {
  padding: 1rem 1.5rem 0;
  font-weight: 600;
  font-size: 1rem;
  letter-spacing: -0.01em;
}
.loom-card-content {
  padding: 1.5rem;
}
.loom-stat {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
}
.loom-stat-label {
  font-size: 0.8rem;
  color: hsl(var(--muted-foreground));
}
.loom-stat-value {
  font-size: 1.5rem;
  font-weight: 600;
}
.loom-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  white-space: nowrap;
  border-radius: var(--radius);
  font-size: 0.875rem;
  font-weight: 500;
  height: 2.25rem;
  padding: 0 1rem;
  border: 1px solid transparent;
  cursor: pointer;
  transition: background-color 0.15s, color 0.15s, border-color 0.15s;
}
.loom-button:focus-visible {
  outline: 2px solid hsl(var(--ring));
  outline-offset: 2px;
}
.loom-button:disabled {
  opacity: 0.5;
  pointer-events: none;
}
.loom-button-primary {
  background: hsl(var(--primary));
  color: hsl(var(--primary-foreground));
}
.loom-button-primary:hover {
  background: hsl(var(--primary) / 0.9);
}
.loom-button-secondary {
  background: hsl(var(--background));
  color: hsl(var(--foreground));
  border-color: hsl(var(--border));
}
.loom-button-secondary:hover {
  background: hsl(var(--accent));
}
.loom-button-ghost {
  background: transparent;
  color: hsl(var(--foreground));
}
.loom-button-ghost:hover {
  background: hsl(var(--accent));
}
.loom-button-warn {
  background: hsl(var(--destructive));
  color: hsl(var(--destructive-foreground));
}
.loom-button-warn:hover {
  background: hsl(var(--destructive) / 0.9);
}
.loom-divider {
  border: none;
  border-top: 1px solid hsl(var(--border));
  margin: 0;
  height: 0;
}
.loom-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.125rem 0.625rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
  background: hsl(var(--primary));
  color: hsl(var(--primary-foreground));
  border: 1px solid transparent;
}
.loom-alert {
  padding: 0.75rem 1rem;
  border-radius: var(--radius);
  border: 1px solid hsl(var(--border));
  background: hsl(var(--background));
  color: hsl(var(--foreground));
}
.loom-alert-title {
  font-weight: 600;
  margin-bottom: 0.25rem;
}
.loom-alert-red {
  border-color: hsl(var(--destructive) / 0.5);
  color: hsl(var(--destructive));
}
.loom-alert-green {
  border-color: hsl(142 71% 45% / 0.5);
  color: hsl(142 71% 35%);
}
.loom-alert-yellow {
  border-color: hsl(38 92% 50% / 0.5);
  color: hsl(38 92% 38%);
}
.loom-alert-blue {
  border-color: hsl(221 83% 53% / 0.5);
  color: hsl(221 83% 45%);
}
.loom-inline-code {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 0.875em;
  background: hsl(var(--muted));
  padding: 0.125rem 0.375rem;
  border-radius: calc(var(--radius) - 0.25rem);
}
.loom-key-value-row {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.375rem 0;
  border-bottom: 1px solid hsl(var(--border));
}
.loom-kv-label {
  color: hsl(var(--muted-foreground));
}
.loom-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 10rem;
  color: hsl(var(--muted-foreground));
}
.loom-skeleton {
  background: hsl(var(--muted));
  border-radius: calc(var(--radius) - 0.25rem);
  animation: loom-skeleton-pulse 1.6s ease-in-out infinite;
}
.loom-skeleton-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
@keyframes loom-skeleton-pulse {
  50% {
    opacity: 0.5;
  }
}
.loom-avatar {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 9999px;
  object-fit: cover;
  display: inline-block;
}
.loom-avatar-empty {
  background: hsl(var(--muted));
}
.loom-image {
  max-width: 100%;
  height: auto;
  border-radius: var(--radius);
}
.loom-icon {
  display: inline-flex;
  align-items: center;
  width: 1.5rem;
  height: 1.5rem;
}
.loom-icon svg {
  width: 100%;
  height: 100%;
}
.loom-icon-xs {
  width: 1rem;
  height: 1rem;
}
.loom-icon-sm {
  width: 1.25rem;
  height: 1.25rem;
}
.loom-icon-lg {
  width: 2rem;
  height: 2rem;
}
.loom-icon-xl {
  width: 3rem;
  height: 3rem;
}
.loom-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
  gap: 1rem;
}
.loom-anchor {
  color: hsl(var(--primary));
  text-decoration: none;
  font-weight: 500;
}
.loom-anchor:hover {
  text-decoration: underline;
}
.loom-breadcrumbs {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: hsl(var(--muted-foreground));
}
.loom-code-block {
  background: hsl(240 10% 3.9%);
  color: hsl(0 0% 98%);
  border-radius: var(--radius);
  padding: 0.75rem 1rem;
  overflow: auto;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 0.85rem;
}
.loom-code-block-title {
  font-size: 0.8rem;
  color: hsl(0 0% 98% / 0.6);
  margin-bottom: 0.5rem;
}
.loom-code-block pre {
  margin: 0;
}
.loom-tabs {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.loom-tabs-list {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.25rem;
  border-radius: var(--radius);
  background: hsl(var(--muted));
  width: fit-content;
}
.loom-tab-trigger {
  padding: 0.375rem 0.75rem;
  border-radius: calc(var(--radius) - 0.125rem);
  font-size: 0.875rem;
  font-weight: 500;
  color: hsl(var(--muted-foreground));
  cursor: pointer;
  border: none;
  background: transparent;
}
.loom-tab-trigger[aria-selected="true"] {
  background: hsl(var(--background));
  color: hsl(var(--foreground));
  box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
}
.loom-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}
.loom-table th,
.loom-table td {
  text-align: left;
  padding: 0.625rem 0.75rem;
  border-bottom: 1px solid hsl(var(--border));
}
.loom-table th {
  font-weight: 500;
  color: hsl(var(--muted-foreground));
  height: 2.75rem;
}
.loom-table-striped tbody tr:nth-child(even) {
  background: hsl(var(--muted) / 0.4);
}
.loom-table-highlight tbody tr:hover {
  background: hsl(var(--muted) / 0.6);
}
.loom-table-sticky thead th {
  position: sticky;
  top: 0;
  background: hsl(var(--background));
  z-index: 1;
}
.loom-field {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  width: 100%;
}
.loom-label {
  font-size: 0.875rem;
  font-weight: 500;
  line-height: 1;
}
.loom-input {
  display: flex;
  width: 100%;
  height: 2.25rem;
  border-radius: var(--radius);
  border: 1px solid hsl(var(--input));
  background: hsl(var(--background));
  padding: 0 0.75rem;
  font-size: 0.875rem;
  color: hsl(var(--foreground));
}
.loom-input:focus-visible {
  outline: 2px solid hsl(var(--ring));
  outline-offset: 2px;
}
textarea.loom-input {
  height: auto;
  min-height: 4rem;
  padding: 0.5rem 0.75rem;
  font-family: inherit;
}
.loom-toggle {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
}
.loom-toggle input {
  width: 1rem;
  height: 1rem;
  accent-color: hsl(var(--primary));
}
.loom-spinner {
  display: inline-block;
  width: 2rem;
  height: 2rem;
  border: 2px solid hsl(var(--muted));
  border-top-color: hsl(var(--primary));
  border-radius: 9999px;
  animation: loom-spin 0.7s linear infinite;
}
.loom-spinner-xs {
  width: 1rem;
  height: 1rem;
}
.loom-spinner-sm {
  width: 1.25rem;
  height: 1.25rem;
}
.loom-spinner-lg {
  width: 3rem;
  height: 3rem;
}
.loom-spinner-xl {
  width: 4rem;
  height: 4rem;
}
@keyframes loom-spin {
  to {
    transform: rotate(360deg);
  }
}
