<label class="loom-field">{{#if labelText}}<span class="loom-label">{{{labelText}}}</span>{{/if}}<select class="loom-input"{{{testidAttr}}}{{#if hasBind}} [value]="{{bind}}()" (change)="{{bind}}.set($any($event.target).value)"{{/if}}>@for (opt of {{{optionsExpr}}}; track opt) {<option [value]="opt">\{{ opt }}</option>}</select>{{#if hasError}}@if ( {{{error}}} ) {<span class="loom-error">\{{ {{{error}}} }}</span>}{{/if}}</label>
