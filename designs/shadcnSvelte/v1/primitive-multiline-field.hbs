{{#if hasBind}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><textarea class="loom-input min-h-20" value={{expr bind}} oninput={(e) => { {{bind}} = e.currentTarget.value; }}{{{testidAttr}}}></textarea></label>{{else}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><textarea class="loom-input min-h-20"{{{testidAttr}}}></textarea></label>{{/if}}