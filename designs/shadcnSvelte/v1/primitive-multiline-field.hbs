{{#if hasBind}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><textarea class="loom-input min-h-20" value={{expr bind}} oninput={(e) => { {{bind}} = e.currentTarget.value; }}{{{testidAttr}}}></textarea>{{#if hasError}}{#if ( {{{error}}} )}<span class="text-sm text-red-500">{ {{{error}}} }</span>{/if}{{/if}}</label>{{else}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><textarea class="loom-input min-h-20"{{{testidAttr}}}></textarea>{{#if hasError}}{#if ( {{{error}}} )}<span class="text-sm text-red-500">{ {{{error}}} }</span>{/if}{{/if}}</label>{{/if}}