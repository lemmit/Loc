{
  "name": "shadcnSvelte",
  "version": "v1",
  "format": "svelte",
  "stack": "sv1",
  "emits": {
    "app-shell": "app-shell.hbs",
    "components-ui-Tabs": "components-ui-Tabs.hbs",
    "field-input-array": "field-input-array.hbs",
    "field-input-bool": "field-input-bool.hbs",
    "field-input-datetime": "field-input-datetime.hbs",
    "field-input-decimal": "field-input-decimal.hbs",
    "field-input-enum-select": "field-input-enum-select.hbs",
    "field-input-id-select": "field-input-id-select.hbs",
    "field-input-id-text": "field-input-id-text.hbs",
    "field-input-int": "field-input-int.hbs",
    "field-input-money": "field-input-money.hbs",
    "field-input-string": "field-input-string.hbs",
    "field-input-valueobject": "field-input-valueobject.hbs",
    "form-default-onsubmit": "form-default-onsubmit.hbs",
    "form-of-decls": "form-of-decls.hbs",
    "form-op-decls": "form-op-decls.hbs",
    "form-op-module": "form-op-module.hbs",
    "form-runs-decls": "form-runs-decls.hbs",
