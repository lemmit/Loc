{{#if hasBind}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><input type="password" class="loom-input" value={{expr bind}} oninput={(e) => { {{bind}} = e.currentTarget.value; }}{{{testidAttr}}} /></label>{{else}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><input type="password" class="loom-input"{{{testidAttr}}} /></label>{{/if}}