{{#if hasBind}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><select class="loom-input" value={{expr bind}} onchange={(e) => { {{bind}} = e.currentTarget.value; }}{{{testidAttr}}}><option value="" disabled>Select…</option>{#each ({{{optionsExpr}}}) as __v (__v)}<option value={__v}>{__v}</option>{/each}</select></label>{{else}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><select class="loom-input"{{{testidAttr}}}><option value="" disabled>Select…</option>{#each ({{{optionsExpr}}}) as __v (__v)}<option value={__v}>{__v}</option>{/each}</select></label>{{/if}}