{{#if hasBind}}<label class="flex items-center gap-2"><input type="checkbox" role="switch" class="loom-switch" checked={{expr bind}} onchange={(e) => { {{bind}} = e.currentTarget.checked; }}{{{testidAttr}}} /><span class="loom-label">{{{labelText}}}</span></label>{{else}}<label class="flex items-center gap-2"><input type="checkbox" role="switch" class="loom-switch"{{{testidAttr}}} /><span class="loom-label">{{{labelText}}}</span></label>{{/if}}