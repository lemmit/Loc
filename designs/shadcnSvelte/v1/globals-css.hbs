/* Auto-generated.  Do not edit by hand. */
@import "tailwindcss";
@import "./theme.css";

:root {
  --background: 0 0% 100%;
  --foreground: 240 10% 3.9%;
  --card: 0 0% 100%;
  --card-foreground: 240 10% 3.9%;
  --primary: 240 5.9% 10%;
  --primary-foreground: 0 0% 98%;
  --muted: 240 4.8% 95.9%;
  --muted-foreground: 240 3.8% 46.1%;
  --accent: 240 4.8% 95.9%;
  --accent-foreground: 240 5.9% 10%;
  --destructive: 0 84.2% 60.2%;
  --border: 240 5.9% 90%;
  --ring: 240 5.9% 10%;
}

@theme {
  --color-background: hsl(var(--background));
  --color-foreground: hsl(var(--foreground));
  --color-card: hsl(var(--card));
  --color-card-foreground: hsl(var(--card-foreground));
  --color-primary: var(--loom-primary);
  --color-primary-foreground: hsl(var(--primary-foreground));
  --color-muted: hsl(var(--muted));
  --color-muted-foreground: hsl(var(--muted-foreground));
  --color-accent: hsl(var(--accent));
  --color-accent-foreground: hsl(var(--accent-foreground));
  --color-destructive: hsl(var(--destructive));
  --color-border: hsl(var(--border));
  --color-ring: hsl(var(--ring));
  --radius: var(--loom-radius);
  --font-sans: var(--loom-font-family);
  --font-mono: var(--loom-font-family-mono);
}

body {
  background-color: hsl(var(--background));
  color: hsl(var(--foreground));
  font-family: var(--loom-font-family);
}

/* shadcn-style control primitives (hand-rolled — no component deps). */
.loom-label {
  font-size: 0.875rem;
  font-weight: 500;
  line-height: 1;
}
.loom-input {
  display: flex;
  width: 100%;
  height: 2.25rem;
  border-radius: var(--loom-radius);
  border: 1px solid hsl(var(--border));
  background: transparent;
  padding: 0.25rem 0.75rem;
  font-size: 0.875rem;
}
.loom-input:focus-visible {
  outline: 2px solid hsl(var(--ring));
  outline-offset: 1px;
}
textarea.loom-input {
  height: auto;
}
.loom-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  white-space: nowrap;
  border-radius: var(--loom-radius);
  font-size: 0.875rem;
  font-weight: 500;
  height: 2.25rem;
  padding: 0 1rem;
  transition: background-color 120ms ease, color 120ms ease;
  cursor: pointer;
}
.loom-btn:disabled {
  pointer-events: none;
  opacity: 0.5;
}
.loom-btn-primary {
  background: var(--loom-primary);
  color: white;
  border: 1px solid transparent;
}
.loom-btn-primary:hover {
  filter: brightness(1.08);
}
.loom-btn-outline {
  background: transparent;
  border: 1px solid hsl(var(--border));
}
.loom-btn-outline:hover {
  background: hsl(var(--accent));
}
.loom-btn-ghost {
  background: transparent;
  border: 1px solid transparent;
}
.loom-btn-ghost:hover {
  background: hsl(var(--accent));
}
.loom-switch {
  appearance: none;
  width: 2.25rem;
  height: 1.25rem;
  border-radius: 9999px;
  background: hsl(var(--muted));
  position: relative;
  cursor: pointer;
  transition: background-color 120ms ease;
}
.loom-switch:checked {
  background: var(--loom-primary);
}
.loom-switch::after {
  content: "";
  position: absolute;
  top: 2px;
  left: 2px;
  width: 1rem;
  height: 1rem;
  border-radius: 9999px;
  background: white;
  box-shadow: 0 1px 2px rgb(0 0 0 / 0.2);
  transition: transform 120ms ease;
}
.loom-switch:checked::after {
  transform: translateX(1rem);
}
.loom-icon svg {
  width: 1em;
  height: 1em;
}
.loom-icon-sm svg { width: 0.875em; height: 0.875em; }
.loom-icon-lg svg { width: 1.5em; height: 1.5em; }
.text-destructive { color: hsl(var(--destructive)); }
