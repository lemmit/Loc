{{#if rowFields}}
<div class="flex flex-col gap-2">
          <span class="loom-label">{{label}}</span>
          {#each form.values.{{path}} as row, index}
          <div class="flex gap-2 items-end">
            {{#each rowFields}}{{#if (eq template "field-input-int")}}<input type="number" step="1" class="loom-input" placeholder="{{label}}" value={form.values.{{../path}}[index].{{path}} } oninput={(e) => { form.values.{{../path}}[index].{{path}} = e.currentTarget.value === "" ? 0 : parseInt(e.currentTarget.value, 10) || 0; }} />{{else}}{{#if (eq template "field-input-decimal")}}<input type="number" step="0.01" class="loom-input" placeholder="{{label}}" value={form.values.{{../path}}[index].{{path}} } oninput={(e) => { form.values.{{../path}}[index].{{path}} = Number(e.currentTarget.value) || 0; }} />{{else}}<input class="loom-input" placeholder="{{label}}" bind:value={form.values.{{../path}}[index].{{path}} } />{{/if}}{{/if}}{{/each}}<button type="button" class="loom-btn" onclick={() => form.values.{{path}}.splice(index, 1)}>Remove</button>
          </div>
          {/each}
          <button type="button" class="loom-btn" onclick={() => form.values.{{path}}.push({{{defaultRowJson}}})}>Add {{elementLabel}}</button>
        </div>
{{else}}
<div class="flex flex-col gap-2">
          <label class="loom-label" for="{{testId}}">{{label}}</label>
          <input id="{{testId}}" class="loom-input" data-testid="{{testId}}" placeholder="(arrays not yet supported in forms)" disabled />
        </div>
{{/if}}
