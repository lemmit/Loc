<div class="flex flex-col gap-2">
          <label class="loom-label" for="{{testId}}">{{label}}</label>
          <input id="{{testId}}" type="number" step="0.01" class="loom-input" data-testid="{{testId}}" value={form.values.{{path}} } oninput={(e) => { form.values.{{path}} = e.currentTarget.value === "" ? 0 : parseFloat(e.currentTarget.value) || 0; }} />
          {#if form.errors["{{path}}"]}<p class="text-sm text-destructive">{form.errors["{{path}}"]}</p>{/if}
        </div>