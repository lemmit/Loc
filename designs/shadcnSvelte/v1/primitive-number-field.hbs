{{#if hasBind}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><input type="number" class="loom-input" value={{expr bind}} oninput={(e) => { {{bind}} = Number(e.currentTarget.value) || 0; }}{{{testidAttr}}} /></label>{{else}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><input type="number" class="loom-input"{{{testidAttr}}} /></label>{{/if}}