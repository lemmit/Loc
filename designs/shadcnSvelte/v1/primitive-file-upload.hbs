{{#if hasBind}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><input type="file" class="loom-input" onchange={async (e) => { const file = e.currentTarget.files?.[0]; if (!file) { {{bind}} = null; return; } const fd = new FormData(); fd.append("file", file); {{bind}} = await api.upload("/files", fd); }}{{{testidAttr}}} />{{#if hasError}}{#if ( {{{error}}} )}<span class="text-sm text-red-500">{ {{{error}}} }</span>{/if}{{/if}}</label>{{else}}<label class="flex flex-col gap-2"><span class="loom-label">{{{labelText}}}</span><input type="file" class="loom-input"{{{testidAttr}}} />{{#if hasError}}{#if ( {{{error}}} )}<span class="text-sm text-red-500">{ {{{error}}} }</span>{/if}{{/if}}</label>{{/if}}
