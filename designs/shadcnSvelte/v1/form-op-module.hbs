{#snippet {{opCamel}}OpModal(form: LoomForm<{{opPascal}}{{aggregateName}}Request>)}
  <button type="button" class="loom-btn {{#if triggerPrimary}}loom-btn-primary{{else}}loom-btn-outline{{/if}}" onclick={() => { {{opCamel}}ModalOpen = true; }} data-testid="{{slug}}-op-{{opName}}">{{triggerLabel}}</button>
  {#if {{opCamel}}ModalOpen}
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
      <div class="w-full max-w-md rounded-xl border bg-background p-6 shadow-lg" role="dialog" aria-modal="true" aria-labelledby="{{slug}}-op-{{opName}}-title" tabindex="-1" data-testid="{{slug}}-op-{{opName}}-form" use:modalTrap={() => { {{opCamel}}ModalOpen = false; }}>
        <h3 id="{{slug}}-op-{{opName}}-title" class="mb-4 text-lg font-semibold">{{humanOp}}</h3>
        <form onsubmit={(e) => { e.preventDefault(); form.submit(async (vals) => {
          try {
            await {{opCamel}}.mutateAsync(vals);
            toast.success("{{humanOp}} succeeded");
            {{opCamel}}ModalOpen = false;
          } catch (err) {
            const outcome = form.applyServerErrors(err);
            if (outcome.kind === "global") {
              toast.error(outcome.title);
            } else if (outcome.kind === "unhandled") {
              toast.error((err as Error).message);
            }
          }
        }); }}>
          <div class="flex flex-col gap-4">
            {{#if hasParams}}{{#each fieldHtmls}}{{{this}}}
            {{/each}}{{else}}<p class="text-sm text-muted-foreground">This operation has no parameters.</p>
            {{/if}}<div class="flex justify-end gap-2 pt-2">
              <button type="button" class="loom-btn loom-btn-outline" onclick={() => { {{opCamel}}ModalOpen = false; }}>Cancel</button>
              <button type="submit" class="loom-btn loom-btn-primary" disabled={ {{opCamel}}.isPending } data-testid="{{slug}}-op-{{opName}}-submit">{{humanOp}}</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  {/if}
{/snippet}