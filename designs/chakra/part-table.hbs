{{#if columns.length}}<Card variant="outline">
        <CardBody>
          <VStack gap={2} alignItems="stretch">
            <HStack justifyContent="space-between" alignItems="center">
              <Heading size="sm">{{humanName}}</Heading>
              <Text fontSize="sm" color="gray.500">{ {{{arrayExpr}}}.length === 1 ? "1 item" : {{{arrayExpr}}}.length + " items"}</Text>
            </HStack>
            <TableContainer borderWidth="1px" borderRadius="md">
              <Table size="sm" data-testid="{{testId}}">
                <Thead>
                  <Tr>
                    {{#each columns}}<Th>{{title}}</Th>
                    {{/each}}
                  </Tr>
                </Thead>
                <Tbody>
                  { {{{arrayExpr}}}.map((row) => (
                    <Tr key={row.id} data-testid={`{{testId}}-row-${row.id}`}>
                      {{#each columns}}{{> (concat "cell-" kind)}}
                      {{/each}}
                    </Tr>
                  ))}
                </Tbody>
              </Table>
            </TableContainer>
          </VStack>
        </CardBody>
      </Card>{{else}}<Card variant="outline"><CardBody><Heading size="sm">{{humanName}}</Heading><Text fontSize="sm" color="gray.500" mt={2}>{JSON.stringify({{{arrayExpr}}})}</Text></CardBody></Card>{{/if}}