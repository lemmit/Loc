<Controller
          control={control}
          name="{{path}}"
          render={({ field, fieldState }) => (
            <Field.Root invalid={!!fieldState.error}>
              <Field.Label>{{label}}</Field.Label>
              <Input type="text" inputMode="decimal" pattern="^-?\d+(\.\d+)?$" value={field.value instanceof Decimal ? field.value.toString() : String(field.value ?? "0")} onChange={(e) => { try { field.onChange(new Decimal(e.target.value || "0")); } catch { field.onChange(new Decimal("0")); } }} data-testid="{{testId}}" />
              <Field.ErrorText>{fieldState.error?.message}</Field.ErrorText>
            </Field.Root>
          )}
        />
