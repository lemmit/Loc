{{#if hasBind}}<Field.Root{{#if hasError}} invalid={Boolean( {{{error}}} )}{{/if}}{{{testidAttr}}}><Field.Label>{{{labelAttr}}}</Field.Label><Input type="file" onChange={async (e) => { const f = e.target.files?.[0]; if (!f) { {{setter}}(null); return; } const fd = new FormData(); fd.append("file", f); {{setter}}(await api.upload("/files", fd)); }} />{{#if hasError}}<Field.ErrorText>{ {{{error}}} }</Field.ErrorText>{{/if}}</Field.Root>{{else}}<Field.Root{{{testidAttr}}}><Field.Label>{{{labelAttr}}}</Field.Label><Input type="file" /></Field.Root>{{/if}}
