function {{opPascal}}Modal({ open, onClose, mut }: { open: boolean; onClose: () => void; mut: ReturnType<typeof use{{opPascal}}{{aggregateName}}> }) {
{{#each idHookCalls}}{{{this}}}
{{/each}}  const toast = useToast();
  const {{{destructured}}} = useForm<{{opPascal}}Request>({
    resolver: zodResolver({{opPascal}}Request),
    defaultValues: {{{defaultValuesTs}}},
  });
  return (
    <Modal isOpen={open} onClose={onClose} size="md">
      <ModalOverlay />
      <ModalContent>
        <form
          data-testid="{{slug}}-op-{{opName}}-form"
          onSubmit={handleSubmit(async (vals) => {
            try {
              await mut.mutateAsync(vals);
              toast({ title: "{{humanOp}} succeeded", status: "success", duration: 3000, isClosable: true });
              onClose();
            } catch (e) {
              toast({ title: (e as Error).message, status: "error", duration: 5000, isClosable: true });
            }
          })}
        >
          <ModalHeader>{{humanOp}}</ModalHeader>
          <ModalCloseButton />
          <ModalBody>
            <VStack gap={4}>
              {{#if hasParams}}{{#each fieldHtmls}}{{{this}}}
              {{/each}}{{else}}<Text>This operation has no parameters.</Text>
              {{/if}}
            </VStack>
          </ModalBody>
          <ModalFooter gap={2}>
            <Button variant="ghost" onClick={onClose}>Cancel</Button>
            <Button type="submit" colorScheme="brand" isLoading={mut.isPending} data-testid="{{slug}}-op-{{opName}}-submit">{{humanOp}}</Button>
          </ModalFooter>
        </form>
      </ModalContent>
    </Modal>
  );
}
