<Controller
          control={control}
          name="{{path}}"
          render={({ field }) => (
            <FormControl display="flex" alignItems="center">
              <FormLabel mb={0}>{{label}}</FormLabel>
              <Switch isChecked={!!field.value} onChange={(e) => field.onChange(e.target.checked)} data-testid="{{testId}}" />
            </FormControl>
          )}
        />