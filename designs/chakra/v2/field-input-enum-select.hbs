<Controller
          control={control}
          name="{{path}}"
          render={({ field, fieldState }) => (
            <FormControl isInvalid={!!fieldState.error}>
              <FormLabel>{{label}}</FormLabel>
              <Select data-testid="{{testId}}" value={field.value as string ?? ""} onChange={(e) => field.onChange(e.target.value)}>
                <option value="">— select —</option>
                { ({{{enumValuesJson}}}).map((v) => <option key={v} value={v}>{v}</option>) }
              </Select>
              <FormErrorMessage>{fieldState.error?.message}</FormErrorMessage>
            </FormControl>
          )}
        />