{{#if hasBind}}<FormControl{{{testidAttr}}}><FormLabel>{{{labelAttr}}}</FormLabel><NumberInput value={{expr bind}} onChange={(_s, n) => {{setter}}(Number.isNaN(n) ? 0 : n)}><NumberInputField /></NumberInput></FormControl>{{else}}<FormControl{{{testidAttr}}}><FormLabel>{{{labelAttr}}}</FormLabel><NumberInput><NumberInputField /></NumberInput></FormControl>{{/if}}