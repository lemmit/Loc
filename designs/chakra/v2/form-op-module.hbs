function {{opPascal}}OpModal({ mut{{#if recordVar}}, record{{/if}} }: { mut: ReturnType<typeof use{{opPascal}}{{aggregateName}}>{{#if recordVar}}; record: {{recordType}}{{/if}} }) {
  const { isOpen, onOpen, onClose } = useDisclosure();
  const toast = useToast();
{{#each idTargets}}  const {{this.hookVar}} = useAll{{this.namePlural}}();
{{/each}}  const {{{destructured}}} = useForm<{{opPascal}}{{aggregateName}}Request>({
    resolver: zodResolver({{opPascal}}{{aggregateName}}Request),
    defaultValues: {{{defaultValuesTs}}},
  });{{#each fieldArrays}}
  const { fields: {{this.name}}Fields, append: append{{this.pascal}}, remove: remove{{this.pascal}} } = useFieldArray({ control, name: "{{this.name}}" });{{/each}}
  return (
    <>
      <Button colorScheme="brand" variant="{{#if triggerPrimary}}solid{{else}}outline{{/if}}" onClick={onOpen} data-testid="{{slug}}-op-{{opName}}">{{triggerLabel}}</Button>
      <Modal isOpen={isOpen} onClose={onClose}>
        <ModalOverlay />
        <ModalContent>
          <ModalHeader>{{humanOp}}</ModalHeader>
          <ModalCloseButton />
          <form
            data-testid="{{slug}}-op-{{opName}}-form"
            onSubmit={handleSubmit(async (vals) => {
              try {
                await mut.mutateAsync(vals);
                toast({ status: "success", description: "{{humanOp}} succeeded" });
                onClose();
              } catch (e) {
                const outcome = applyServerErrors({ error: e, setError, fieldMap: {} as const });
                if (outcome.kind === "global") {
                  toast({ status: "error", description: outcome.title });
                } else if (outcome.kind === "unhandled") {
                  toast({ status: "error", description: (e as Error).message });
                }
              }
            })}
          >
            <ModalBody>
              <VStack gap={4}>
                {{#if hasParams}}{{#each fieldHtmls}}{{{this}}}
                {{/each}}{{else}}<Text color="gray.500">This operation has no parameters.</Text>
                {{/if}}</VStack>
            </ModalBody>
            <ModalFooter gap={2}>
              <Button type="button" variant="ghost" onClick={onClose}>Cancel</Button>
              <Button type="submit" colorScheme="brand" isLoading={mut.isPending} data-testid="{{slug}}-op-{{opName}}-submit">{{humanOp}}</Button>
            </ModalFooter>
          </form>
        </ModalContent>
      </Modal>
    </>
  );
}
