// `@chakra-ui/icons` is intentionally NOT a dep here: its v2 release
// (the only one that ships HamburgerIcon under that import name)
// declares `peerDependency: "@chakra-ui/react": ">=2.0.0"`, which esm.sh
// resolves to the latest matching version (3.x) — that branch dropped
// `forwardRef` and the bundle fails with "No matching export … for
// import 'forwardRef'".  Inlining the SVG sidesteps the peerDep
// without pulling another icon library.
function HamburgerIcon(): JSX.Element {
  return (
    <svg viewBox="0 0 24 24" width="1em" height="1em" fill="currentColor" aria-hidden="true">
      <path d="M3 6h18v2H3zM3 11h18v2H3zM3 16h18v2H3z" />
    </svg>
  );
}

const DRAWER_WIDTH = "240px";

class AppErrorBoundary extends React.Component<
  { children: React.ReactNode },
  { error: Error | null }
> {
  state = { error: null as Error | null };
  static getDerivedStateFromError(error: Error) {
    return { error };
  }
  override componentDidCatch(error: Error, info: React.ErrorInfo) {
    // eslint-disable-next-line no-console
    console.error("App error boundary caught:", error, info.componentStack);
  }
  override render() {
    if (this.state.error) {
      return (
        <VStack data-testid="app-error" p={4} gap={2} alignItems="flex-start">
          <Alert status="error">
            <AlertIcon />
            <AlertDescription>{this.state.error.message}</AlertDescription>
          </Alert>
          <Box>
            <Button
              variant="outline"
              onClick={() => {
                this.setState({ error: null });
                window.location.assign("/");
              }}
            >
              Back to home
            </Button>
          </Box>
        </VStack>
      );
    }
    return this.props.children;
  }
}

function NotFound() {
  return (
    <VStack data-testid="not-found" p={4} gap={1} alignItems="flex-start">
      <Heading size="md">Not found</Heading>
      <RouterLink to="/">← Back to home</RouterLink>
    </VStack>
  );
}

function useIsActive() {
  const location = useLocation();
  return (path: string, opts?: { exact?: boolean }) => {
    if (opts?.exact) return location.pathname === path;
    return (
      location.pathname === path || location.pathname.startsWith(path + "/")
    );
  };
}

