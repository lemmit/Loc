<%!-- field-row-valueobject: key-value rows for a value-object field --%>
<div class="space-y-2" data-testid="{{testId}}">
  <p class="text-sm font-medium text-gray-500">{{label}}</p>
  <div class="ml-4 space-y-2 border-l-2 border-gray-100 pl-4">
    {{#each voFields}}
    <div class="flex flex-col sm:flex-row sm:gap-4" data-testid="{{testId}}">
      <dt class="text-sm font-medium text-gray-500 sm:w-32 sm:flex-shrink-0">{{humanLabel}}</dt>
      <dd class="text-sm text-gray-900"><%= {{valueExpr}} || "—" %></dd>
    </div>
    {{/each}}
  </div>
</div>
