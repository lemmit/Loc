<%!-- field-row-enum: key-value row for an enum field --%>
<div class="flex flex-col sm:flex-row sm:gap-4" data-testid="{{testId}}">
  <dt class="text-sm font-medium text-gray-500 sm:w-40 sm:flex-shrink-0">{{label}}</dt>
  <dd class="text-sm text-gray-900">
    <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
      <%= {{valueExpr}} %>
    </span>
  </dd>
</div>
