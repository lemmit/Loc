<%!-- Auto-generated. Operation modal form. Rendered per-operation inside page-detail. --%>
<.modal id={"modal-#{@op_name}"} :if={@active_modal == @op_name}>
  <:title><%= @human_op %></:title>
  <.simple_form for={@op_form} phx-submit={"submit_op_#{@op_name}"} phx-change={"validate_op_#{@op_name}"}>
    <%= if @has_params do %>
      <%!-- Field inputs are injected by the LiveView emitter (Phase 7) --%>
    <% else %>
      <p class="text-sm text-gray-500">This operation has no parameters.</p>
    <% end %>
    <:actions>
      <.button type="button" phx-click="close_modal" class="btn-secondary">Cancel</.button>
      <.button type="submit" data-testid={"#{@slug}-op-#{@op_name}-submit"} phx-disable-with="Running…">
        <%= @human_op %>
      </.button>
    </:actions>
  </.simple_form>
</.modal>
