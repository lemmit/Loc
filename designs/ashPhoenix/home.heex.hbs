<%!-- Auto-generated. Landing page for {{systemNameHuman}}. --%>
<div data-testid="home" class="space-y-6">
  <div class="space-y-1">
    <p class="text-sm font-semibold uppercase tracking-wide text-gray-400">{{systemNameHuman}}</p>
    <h2 class="text-2xl font-semibold tracking-tight">Welcome</h2>
    <p class="text-gray-500">Pick a section from the sidebar to start, or jump straight in below.</p>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <div class="space-y-1.5">
        <p class="font-semibold">
          {{aggregateCount}} aggregate{{#unless (eq aggregateCount 1)}}s{{/unless}}
        </p>
        <p class="text-sm text-gray-500">Manage records of each kind from the sidebar.</p>
        {{#if firstAggregateSlug}}
        <.link navigate="/{{firstAggregateSlug}}" data-testid="home-aggregates-link" class="text-sm text-blue-600 hover:underline">
          Browse the sidebar →
        </.link>
        {{/if}}
      </div>
    </div>

    {{#if workflowCount}}
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <div class="space-y-1.5">
        <p class="font-semibold">
          {{workflowCount}} workflow{{#unless (eq workflowCount 1)}}s{{/unless}}
        </p>
        <p class="text-sm text-gray-500">System-level orchestrations you can run from a form.</p>
        <.link navigate="/workflows" data-testid="home-workflows-link" class="text-sm text-blue-600 hover:underline">
          Open workflows →
        </.link>
      </div>
    </div>
    {{/if}}

    {{#if viewCount}}
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
      <div class="space-y-1.5">
        <p class="font-semibold">
          {{viewCount}} view{{#unless (eq viewCount 1)}}s{{/unless}}
        </p>
        <p class="text-sm text-gray-500">Saved queries — open one to inspect rows.</p>
        <.link navigate="/views" data-testid="home-views-link" class="text-sm text-blue-600 hover:underline">
          Open views →
        </.link>
      </div>
    </div>
    {{/if}}
  </div>
</div>
