<%!-- cell-bool: renders a boolean as a badge --%>
<td data-testid={{{testIdExpr}}} class="px-4 py-3 text-sm">
  <%= if {{valueExpr}} do %>
    <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">Yes</span>
  <% else %>
    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">No</span>
  <% end %>
</td>
