<%!-- Auto-generated. Detail page for a single {{humanAgg}}. --%>
<div data-testid="{{slug}}-detail" class="space-y-4">
  <nav aria-label="breadcrumb" data-testid="{{slug}}-detail-breadcrumbs">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li class="flex items-center gap-2">
        <.link navigate="/" class="hover:text-gray-900 hover:underline">Home</.link>
        <span aria-hidden="true">/</span>
      </li>
      <li class="flex items-center gap-2">
        <.link navigate="/{{slug}}" class="hover:text-gray-900 hover:underline">{{humanPlural}}</.link>
        <span aria-hidden="true">/</span>
      </li>
      <li><span class="text-gray-900 font-medium"><%= {{titleExpr}} %></span></li>
    </ol>
  </nav>

  <div class="flex items-end justify-between">
    <div class="space-y-0.5">
      <p class="text-sm font-semibold uppercase tracking-wide text-gray-400">{{humanAgg}}</p>
      <div class="flex items-center gap-3">
        <h2 class="text-2xl font-semibold tracking-tight" data-testid="{{slug}}-detail-title">
          <%= {{titleExpr}} %>
        </h2>
        <span class="font-mono text-xs text-gray-400" data-testid="{{slug}}-detail-id">
          <%= String.slice(@record.id, 0, 8) %>…
        </span>
      </div>
    </div>
    {{#if opButtons}}
    <div class="flex items-center gap-2" data-testid="{{slug}}-detail-ops">
      {{#each opButtons}}{{> op-button this}}{{/each}}
    </div>
    {{/if}}
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {{#each fieldRows}}{{> (lookup . "template") this}}{{/each}}
    </dl>
  </div>

  {{#each parts}}{{> part-table this}}{{/each}}

  <%!-- Operation modals — one per operation. Shown when @active_modal == "<op_name>". --%>
  {{#each opButtons}}
  <.modal id="modal-{{name}}" :if={@active_modal == "{{name}}"}>
    <:title>{{humanName}}</:title>
    <.simple_form for={@op_form} phx-submit="submit_op_{{name}}" phx-change="validate_op_{{name}}">
      <%!-- Field inputs injected by Phase 7 LiveView emitter --%>
      <:actions>
        <.button type="button" phx-click="close_modal" class="btn-secondary">Cancel</.button>
        <.button type="submit" data-testid="{{../slug}}-op-{{name}}-submit">{{humanName}}</.button>
      </:actions>
    </.simple_form>
  </.modal>
  {{/each}}
</div>
