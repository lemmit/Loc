<%!-- field-row-id-link: key-value row for a navigable id field --%>
<div class="flex flex-col sm:flex-row sm:gap-4" data-testid="{{testId}}">
  <dt class="text-sm font-medium text-gray-500 sm:w-40 sm:flex-shrink-0">{{label}}</dt>
  <dd class="text-sm">
    <.link navigate={{{toExpr}}} class="font-mono text-blue-600 hover:underline">
      <%= {{valueExpr}} || "—" %>
    </.link>
  </dd>
</div>
