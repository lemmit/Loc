<%!-- Auto-generated. Workflows index page (/workflows). --%>
<div data-testid="workflows-index" class="space-y-4">
  <nav aria-label="breadcrumb" data-testid="workflows-index-breadcrumbs">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li class="flex items-center gap-2">
        <.link navigate="/" class="hover:text-gray-900 hover:underline">Home</.link>
        <span aria-hidden="true">/</span>
      </li>
      <li><span class="text-gray-900 font-medium">Workflows</span></li>
    </ol>
  </nav>

  <div class="space-y-0.5">
    <h2 class="text-2xl font-semibold tracking-tight">Workflows</h2>
    <p class="text-gray-500">System-level orchestrations. Pick one to run.</p>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {{#each cards}}
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm" data-testid="workflow-card-{{slug}}">
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-blue-600" aria-hidden="true">
              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0 1 12 2v5h4a1 1 0 0 1 .82 1.573l-7 10A1 1 0 0 1 8 18v-5H4a1 1 0 0 1-.82-1.573l7-10a1 1 0 0 1 1.12-.38Z" clip-rule="evenodd" />
            </svg>
            <h3 class="text-base font-semibold">{{humanWorkflow}}</h3>
          </div>
          <.link navigate="/workflows/{{slug}}"
                 data-testid="workflow-{{slug}}-run"
                 class="inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500">
            Run →
          </.link>
        </div>
        {{#if hasParams}}
        <div class="space-y-1">
          {{#each params}}
          <p class="text-sm text-gray-500" data-testid="workflow-{{../slug}}-param-{{name}}">
            <strong class="font-medium text-gray-700">{{humanName}}</strong>: <code class="font-mono text-xs">{{typeLabelJson}}</code>
          </p>
          {{/each}}
        </div>
        {{else}}
        <p class="text-sm text-gray-500">No parameters.</p>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>
</div>
