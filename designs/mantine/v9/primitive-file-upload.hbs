{{#if hasBind}}<FileInput label={{{labelAttr}}} clearable placeholder={ {{bind}}?.key ?? "Choose file" } onChange={async (f) => { if (!f) { {{setter}}(null); return; } const fd = new FormData(); fd.append("file", f); {{setter}}(await api.upload("/files", fd)); }}{{#if hasError}} error={ {{{error}}} }{{/if}}{{{testidAttr}}} />{{else}}<FileInput label={{{labelAttr}}}{{#if hasError}} error={ {{{error}}} }{{/if}}{{{testidAttr}}} />{{/if}}
