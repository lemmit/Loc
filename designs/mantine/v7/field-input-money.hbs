<Controller
          control={control}
          name="{{path}}"
          render={({ field, fieldState }) => (
            <TextInput label="{{label}}" data-testid="{{testId}}" value={field.value instanceof Decimal ? field.value.toString() : String(field.value ?? "0")} onChange={(e) => { try { field.onChange(new Decimal(e.currentTarget.value || "0")); } catch { field.onChange(new Decimal("0")); } }} inputMode="decimal" error={fieldState.error?.message} />
          )}
        />
