}

// Active-route helper — drives sidebar NavLink active styling.
// Defaults to a prefix match so /orders/<id> + /orders/new + /orders
// keep the "Orders" link highlighted; the `exact` opt-in narrows
// to literal equality (used by /workflows + /views index links).
function useIsActive() {
  const location = useLocation();
  return (path: string, opts?: { exact?: boolean }) => {
    if (opts?.exact) return location.pathname === path;
    return (
      location.pathname === path || location.pathname.startsWith(path + "/")
    );
  };
}

interface NavLinkProps {
  to: string;
  label: string;
  active: boolean;
  testId: string;
}

function NavLink({ to, label, active, testId }: NavLinkProps) {
  return (
    <RouterLink
      to={to}
      data-testid={testId}
      className={cn(
        "rounded-md px-3 py-2 text-sm font-medium transition-colors",
        active
          ? "bg-accent text-accent-foreground"
          : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
      )}
    >
      {label}
    </RouterLink>
  );
}

// Default app chrome — header + sidebar + main with an Outlet that
// React Router fills with the active in-shell child route.  Pages
// declared with `layout: none` mount as sibling routes outside this
// wrapper (see `App()` below) so they get no header / sidebar /
// padding.
function AppShellLayout() {
  const isActive = useIsActive();
{{#if navUsesSession}}  const currentUser = useSession().user as Record<string, any>;
{{/if}}  const [opened, setOpened] = useState(false);
  // Mobile UX: auto-close the sidebar after a route change.  Tapping
  // a NavLink on a phone otherwise leaves the menu covering the
  // destination page.  Desktop is unaffected — the sidebar is
  // permanently visible above the `sm` breakpoint.
  const location = useLocation();
  React.useEffect(() => {
    setOpened(false);
  }, [location.pathname]);
  return (
    <div className="flex min-h-screen flex-col">
      {/* Skip link (WCAG 2.4.1 Bypass Blocks) — first focusable element,
          off-screen until focused, jumps to the <main> landmark. */}
      <a
        href="#main-content"
        className="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:border focus:bg-background focus:px-4 focus:py-2 focus:text-sm focus:font-medium"
      >
        Skip to content
      </a>
      <header className="sticky top-0 z-40 flex h-14 items-center gap-4 border-b bg-background px-4 lg:px-6">
        <Button
          variant="ghost"
          size="icon"
          className="sm:hidden"
          onClick={() => setOpened(!opened)}
          data-testid="nav-burger"
          aria-label="Toggle navigation"
        >
          <Menu className="h-5 w-5" />
        </Button>
        <RouterLink to="/" className="flex items-center gap-2">
          <div className="h-7 w-7 rounded-md bg-primary" aria-hidden="true" />
          <span className="text-lg font-semibold tracking-tight">{{systemNameHuman}}</span>
        </RouterLink>
      </header>
      <div className="flex flex-1">
        <nav
          data-testid="nav-sidebar"
          aria-label="Primary navigation"
          className={cn(
            "w-60 shrink-0 border-r bg-background p-4 sm:block",
            opened ? "block" : "hidden",
          )}
        >
          <div className="flex flex-col gap-1">
{{#each navSections}}            <p className="mt-2 mb-1 px-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">{{label}}</p>
{{#each entries}}{{#if external}}            <a href="{{href}}" target="_blank" rel="noreferrer" data-testid="{{testId}}" className="rounded-md px-3 py-2 text-sm font-medium transition-colors text-muted-foreground hover:bg-accent hover:text-accent-foreground">{{label}}</a>{{else}}{{#if requiresJs}}            {({{{requiresJs}}}) ? <NavLink to="{{to}}" label="{{label}}" active={isActive({{{activeArgs}}})} testId="{{testId}}" /> : null}{{else}}            <NavLink to="{{to}}" label="{{label}}" active={isActive({{{activeArgs}}})} testId="{{testId}}" />{{/if}}{{/if}}
{{/each}}{{/each}}          </div>
        </nav>
        <main id="main-content" className="flex-1 p-4 lg:p-6">
          <AppErrorBoundary>
            <Outlet />
          </AppErrorBoundary>
        </main>
      </div>
    </div>
  );
}

