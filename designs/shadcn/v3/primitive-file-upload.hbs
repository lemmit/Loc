{{#if hasBind}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Input type="file" onChange={async (e) => { const f = e.target.files?.[0]; if (!f) { {{setter}}(null); return; } const fd = new FormData(); fd.append("file", f); {{setter}}(await api.upload("/files", fd)); }}{{{testidAttr}}} />{{#if hasError}}{( {{{error}}} ) ? <p className="text-sm text-destructive">{ {{{error}}} }</p> : null}{{/if}}</div>{{else}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Input type="file"{{{testidAttr}}} /></div>{{/if}}
