<FormField
          control={form.control}
          name="{{path}}"
          render={({ field }) => (
            <FormItem>
              <FormLabel>{{label}}</FormLabel>
              <FormControl>
                <Input
                  type="text"
                  inputMode="decimal"
                  pattern="^-?\d+(\.\d+)?$"
                  data-testid="{{testId}}"
                  value={field.value instanceof Decimal ? field.value.toString() : String(field.value ?? "0")}
                  onChange={(e) => { try { field.onChange(new Decimal(e.target.value || "0")); } catch { field.onChange(new Decimal("0")); } }}
                  onBlur={field.onBlur}
                  ref={field.ref}
                  name={field.name}
                />
              </FormControl>
              <FormMessage />
            </FormItem>
          )}
        />
