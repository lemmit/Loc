{{#if hasBind}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Input type="number" value={{expr bind}} onChange={(e) => {{setter}}(Number(e.currentTarget.value) || 0)}{{{testidAttr}}} />{{#if hasError}}{( {{{error}}} ) ? <p className="text-sm text-destructive">{ {{{error}}} }</p> : null}{{/if}}</div>{{else}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Input type="number"{{{testidAttr}}} />{{#if hasError}}{( {{{error}}} ) ? <p className="text-sm text-destructive">{ {{{error}}} }</p> : null}{{/if}}</div>{{/if}}