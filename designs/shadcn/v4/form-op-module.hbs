function {{opPascal}}OpModal({ mut{{#if recordVar}}, record{{/if}} }: { mut: ReturnType<typeof use{{opPascal}}{{aggregateName}}>{{#if recordVar}}; record: {{recordType}}{{/if}} }) {
  const [open, setOpen] = useState(false);
{{#each idTargets}}  const {{this.hookVar}} = useAll{{this.namePlural}}();
{{/each}}  const form = useForm<{{opPascal}}{{aggregateName}}Request>({
    resolver: zodResolver({{opPascal}}{{aggregateName}}Request),
    defaultValues: {{{defaultValuesTs}}},
  });{{#each fieldArrays}}
  const { fields: {{this.name}}Fields, append: append{{this.pascal}}, remove: remove{{this.pascal}} } = useFieldArray({ control: form.control, name: "{{this.name}}" });{{/each}}
  return (
    <Dialog open={open} onOpenChange={setOpen}>
      <DialogTrigger asChild>
        <Button variant="{{#if triggerPrimary}}default{{else}}secondary{{/if}}" data-testid="{{slug}}-op-{{opName}}">{{triggerLabel}}</Button>
      </DialogTrigger>
      <DialogContent data-testid="{{slug}}-op-{{opName}}-form">
        <DialogHeader>
          <DialogTitle>{{humanOp}}</DialogTitle>
        </DialogHeader>
        <Form {...form}>
          <form
            onSubmit={form.handleSubmit(async (vals) => {
              try {
                await mut.mutateAsync(vals);
                toast.success("{{humanOp}} succeeded");
                setOpen(false);
              } catch (e) {
                const outcome = applyServerErrors({ error: e, setError: form.setError, fieldMap: {} as const });
                if (outcome.kind === "global") {
                  toast.error(outcome.title);
                } else if (outcome.kind === "unhandled") {
                  toast.error((e as Error).message);
                }
              }
            })}
          >
            <div className="flex flex-col gap-4">
              {{#if hasParams}}{{#each fieldHtmls}}{{{this}}}
              {{/each}}{{else}}<p className="text-sm text-muted-foreground">This operation has no parameters.</p>
              {{/if}}<div className="flex justify-end gap-2 pt-2">
                <Button type="button" variant="outline" onClick={() => setOpen(false)}>Cancel</Button>
                <Button type="submit" disabled={mut.isPending} data-testid="{{slug}}-op-{{opName}}-submit">{{humanOp}}</Button>
              </div>
            </div>
          </form>
        </Form>
      </DialogContent>
    </Dialog>
  );
}
