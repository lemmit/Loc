}

// Active-route helper — drives sidebar NavLink active styling.
// Defaults to a prefix match so /orders/<id> + /orders/new + /orders
// keep the "Orders" link highlighted; the `exact` opt-in narrows
// to literal equality (used by /workflows + /views index links).
function useIsActive() {
  const location = useLocation();
  return (path: string, opts?: { exact?: boolean }) => {
    if (opts?.exact) return location.pathname === path;
    return (
      location.pathname === path || location.pathname.startsWith(path + "/")
    );
  };
}

interface NavLinkProps {
  to: string;
  label: string;
  active: boolean;
  testId: string;
}

function NavLink({ to, label, active, testId }: NavLinkProps) {
  return (
    <RouterLink
      to={to}
      data-testid={testId}
      className={cn(
        "rounded-md px-3 py-2 text-sm font-medium transition-colors",
        active
          ? "bg-accent text-accent-foreground"
          : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
      )}
    >
      {label}
    </RouterLink>
  );
}

