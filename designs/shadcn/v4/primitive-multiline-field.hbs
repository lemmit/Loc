{{#if hasBind}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Textarea value={{expr bind}} onChange={(e) => {{setter}}(e.currentTarget.value)}{{{testidAttr}}} /></div>{{else}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Textarea{{{testidAttr}}} /></div>{{/if}}