function {{opPascal}}Form({ mut, onClose }: { mut: ReturnType<typeof use{{opPascal}}{{aggregateName}}>; onClose: () => void }) {
{{#each idHookCalls}}{{{this}}}
{{/each}}  const form = useForm<{{opPascal}}Request>({
    resolver: zodResolver({{opPascal}}Request),
    defaultValues: {{{defaultValuesTs}}},
  });
  return (
    <Form {...form}>
      <form
        data-testid="{{slug}}-op-{{opName}}-form"
        onSubmit={form.handleSubmit(async (vals) => {
          try {
            await mut.mutateAsync(vals);
            toast.success("{{humanOp}} succeeded");
            onClose();
          } catch (e) {
            toast.error((e as Error).message);
          }
        })}
      >
        <div className="flex flex-col gap-4">
        {{#if hasParams}}{{#each fieldHtmls}}{{{this}}}
        {{/each}}{{else}}<p className="text-sm text-muted-foreground">This operation has no parameters.</p>
        {{/if}}<div className="flex justify-end gap-2 pt-2">
          <Button type="button" variant="outline" onClick={onClose}>Cancel</Button>
          <Button type="submit" disabled={mut.isPending} data-testid="{{slug}}-op-{{opName}}-submit">{{humanOp}}</Button>
        </div>
        </div>
      </form>
    </Form>
  );
}
