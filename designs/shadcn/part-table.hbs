{{#if columnHeaders.length}}<Card>
        <CardHeader>
          <div className="flex items-center justify-between">
            <CardTitle className="text-base">{{humanName}}</CardTitle>
            <span className="text-sm text-muted-foreground">{ {{{arrayExpr}}}.length === 1 ? "1 item" : {{{arrayExpr}}}.length + " items"}</span>
          </div>
        </CardHeader>
        <CardContent>
          <Table data-testid="{{testId}}">
            <TableHeader>
              <TableRow>
                {{#each columnHeaders}}<TableHead>{{this}}</TableHead>
                {{/each}}
              </TableRow>
            </TableHeader>
            <TableBody>
              { {{{arrayExpr}}}.map((row) => (
                <TableRow key={row.id} data-testid={`{{testId}}-row-${row.id}`}>
                  {{#each cells}}{{{cellHtml}}}
                  {{/each}}
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </CardContent>
      </Card>{{else}}<Card><CardHeader><CardTitle className="text-base">{{humanName}}</CardTitle></CardHeader><CardContent><p className="text-sm text-muted-foreground">{JSON.stringify({{{arrayExpr}}})}</p></CardContent></Card>{{/if}}
