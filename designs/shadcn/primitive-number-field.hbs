{{#if hasBind}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Input type="number" value={{expr bind}} onChange={(e) => {{setter}}(Number(e.currentTarget.value) || 0)}{{{testidAttr}}} /></div>{{else}}<div className="flex flex-col gap-2"><Label>{{{labelText}}}</Label><Input type="number"{{{testidAttr}}} /></div>{{/if}}