<div class="flex flex-col gap-2"><Label>{{label}}</Label><Input type="number" step="0.01" data-testid="{{testId}}" :model-value="form.values.{{path}}" @update:model-value="(v) => form.values.{{path}} = Number(v) || 0" /><p v-if='form.errors["{{path}}"]' class="text-sm text-destructive">\{{ form.errors["{{path}}"] }}</p></div>
