<div class="flex flex-col gap-2"><Label for="{{testId}}">{{label}}</Label><Input id="{{testId}}" type="number" step="1" data-testid="{{testId}}" :model-value="form.values.{{path}}" @update:model-value="(v) => form.values.{{path}} = Math.trunc(Number(v)) || 0" /><p v-if='form.errors["{{path}}"]' class="text-sm text-destructive">\{{ form.errors["{{path}}"] }}</p></div>
