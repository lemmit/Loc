<div class="flex flex-col gap-2"><Label for="{{testId}}">{{label}}</Label><input id="{{testId}}" type="file" data-testid="{{testId}}" @change="async (e: Event) => { const file = (e.target as HTMLInputElement).files?.[0]; if (!file) { form.values.{{path}} = null; return; } const fd = new FormData(); fd.append('file', file); form.values.{{path}} = (await api.upload('/files', fd)) as typeof form.values.{{path}}; }" /><p v-if='form.errors["{{path}}"]' class="text-sm text-destructive">\{{ form.errors["{{path}}"] }}</p></div>
