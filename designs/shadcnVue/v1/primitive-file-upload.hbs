{{#if hasBind}}<div class="flex flex-col gap-2"><Label>{{{labelText}}}</Label><input type="file" @change="async (e: Event) => { const file = (e.target as HTMLInputElement).files?.[0]; if (!file) { {{setter}}(null); return; } {{setter}}(await api.uploadFile(file)); }"{{{testidAttr}}} />{{#if hasError}}<p v-if='( {{{error}}} )' v-text='( {{{error}}} )' class="text-sm text-destructive"></p>{{/if}}</div>{{else}}<div class="flex flex-col gap-2"><Label>{{{labelText}}}</Label><input type="file"{{{testidAttr}}} />{{#if hasError}}<p v-if='( {{{error}}} )' v-text='( {{{error}}} )' class="text-sm text-destructive"></p>{{/if}}</div>{{/if}}
