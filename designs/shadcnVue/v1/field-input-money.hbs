<div class="flex flex-col gap-2"><Label for="{{testId}}">{{label}}</Label><Input id="{{testId}}" inputmode="decimal" data-testid="{{testId}}" :model-value="String(form.values.{{path}} ?? '0')" @update:model-value="(v) => form.values.{{path}} = String(v || '0')" /><p v-if='form.errors["{{path}}"]' class="text-sm text-destructive">\{{ form.errors["{{path}}"] }}</p></div>
