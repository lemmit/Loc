<div class="flex flex-col gap-2"><Label for="{{testId}}">{{label}}</Label><Select :model-value="form.values.{{path}}" @update:model-value="(v) => form.values.{{path}} = String(v ?? '') as typeof form.values.{{path}}"><SelectTrigger id="{{testId}}" data-testid="{{testId}}"><SelectValue placeholder="Select…" /></SelectTrigger><SelectContent><SelectItem v-for="__o in ({{{hookVar}}}.data?.items ?? [])" :key="__o.id" :value="__o.id" :data-testid="`{{testId}}-option-${__o.id}`">\{{ __o.{{displayField}} }}</SelectItem></SelectContent></Select><p v-if='form.errors["{{path}}"]' class="text-sm text-destructive">\{{ form.errors["{{path}}"] }}</p></div>
