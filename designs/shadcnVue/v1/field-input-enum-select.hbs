<div class="flex flex-col gap-2"><Label>{{label}}</Label><Select :model-value="form.values.{{path}}" @update:model-value="(v) => form.values.{{path}} = String(v ?? '') as typeof form.values.{{path}}"><SelectTrigger data-testid="{{testId}}"><SelectValue placeholder="Select…" /></SelectTrigger><SelectContent><SelectItem v-for='__v in {{{enumValuesJson}}}' :key="__v" :value="__v">\{{ __v }}</SelectItem></SelectContent></Select><p v-if='form.errors["{{path}}"]' class="text-sm text-destructive">\{{ form.errors["{{path}}"] }}</p></div>
