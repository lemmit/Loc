<mat-form-field class="loom-field">{{#if labelText}}<mat-label>{{{labelText}}}</mat-label>{{/if}}<mat-select{{{testidAttr}}}{{#if hasBind}} [value]="{{bind}}()" (selectionChange)="{{bind}}.set($event.value)"{{/if}}>@for (opt of {{{optionsExpr}}}; track opt) {<mat-option [value]="opt">\{{ opt }}</mat-option>}</mat-select></mat-form-field>{{#if hasError}}@if ( {{{error}}} ) {<span class="loom-error">\{{ {{{error}}} }}</span>}{{/if}}
