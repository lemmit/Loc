/* Auto-generated.  Do not edit by hand.
   Base resets + the design tokens projected from the system's
   `theme { … }` block.  The Material palette itself rides the prebuilt
   theme listed first in angular.json `styles`. */
html,
body {
  height: 100%;
}
body {
  margin: 0;
  font-family: {{{fontFamily}}};
}
:root {
  --loom-primary: {{brandShades.[6]}};
  --loom-accent: {{accentShades.[6]}};
}
.loom-stack {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.loom-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12px;
}
.loom-toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.loom-container {
  max-width: 960px;
  margin: 0 auto;
  width: 100%;
}
.loom-paper {
  padding: 16px;
  border: 1px solid rgba(0, 0, 0, 0.12);
  border-radius: 8px;
  background: #fff;
}
.loom-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.loom-stat-label {
  font-size: 0.8rem;
  color: rgba(0, 0, 0, 0.6);
}
.loom-stat-value {
  font-size: 1.4rem;
  font-weight: 600;
}
.loom-badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 600;
  background: var(--loom-primary);
  color: #fff;
}
.loom-alert {
  padding: 12px 16px;
  border-radius: 8px;
  border: 1px solid transparent;
}
.loom-alert-title {
  font-weight: 600;
  margin-bottom: 4px;
}
.loom-alert-red {
  background: #fdecea;
  border-color: #f5c6cb;
  color: #842029;
}
.loom-alert-green {
  background: #eafaf1;
  border-color: #c3e6cb;
  color: #0f5132;
}
.loom-alert-yellow {
  background: #fff8e1;
  border-color: #ffe8a1;
  color: #664d03;
}
.loom-alert-blue {
  background: #e7f1ff;
  border-color: #b6d4fe;
  color: #084298;
}
