{
  "name": "angularMaterial",
  "version": "v1",
  "format": "angular",
  "stack": "ng1",
  "emits": {
    "primitive-heading": "primitive-heading.hbs",
    "primitive-text": "primitive-text.hbs",
    "primitive-stack": "primitive-stack.hbs",
    "primitive-card": "primitive-card.hbs",
    "primitive-divider": "primitive-divider.hbs",
    "package-json": "package-json.hbs",
    "angular-json": "angular-json.hbs",
    "tsconfig": "tsconfig.hbs",
    "tsconfig-app": "tsconfig-app.hbs",
    "main": "main.hbs",
    "app-config": "app-config.hbs",
    "app-shell": "app-shell.hbs",
    "theme": "theme.hbs",
    "format-helpers": "format-helpers.hbs"
  },
  "imports": {
    "primitive-card": [{ "from": "@angular/material/card", "named": ["MatCardModule"] }],
    "primitive-divider": [{ "from": "@angular/material/divider", "named": ["MatDividerModule"] }]
  }
}
