// Auth + capabilities â€” the authorization and cross-aggregate-behaviour
// surface that no other playground example exercises.  Targets a single
// .NET deployable so the generated tree reads concretely as EF Core
// artifacts â€” named query filters, Auth/*.cs, the AuditableInterceptor.
// (All five backends compile the capability query filters today â€” .NET,
// Hono, Java, Phoenix, and Python; see docs/capabilities.md.  .NET is
// just the most legible to browse as static files.)  Files-only in the
// playground (.NET doesn't boot in-browser); open the generated tree to
// read Auth/*.cs, the EF query filters, and the AuditableInterceptor.
//
// Demonstrates, end to end:
//   â€˘ system `user { ... }` JWT claim shape + `currentUser` magic id.
//   â€˘ `auth: required` on the deployable â†’ JWT-decode middleware.
//   â€˘ subdomain `permissions { ... }` â†’ typed `permissions.<name>`.
//   â€˘ `requires <expr>` authorization gate (HTTP 403) vs `precondition`
//     domain gate (HTTP 400).
//   â€˘ row-level visibility: a repository find and a view filtered by
//     `currentUser`.
//   â€˘ the `audit` + `softDelete` capability macros (context) paired with
//     `auditable` + `softDeletable` (aggregate) â€” the canonical
//     audit-columns + soft-delete-filter pattern.
//   â€˘ a hand-written capability group (`filter for "tenantScoped"`) to
//     show the surface the macros desugar into.

system Helpdesk {

  // The JWT claim shape the verifier hook decodes per request.  Every
  // `currentUser.<field>` below type-checks against this block.
  user {
    id: string
    role: string
    permissions: string[]
    tenantId: string
  }

  // `tenantScoped` â€” a user-declared capability: the multi-tenant read filter,
  // applied per aggregate via `with tenantScoped` (the typed replacement for the
  // old `filter for "tenantScoped"` + `implements "tenantScoped"` string group).
  capability tenantScoped {
    filter this.tenantId == currentUser.tenantId
  }

  subdomain Support {

    // Typed permission catalogue.  `permissions.ticketsClose` lowers to
    // the stable string "support.ticketsClose" on both sides of the wire.
    permissions {
      ticketsClose,
      ticketsReassign
    }

    // Audit + soft-delete are built-in capabilities applied per aggregate
    // (below): `auditable` co-locates the audit fields + stamps, `softDeletable`
    // the isDeleted/deletedAt state + read filter; `tenantScoped` (declared
    // above) is the user-defined multi-tenant filter.
    context Support {

      enum TicketStatus { Open, Pending, Closed }

      // `auditable` (capability) adds createdAt/updatedAt/createdBy/updatedBy +
      // the create/update stamps; `softDeletable` (capability) adds
      // isDeleted/deletedAt + the read filter; `softDelete` (macro) adds the
      // softDelete()/restore() operations.
      aggregate Ticket with auditable, softDeletable, softDelete, tenantScoped {
        tenantId: string
        subject: string
        status: TicketStatus
        assignee: string

        invariant subject.length > 0

        // `requires` (403) gates the caller; `precondition` (400) gates
        // the state.  currentUser + permissions.<name> resolve here.
        operation close() {
          requires currentUser.role == "agent"
                || currentUser.permissions.contains(permissions.ticketsClose)
          precondition status != Closed
          status := Closed
        }

        operation reassign(to: string) {
          requires currentUser.role == "agent"
                || currentUser.permissions.contains(permissions.ticketsReassign)
          precondition status != Closed
          assignee := to
        }
      }

      // Row-level visibility: both the find and the view scope their
      // result to the requesting user via `currentUser` (slice 1C).
      repository Tickets for Ticket {
        find mine(): Ticket[] where assignee == currentUser.id
        find openInTenant(): Ticket[]
          where tenantId == currentUser.tenantId && status == Open
      }

      view MyOpenTickets = Ticket where assignee == currentUser.id && status == Open
    }
  }

  storage primary { type: postgres }
  resource ticketsState { for: Support, kind: state, use: primary }

  deployable api {
    platform: dotnet
    contexts: [Support]
    dataSources: [ticketsState]
    port: 8080
    auth: required
  }
}
