/** Adapt a zod schema to vee-validate's `TypedSchema` contract — the
 *  local stand-in for `@vee-validate/zod`'s `toTypedSchema` (see the
 *  header note on the zod-4 peer mismatch). */
function toTypedSchema<T>(schema: z.ZodType<T>): TypedSchema<Record<string, unknown>, T> {
  return {
    __type: "VVTypedSchema",
    async parse(values) {
      const result = await schema.safeParseAsync(values);
      if (result.success) return { value: result.data, errors: [] };
      return {
        errors: result.error.issues.map((issue) => ({
          path: issue.path.join(".") || undefined,
          errors: [issue.message],
        })),
      };
    },
  };
}

export function useLoomForm<T extends Record<string, unknown>>(
  schema: z.ZodType<T>,
  // DRAFT values, deliberately looser than T: an enum field starts
  // as "" and a user is mid-typing until submit — only the zod parse
  // produces a real T.  `values` is exposed AS T so template
  // bindings type-check against the wire shape.
  initialValues: Record<string, unknown>,
): LoomForm<T> {
  const values = reactive(initialValues) as T;
  const form = useForm({
    validationSchema: toTypedSchema(schema),
    initialValues: initialValues as Record<string, unknown>,
  });

  // `form.errors` is a ComputedRef keyed by dot-path (only errored
  // fields present).  Expose it as a plain lookup so the pack markup's
  // `form.errors["x"]` reads track the underlying ref reactively.
  const errors = new Proxy({} as Record<string, string | undefined>, {
    get: (_target, key: string | symbol): string | undefined =>
      typeof key === "string" ? form.errors.value[key] : undefined,
  });

  function clearErrors(): void {
    form.setErrors({});
  }
  function setError(path: string, message: string): void {
    form.setFieldError(path, message);
  }

  function handleSubmit(handler: (vals: T) => Promise<void> | void) {
    const run = form.handleSubmit(async (vals) => {
      try {
        await handler(vals as T);
      } catch (err) {
        applyServerError(err, setError);
      }
    });
    return async (e?: Event): Promise<void> => {
      e?.preventDefault();
      // Feed the locally-held draft into vee-validate, then validate +
      // dispatch through its submit runner (which short-circuits when
      // invalid, leaving `errors` populated).
      form.setValues(values as Record<string, unknown>, false);
      await run(e);
    };
  }

  return {
    values,
    errors,
    get submitting() {
      return form.isSubmitting.value;
    },
    handleSubmit,
    setError,
    clearErrors,
  };
}

/** Map a thrown server error onto the form: a ProblemDetails-style
 *  `errors` record (RFC 7807 validation shape) lands per-field;
 *  anything else lands on `__global`.  Mirrors the React projects'
 *  `apply-server-errors.ts` semantics at the granularity the shared
 *  fetch client surfaces. */
function applyServerError(err: unknown, setError: (p: string, m: string) => void): void {
  if (err && typeof err === "object" && "errors" in err) {
    const fieldErrors = (err as { errors: unknown }).errors;
    if (fieldErrors && typeof fieldErrors === "object") {
      let mapped = false;
      for (const [field, msgs] of Object.entries(fieldErrors as Record<string, unknown>)) {
        const msg = Array.isArray(msgs) ? String(msgs[0] ?? "") : String(msgs);
        if (msg) {
          setError(field, msg);
          mapped = true;
        }
      }
      if (mapped) return;
    }
  }
  setError("__global", err instanceof Error ? err.message : String(err));
}
