// wire schema is the SAME shared zod request schema the api module
// exports, adapted to vee-validate's `TypedSchema` contract by the
// local `toTypedSchema` below.
//
// NB: the adapter is emitted inline rather than pulled from
// `@vee-validate/zod` because that package's peer range pins zod 3
// (`zod@^3.24.0`), while the generated stack is zod 4 — so a plain
// `npm install` would ERESOLVE.  vee-validate core carries no zod peer,
// and the `TypedSchema` contract is tiny + stable, so wrapping the zod
// schema here keeps the dependency graph clean.
import { reactive } from "vue";
import { type TypedSchema, useForm } from "vee-validate";
import type { z } from "zod";

export interface LoomForm<T extends Record<string, unknown>> {
  /** Reactive form values — field inputs bind `v-model="form.values.x"`.
   *  Held locally (not vee-validate's internal `values`, which is not
   *  meant to be mutated directly) so array push/splice + nested
   *  `v-model` writes the pack templates emit keep working; the current
   *  snapshot is pushed into vee-validate on each submit. */
  values: T;
  /** Per-field error messages keyed by dot-path; `__global` carries
   *  whole-form failures (server rejections that don't map to a
   *  field).  Inputs bind `:error-messages='form.errors["x"]'`. */
  errors: Record<string, string | undefined>;
  /** True while an async submit handler is in flight. */
  submitting: boolean;
  /** Build a form `@submit.prevent` handler: pushes the current values
   *  into vee-validate, validates against the typed schema (populating
   *  `errors`), and only then runs the supplied handler with the PARSED
   *  data.  A handler throw is captured as a server error (field map
   *  when the error carries a ProblemDetails-style `errors` record,
   *  `__global` otherwise). */
  handleSubmit(handler: (vals: T) => Promise<void> | void): (e?: Event) => Promise<void>;
  setError(path: string, message: string): void;
