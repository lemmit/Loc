{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "test/**/*.ts",
      "scripts/**/*.mjs",
      "!src/language/generated",
      "!test/fixtures",
      "!**/__snapshots__",
      "!**/*.d.ts",
      "!out",
      "!coverage",
      "!node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off"
      },
      "suspicious": {
        "noFallthroughSwitchClause": "error",
        "noAssignInExpressions": "error",
        "useIterableCallbackReturn": "error",
        "noThenProperty": "error",
        "noSelfCompare": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["test/macro/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
