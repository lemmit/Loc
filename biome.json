{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "test/**/*.ts",
      "scripts/**/*.mjs",
      "!src/language/generated",
      "!test/fixtures",
      "!test/__snapshots__",
      "!**/*.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off"
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "warn"
      },
      "suspicious": {
        "noFallthroughSwitchClause": "warn",
        "noAssignInExpressions": "warn",
        "useIterableCallbackReturn": "warn",
        "noThenProperty": "warn",
        "noSelfCompare": "warn",
        "noConfusingVoidType": "warn"
      },
      "complexity": {
        "useLiteralKeys": "warn",
        "noUselessConstructor": "warn",
        "useOptionalChain": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "warn"
      }
    }
  }
}
