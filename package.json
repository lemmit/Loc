{
  "name": "loc-ddd-dsl",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "description": "Langium-based DDD DSL with TypeScript (Hono + Drizzle) and .NET (ASP.NET Core + EF Core) code generators",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ddd": "./bin/cli.js"
  },
  "main": "./out/language/main.js",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "build:web": "test -d web/node_modules && tsc -p web/tsconfig.json --noEmit || echo 'web/node_modules not present \u2014 run (cd web && npm install) once to enable the web tsc gate'",
    "watch": "tsc -b tsconfig.json --watch",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch",
    "test": "vitest run --exclude '**/e2e.test.ts' --exclude '**/generated-build.test.ts' --exclude '**/generated-react-build.test.ts' --exclude '**/generated-svelte-build.test.ts' --exclude '**/generated-dotnet-build.test.ts' --exclude '**/generated-dotnet-format.test.ts' --exclude '**/generated-elixir-ash-build.test.ts' --exclude '**/generated-elixir-ash-format.test.ts' --exclude '**/generated-elixir-ash-dialyzer.test.ts' --exclude '**/generated-biome.test.ts' --exclude '**/observability-events.test.ts' --exclude '**/observability-events-dotnet.test.ts' --exclude '**/observability-events-elixir-ash.test.ts' --exclude '**/auth-oidc-e2e.test.ts' --exclude '**/auth-oidc-dotnet-e2e.test.ts' --exclude '**/auth-oidc-java-e2e.test.ts' --exclude '**/auth-oidc-python-e2e.test.ts' --exclude '**/auth-oidc-compose-e2e.test.ts' --exclude '**/auth-oidc-elixir-compose-e2e.test.ts'",
    "test:watch": "vitest --exclude '**/e2e.test.ts' --exclude '**/generated-build.test.ts' --exclude '**/generated-react-build.test.ts' --exclude '**/generated-svelte-build.test.ts' --exclude '**/generated-dotnet-build.test.ts' --exclude '**/generated-dotnet-format.test.ts' --exclude '**/generated-elixir-ash-build.test.ts' --exclude '**/generated-elixir-ash-format.test.ts' --exclude '**/generated-elixir-ash-dialyzer.test.ts' --exclude '**/generated-biome.test.ts' --exclude '**/observability-events.test.ts' --exclude '**/observability-events-dotnet.test.ts' --exclude '**/observability-events-elixir-ash.test.ts' --exclude '**/auth-oidc-e2e.test.ts' --exclude '**/auth-oidc-dotnet-e2e.test.ts' --exclude '**/auth-oidc-java-e2e.test.ts' --exclude '**/auth-oidc-python-e2e.test.ts' --exclude '**/auth-oidc-compose-e2e.test.ts' --exclude '**/auth-oidc-elixir-compose-e2e.test.ts'",
    "test:coverage": "vitest run --coverage --exclude '**/e2e.test.ts' --exclude '**/generated-build.test.ts' --exclude '**/generated-react-build.test.ts' --exclude '**/generated-svelte-build.test.ts' --exclude '**/generated-dotnet-build.test.ts' --exclude '**/generated-dotnet-format.test.ts' --exclude '**/generated-elixir-ash-build.test.ts' --exclude '**/generated-elixir-ash-format.test.ts' --exclude '**/generated-elixir-ash-dialyzer.test.ts' --exclude '**/generated-biome.test.ts' --exclude '**/observability-events.test.ts' --exclude '**/observability-events-dotnet.test.ts' --exclude '**/observability-events-elixir-ash.test.ts' --exclude '**/auth-oidc-e2e.test.ts' --exclude '**/auth-oidc-dotnet-e2e.test.ts' --exclude '**/auth-oidc-java-e2e.test.ts' --exclude '**/auth-oidc-python-e2e.test.ts' --exclude '**/auth-oidc-compose-e2e.test.ts' --exclude '**/auth-oidc-elixir-compose-e2e.test.ts'",
    "test:e2e": "LOOM_E2E=1 vitest run test/e2e/e2e.test.ts",
    "test:tsc": "LOOM_TS_BUILD=1 vitest run test/e2e/generated-build.test.ts",
    "test:tsc-react": "LOOM_REACT_BUILD=1 vitest run test/e2e/generated-react-build.test.ts",
    "test:tsc-react-extern": "LOOM_REACT_BUILD=1 vitest run test/e2e/extern-component-build.test.ts",
    "test:vue-build": "LOOM_VUE_BUILD=1 vitest run test/e2e/generated-vue-build.test.ts",
    "test:vue-e2e": "LOOM_VUE_E2E=1 vitest run test/e2e/generated-vue-e2e.test.ts",
    "test:angular-build": "LOOM_ANGULAR_BUILD=1 vitest run test/e2e/generated-angular-build.test.ts",
    "test:dotnet": "LOOM_DOTNET_BUILD=1 vitest run test/e2e/generated-dotnet-build.test.ts",
    "test:python": "LOOM_PYTHON_BUILD=1 vitest run test/e2e/generated-python-build.test.ts",
    "test:java": "LOOM_JAVA_BUILD=1 vitest run test/e2e/generated-java-build.test.ts",
    "test:k8s": "LOOM_K8S=1 vitest run test/e2e/k8s-validate.test.ts",
    "test:k8s-e2e": "bash scripts/k8s-e2e-smoke.sh",
    "test:format-dotnet": "LOOM_DOTNET_FORMAT=1 vitest run test/e2e/generated-dotnet-format.test.ts",
    "test:phoenix": "LOOM_PHOENIX_BUILD=1 vitest run test/e2e/generated-elixir-ash-build.test.ts",
    "test:phoenix-vanilla": "LOOM_PHOENIX_VANILLA_BUILD=1 vitest run test/e2e/generated-elixir-vanilla-build.test.ts",
    "test:format-phoenix": "LOOM_PHOENIX_FORMAT=1 vitest run test/e2e/generated-elixir-ash-format.test.ts",
    "test:dialyzer-phoenix": "LOOM_PHOENIX_DIALYZER=1 vitest run test/e2e/generated-elixir-ash-dialyzer.test.ts",
    "test:obs": "LOOM_OBS_E2E=1 vitest run test/e2e/observability-events.test.ts",
    "test:obs-dotnet": "LOOM_OBS_E2E_DOTNET=1 vitest run test/e2e/observability-events-dotnet.test.ts",
    "test:obs-java": "LOOM_OBS_E2E_JAVA=1 vitest run test/e2e/observability-events-java.test.ts",
    "test:obs-python": "LOOM_OBS_E2E_PYTHON=1 vitest run test/e2e/observability-events-python.test.ts",
    "test:obs-phoenix": "LOOM_OBS_E2E_PHOENIX=1 vitest run test/e2e/observability-events-elixir-ash.test.ts",
    "test:obs-phoenix-vanilla": "LOOM_OBS_E2E_PHOENIX_VANILLA=1 vitest run test/e2e/observability-events-elixir-vanilla.test.ts",
    "test:auth-e2e": "LOOM_AUTH_E2E=1 vitest run test/e2e/auth-oidc-e2e.test.ts",
    "test:auth-e2e-dotnet": "LOOM_AUTH_E2E_DOTNET=1 vitest run test/e2e/auth-oidc-dotnet-e2e.test.ts",
    "test:auth-e2e-java": "LOOM_AUTH_E2E_JAVA=1 vitest run test/e2e/auth-oidc-java-e2e.test.ts",
    "test:auth-e2e-python": "LOOM_AUTH_E2E_PYTHON=1 vitest run test/e2e/auth-oidc-python-e2e.test.ts",
    "test:auth-e2e-compose": "LOOM_AUTH_E2E_COMPOSE=1 vitest run test/e2e/auth-oidc-compose-e2e.test.ts",
    "test:auth-e2e-phoenix": "LOOM_AUTH_E2E_PHOENIX=1 vitest run test/e2e/auth-oidc-elixir-compose-e2e.test.ts",
    "test:biome-gen": "LOOM_BIOME=1 vitest run test/e2e/generated-biome.test.ts",
    "prepare": "npm run langium:generate && npm run build && npm run build:web",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "cli": "node bin/cli.js",
    "test:svelte-build": "LOOM_SVELTE_BUILD=1 vitest run test/e2e/generated-svelte-build.test.ts",
    "test:svelte-e2e": "LOOM_SVELTE_E2E=1 vitest run test/e2e/generated-svelte-e2e.test.ts"
  },
  "dependencies": {
    "chalk": "~5.3.0",
    "chevrotain": "~12.0.0",
    "commander": "~12.1.0",
    "handlebars": "^4.7.9",
    "ignore": "^7.0.5",
    "langium": "~4.3.0",
    "vscode-languageserver": "~10.0.0",
    "vscode-languageserver-textdocument": "~1.0.13",
    "vscode-uri": "~3.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@types/node": "~22.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "isomorphic-git": "^1.38.3",
    "langium-cli": "~4.3.0",
    "marked": "^14.1.4",
    "typescript": "~5.9.0",
    "vitest": "^4.1.8"
  }
}
