{
  "name": "loc-ddd-dsl",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "description": "Langium-based DDD DSL with TypeScript (Hono + Drizzle) and .NET (ASP.NET Core + EF Core) code generators",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ddd": "./bin/cli.js"
  },
  "main": "./out/language/main.js",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "watch": "tsc -b tsconfig.json --watch",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch",
    "test": "vitest run --exclude '**/e2e.test.ts' --exclude '**/generated-build.test.ts' --exclude '**/generated-react-build.test.ts' --exclude '**/observability-events.test.ts'",
    "test:watch": "vitest --exclude '**/e2e.test.ts' --exclude '**/generated-build.test.ts' --exclude '**/generated-react-build.test.ts' --exclude '**/observability-events.test.ts'",
    "test:coverage": "vitest run --coverage --exclude '**/e2e.test.ts' --exclude '**/generated-build.test.ts' --exclude '**/generated-react-build.test.ts' --exclude '**/observability-events.test.ts'",
    "test:e2e": "LOOM_E2E=1 vitest run test/e2e/e2e.test.ts",
    "test:tsc": "LOOM_TS_BUILD=1 vitest run test/e2e/generated-build.test.ts",
    "test:tsc-react": "LOOM_REACT_BUILD=1 vitest run test/e2e/generated-react-build.test.ts",
    "test:obs": "LOOM_OBS_E2E=1 vitest run test/e2e/observability-events.test.ts",
    "test:biome-gen": "LOOM_BIOME=1 vitest run test/e2e/generated-biome.test.ts",
    "prepare": "npm run langium:generate && npm run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "cli": "node bin/cli.js"
  },
  "dependencies": {
    "chalk": "~5.3.0",
    "chevrotain": "~11.0.3",
    "commander": "~12.1.0",
    "handlebars": "^4.7.9",
    "ignore": "^7.0.5",
    "langium": "~3.3.0",
    "vscode-languageserver": "~9.0.1",
    "vscode-languageserver-textdocument": "~1.0.12",
    "vscode-uri": "~3.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "~22.10.0",
    "@vitest/coverage-v8": "~2.1.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "langium-cli": "~3.3.0",
    "typescript": "~5.7.0",
    "vitest": "~2.1.0"
  }
}
