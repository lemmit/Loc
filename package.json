{
  "name": "loc-ddd-dsl",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "description": "Langium-based DDD DSL with TypeScript (Hono + Drizzle) and .NET (ASP.NET Core + EF Core) code generators",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ddd": "./bin/cli.js"
  },
  "main": "./out/language/main.js",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "build:web": "test -d web/node_modules && tsc -p web/tsconfig.json --noEmit || echo 'web/node_modules not present — run (cd web && npm install) once to enable the web tsc gate'",
    "watch": "tsc -b tsconfig.json --watch",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch",
    "docs:stdlib": "npm run build && node scripts/gen-stdlib-docs.mjs",
    "test": "vitest run",
    "test:gen": "vitest run test/generator",
    "test:lang": "vitest run test/language",
    "test:ir": "vitest run test/ir test/system test/macro test/platform test/adapters",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "LOOM_E2E=1 vitest run test/e2e/e2e.test.ts",
    "test:tsc": "LOOM_TS_BUILD=1 vitest run test/e2e/generated-build.test.ts",
    "test:tsc-corpus": "LOOM_TS_BUILD=1 vitest run test/e2e/corpus-tsc-build.test.ts",
    "test:java-corpus": "LOOM_JAVA_BUILD=1 vitest run test/e2e/corpus-java-build.test.ts",
    "test:python-corpus": "LOOM_PYTHON_BUILD=1 vitest run test/e2e/corpus-python-build.test.ts",
    "test:dotnet-corpus": "LOOM_DOTNET_BUILD=1 vitest run test/e2e/corpus-dotnet-build.test.ts",
    "test:tsc-react": "LOOM_REACT_BUILD=1 vitest run test/e2e/generated-react-build.test.ts",
    "test:react-e2e": "LOOM_REACT_E2E=1 vitest run test/e2e/generated-react-e2e.test.ts",
    "test:tsc-react-extern": "LOOM_REACT_BUILD=1 vitest run test/e2e/extern-component-build.test.ts",
    "test:vue-build": "LOOM_VUE_BUILD=1 vitest run test/e2e/generated-vue-build.test.ts",
    "test:vue-e2e": "LOOM_VUE_E2E=1 vitest run test/e2e/generated-vue-e2e.test.ts",
    "test:angular-build": "LOOM_ANGULAR_BUILD=1 vitest run test/e2e/generated-angular-build.test.ts",
    "test:angular-e2e": "LOOM_ANGULAR_E2E=1 vitest run test/e2e/generated-angular-e2e.test.ts",
    "test:dotnet": "LOOM_DOTNET_BUILD=1 vitest run test/e2e/generated-dotnet-build.test.ts",
    "test:python": "LOOM_PYTHON_BUILD=1 vitest run test/e2e/generated-python-build.test.ts",
    "test:java": "LOOM_JAVA_BUILD=1 vitest run test/e2e/generated-java-build.test.ts",
    "test:k8s": "LOOM_K8S=1 vitest run test/e2e/k8s-validate.test.ts",
    "test:k8s-e2e": "bash scripts/k8s-e2e-smoke.sh",
    "test:format-dotnet": "LOOM_DOTNET_FORMAT=1 vitest run test/e2e/generated-dotnet-format.test.ts",
    "test:phoenix": "LOOM_PHOENIX_VANILLA_BUILD=1 vitest run test/e2e/generated-elixir-vanilla-build.test.ts",
    "test:tenancy": "LOOM_TENANCY_E2E=1 vitest run test/e2e/tenancy-isolation.test.ts",
    "test:channels": "LOOM_CHANNELS_E2E=1 vitest run test/e2e/channels-e2e.test.ts",
    "test:tenancy-python": "LOOM_TENANCY_E2E_PYTHON=1 vitest run test/e2e/tenancy-isolation-python.test.ts",
    "test:tenancy-java": "LOOM_TENANCY_E2E_JAVA=1 vitest run test/e2e/tenancy-isolation-java.test.ts",
    "test:tenancy-dotnet": "LOOM_TENANCY_E2E_DOTNET=1 vitest run test/e2e/tenancy-isolation-dotnet.test.ts",
    "test:tenancy-elixir": "LOOM_TENANCY_E2E_ELIXIR=1 vitest run test/e2e/tenancy-isolation-elixir.test.ts",
    "test:tenancy-hierarchy": "LOOM_TENANCY_E2E=1 vitest run test/e2e/tenancy-hierarchy.test.ts",
    "test:tenancy-hierarchy-python": "LOOM_TENANCY_E2E_PYTHON=1 vitest run test/e2e/tenancy-hierarchy-python.test.ts",
    "test:tenancy-hierarchy-java": "LOOM_TENANCY_E2E_JAVA=1 vitest run test/e2e/tenancy-hierarchy-java.test.ts",
    "test:tenancy-hierarchy-dotnet": "LOOM_TENANCY_E2E_DOTNET=1 vitest run test/e2e/tenancy-hierarchy-dotnet.test.ts",
    "test:tenancy-hierarchy-elixir": "LOOM_TENANCY_E2E_ELIXIR=1 vitest run test/e2e/tenancy-hierarchy-elixir.test.ts",
    "test:obs": "LOOM_OBS_E2E=1 vitest run test/e2e/observability-events.test.ts",
    "test:obs-dotnet": "LOOM_OBS_E2E_DOTNET=1 vitest run test/e2e/observability-events-dotnet.test.ts",
    "test:obs-java": "LOOM_OBS_E2E_JAVA=1 vitest run test/e2e/observability-events-java.test.ts",
    "test:obs-python": "LOOM_OBS_E2E_PYTHON=1 vitest run test/e2e/observability-events-python.test.ts",
    "test:obs-phoenix": "LOOM_OBS_E2E_PHOENIX_VANILLA=1 vitest run test/e2e/observability-events-elixir-vanilla.test.ts",
    "test:email": "LOOM_EMAIL_E2E=1 vitest run test/e2e/mailer-smtp-e2e.test.ts",
    "test:email-python": "LOOM_EMAIL_E2E_PYTHON=1 vitest run test/e2e/mailer-smtp-python-e2e.test.ts",
    "test:email-dotnet": "LOOM_EMAIL_E2E_DOTNET=1 vitest run test/e2e/mailer-smtp-dotnet-e2e.test.ts",
    "test:email-java": "LOOM_EMAIL_E2E_JAVA=1 vitest run test/e2e/mailer-smtp-java-e2e.test.ts",
    "test:email-elixir": "LOOM_EMAIL_E2E_ELIXIR=1 vitest run test/e2e/mailer-smtp-elixir-e2e.test.ts",
    "test:phoenix-ui-e2e": "LOOM_PHOENIX_UI_E2E=1 vitest run test/e2e/phoenix-ui-smoke-e2e.test.ts",
    "test:auth-e2e": "LOOM_AUTH_E2E=1 vitest run test/e2e/auth-oidc-e2e.test.ts",
    "test:auth-e2e-dotnet": "LOOM_AUTH_E2E_DOTNET=1 vitest run test/e2e/auth-oidc-dotnet-e2e.test.ts",
    "test:auth-e2e-java": "LOOM_AUTH_E2E_JAVA=1 vitest run test/e2e/auth-oidc-java-e2e.test.ts",
    "test:auth-e2e-python": "LOOM_AUTH_E2E_PYTHON=1 vitest run test/e2e/auth-oidc-python-e2e.test.ts",
    "test:auth-e2e-compose": "LOOM_AUTH_E2E_COMPOSE=1 vitest run test/e2e/auth-oidc-compose-e2e.test.ts",
    "test:auth-e2e-phoenix": "LOOM_AUTH_E2E_PHOENIX=1 vitest run test/e2e/auth-oidc-elixir-compose-e2e.test.ts",
    "test:biome-gen": "LOOM_BIOME=1 vitest run test/e2e/generated-biome.test.ts",
    "test:contrast": "vitest run test/generator/frontend/theme-contrast.test.ts",
    "prepare": "npm run langium:generate && npm run build && npm run build:web",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "cli": "node bin/cli.js",
    "test:svelte-build": "LOOM_SVELTE_BUILD=1 vitest run test/e2e/generated-svelte-build.test.ts",
    "test:svelte-e2e": "LOOM_SVELTE_E2E=1 vitest run test/e2e/generated-svelte-e2e.test.ts"
  },
  "overrides": {
    "hono": ">=4.12.26"
  },
  "dependencies": {
    "chalk": "~5.6.0",
    "commander": "~15.0.0",
    "handlebars": "^4.7.9",
    "ignore": "^7.0.5",
    "langium": "~4.3.0",
    "vscode-languageserver": "~10.0.0",
    "vscode-languageserver-textdocument": "~1.0.13",
    "vscode-uri": "~3.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.0",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@types/node": "~24.13.0",
    "@vitest/coverage-v8": "^4.1.9",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "isomorphic-git": "^1.38.5",
    "langium-cli": "~4.3.0",
    "marked": "^18.0.5",
    "playwright": "^1.61.1",
    "typescript": "~6.0.0",
    "vitest": "^4.1.9"
  }
}
