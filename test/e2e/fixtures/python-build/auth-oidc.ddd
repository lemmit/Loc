// OIDC turnkey auth on Python/FastAPI (D-AUTH-OIDC) — an `auth { oidc }` block
// makes the generated app a real OIDC verifier (PyJWT + the issuer's JWKS) and
// adds the /auth/login|callback|logout redirect handshake + /auth/me probe.
// This fixture compiles all of it under uv sync + ruff + mypy --strict (the
// LOOM_PYTHON_BUILD gate), against the real fastapi / pyjwt types.
system Helpdesk {
  user {
    id: string
    roles: string[]
    email: string
  }

  auth {
    provider: keycloak
    oidc {
      issuer: env("OIDC_ISSUER")
      clientId: env("OIDC_CLIENT_ID")
    }
    claims: { roles: "realm_access.roles", email: "email" }
  }

  subdomain Support {
    context Tickets {
      aggregate Ticket with crudish {
        subject: string
        open: bool
      }
      repository Tickets for Ticket { }
    }
  }

  storage primary { type: postgres }
  resource ticketState { for: Tickets, kind: state, use: primary }

  api SupportApi from Support
  deployable api {
    platform: python
    contexts: [Tickets]
    serves: SupportApi
    dataSources: [ticketState]
    port: 8000
    auth: required
  }
}
