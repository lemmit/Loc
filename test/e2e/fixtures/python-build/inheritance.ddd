// Aggregate inheritance on the python backend (aggregate-inheritance.md):
// a TPH (sharedTable) hierarchy in one kind-discriminated table, and a
// TPC (ownTable) hierarchy as standalone per-concrete tables — both with
// the polymorphic base union + read-only base reader.
system PyParties {
  subdomain Registry {
    context Parties {
      // TPH — the whole hierarchy in the shared `parties` table.
      abstract aggregate Party inheritanceUsing: sharedTable {
        name: string
        email: string
      }

      aggregate Customer extends Party {
        creditLimit: int
        operation raiseLimit(by: int) {
          creditLimit := creditLimit + by
        }
      }

      aggregate Vendor extends Party {
        rating: int
      }

      // TPC — each concrete is its own table.
      abstract aggregate Asset inheritanceUsing: ownTable {
        label: string
      }

      aggregate Machine extends Asset {
        serial: string
      }

      aggregate Vehicle extends Asset {
        plate: string
      }

      repository Customers for Customer {
        find byEmail(email: string): Customer? where this.email == email
      }
      repository Vendors for Vendor { }
      repository Machines for Machine { }
      repository Vehicles for Vehicle { }
    }
  }

  api PartiesApi from Registry

  storage pg { type: postgres }
  resource partiesState { for: Parties, kind: state, use: pg }

  deployable api {
    platform: python
    contexts: [Parties]
    dataSources: [partiesState]
    serves: PartiesApi
    port: 8000
  }
}
