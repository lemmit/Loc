// shape: embedded for the Python backend: the root stays a normal
// queryable row — `id` plus its flattened scalar / `X id` columns,
// exactly like the relational root — but each containment folds into one
// jsonb column and reference collections (`X id[]`) fold into a jsonb
// id-array column.  No part tables, no join tables.  Finds run as real
// SQL over the root columns; containments (de)serialise through the same
// to_doc / from_doc helpers the document repository uses.
system EmbSys {
  subdomain Shop {
    context Shop {
      aggregate Tag { label: string }
      repository Tags for Tag {}

      aggregate Order shape: embedded {
        customer: string
        total: money
        tags: Tag id[]
        contains lines: LineItem[]
        contains note: Memo
        entity LineItem { sku: string  qty: int }
        entity Memo { text: string }
        operation addLine(sku: string, qty: int) {
          lines += LineItem { sku: sku, qty: qty }
        }
        operation retotal(amount: money) { total := amount }
      }
      repository Orders for Order {
        find byCustomer(name: string): Order[] where this.customer == name
      }
    }
  }
  api ShopApi from Shop
  storage primary { type: postgres }
  resource shopState { for: Shop, kind: state, use: primary }
  deployable api {
    platform: python
    contexts: [Shop]
    dataSources: [shopState]
    serves: ShopApi
    port: 8000
  }
}
