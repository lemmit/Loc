// Resource verb clients (resources.md) for the Python backend: a
// workflow consuming all three non-persistence infrastructure kinds —
// objectStore (s3 → boto3), queue (rabbitmq → aio-pika), api (restApi →
// httpx).  The generator emits `app/resources/<sourceType>.py` async
// verb helpers and the workflow imports + awaits them.  Bare calls
// (no let-binding) keep the emitted body lint-clean.
system ResourcesSys {
  subdomain Sales {
    context Sales {
      aggregate Order {
        ref: string
        status: string
      }
      repository Orders for Order { }

      workflow Archive {
        create(name: string) {
          salesFiles.put("orders/" + name, name)
          salesFiles.get("orders/" + name)
          salesJobs.enqueue(name)
          salesApi.get("/rate")
          salesApi.post("/log", name)
        }
      }
    }
  }

  api SalesApi from Sales

  storage pg    { type: postgres }
  storage files { type: s3, config: { bucket: "app-files" } }
  storage bus   { type: rabbitmq }
  storage pay   { type: restApi, config: { baseUrl: "https://pay.example.com" } }

  resource salesState { for: Sales, kind: state,       use: pg }
  resource salesFiles { for: Sales, kind: objectStore, use: files }
  resource salesJobs  { for: Sales, kind: queue,       use: bus }
  resource salesApi   { for: Sales, kind: api,         use: pay }

  deployable api {
    platform: python
    contexts: [Sales]
    dataSources: [salesState, salesFiles, salesJobs, salesApi]
    serves: SalesApi
    port: 8000
  }
}
