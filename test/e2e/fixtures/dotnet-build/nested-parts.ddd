system DotnetNest {
  subdomain Logistics {
    context Logistics {
      aggregate Order {
        code: string
        contains shipments: Shipment[]
        operation addShipment(carrier: string) {
          shipments += Shipment { carrier: carrier }
        }

        // Inline nested construction: build a shipment WITH a label in one call.
        // The nested Label omits parentId (stamped from tree position on save).
        operation addFull(carrier: string, zpl: string) {
          shipments += Shipment { carrier: carrier, labels: [Label { zpl: zpl }] }
        }
        entity Shipment {
          carrier: string
          contains labels: Label[]
        }
        entity Label { zpl: string }
      }
      repository Orders for Order {
        find byCode(code: string): Order[] where this.code == code
      }
    }
  }
  api LogisticsApi from Logistics
  storage pg { type: postgres }
  resource logisticsState { for: Logistics, kind: state, use: pg }
  deployable api {
    platform: dotnet
    contexts: [Logistics]
    dataSources: [logisticsState]
    serves: LogisticsApi
    port: 8080
  }
}
