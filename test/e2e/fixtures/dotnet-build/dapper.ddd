// Compile-gate fixture for the .NET `persistence: dapper` adapter
// (D-REALIZATION-AXES Phase 5c).  `persistence:` is a SYSTEM-MODE selection
// (on a deployable), so this is generated via `ddd generate system` and the
// dapper deployable's project is built under `dotnet build /warnaserror` —
// proving the generated Dapper repositories / DbSchema / Npgsql wiring compile.
//
// Exercises the supported v1 surface: scalar (string/int/bool/datetime), enum,
// value-object, single id-ref, optional fields, plus scalar / enum / id-ref
// find predicates.

system DapperNet {
  api OrdersApi from Sales

  subdomain Sales {
    context Orders {
      enum Status { Draft, Confirmed, Shipped }

      valueobject Money {
        amount:   int
        currency: string
      }

      aggregate Customer with crudish {
        name:   string
        active: bool
      }

      aggregate Tag with crudish {
        label: string
      }

      aggregate Order with crudish {
        customerId: Customer id
        status:     Status
        total:      Money
        placedAt:   datetime
        quantity:   int
        note:       string?
        // Reference collection (`X id[]`) → one join table; a
        // `this.tags.contains(x)` find lowers to an EXISTS join subquery.
        tags:       Tag id[]
      }

      repository Customers for Customer {
        find byName(name: string): Customer[] where this.name == name
      }

      repository Tags for Tag { }

      repository Orders for Order {
        find byCustomer(customerId: Customer id): Order[] where this.customerId == customerId
        find byQuantity(quantity: int): Order[] where this.quantity >= quantity
        // Reference-collection membership → EXISTS subquery over order_tags.
        find withTag(tag: Tag id): Order[] where this.tags.contains(tag)
      }

      // Retrieval bundle on Dapper — Run<Name>Async as parameterised SQL
      // (where + sort + paging), exercising the criterion `this-prop` → column
      // rendering under the dapper-build `/warnaserror` gate.
      criterion NameIs(n: string) of Customer = name == n
      retrieval ByNameSorted(n: string) of Customer { where: NameIs(n) sort: [name asc] }

      // First-boot seed data on Dapper (database-seeding.md) — the Dapper
      // seeder frames the marker table + idempotency on Npgsql+Dapper and
      // reuses the domain-`Create` path (I<Agg>Repository.SaveAsync).
      seed default {
        Customer { name: "Acme", active: true }
      }
      seed demo {
        Customer { name: "Globex", active: false }
      }
    }
  }

  storage pg { type: postgres }

  resource ordersState { for: Orders, kind: state, use: pg }

  deployable api {
    platform: dotnet { persistence: dapper }
    contexts: [Orders]
    dataSources: [ordersState]
    serves: OrdersApi
    port: 8080
  }
}
