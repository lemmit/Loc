// `ignoring` filter-bypass on the Java/Spring Boot backend (capability-emission-
// dedup.md §11.6 — the "pay for what you use" hybrid).  Hibernate's
// @SQLRestriction is ALWAYS-ON and unbypassable by design, so a capability some
// read `ignoring`s is PROMOTED: removed from @SQLRestriction and emitted as a
// bypassable Hibernate named filter (@FilterDef(autoEnabled, applyToLoadByKey) +
// @Filter), which a bypassing read disables via the Session
// (disableFilter/enableFilter, re-armed in finally).  This fixture is the
// decisive check that the resulting entity + repository impl compiles under
// `gradle testClasses bootJar` against Spring Boot 4.1 / Hibernate 7.x.
//
// Triage shapes exercised on `Product`:
//   * softDeletable — a capability filter (`is_deleted = false`) BYPASSED by
//     `recent`/`allRows`, so it is PROMOTED to a bypassable @Filter and disabled
//     per-read; `normal` + the default reads keep it (always-on autoEnabled).
//   * a bare `filter this.price > 0` — NOT bypassable (no capability origin),
//     so it STAYS in @SQLRestriction (always-on) even though softDeletable left.
//   * `allRows` uses `ignoring *` (bypass every promoted capability).
system BypassShop {
  capability softDeletable {
    isDeleted: bool
    filter this.isDeleted == false
  }
  subdomain Sales {
    context Catalog {
      aggregate Product with softDeletable {
        name: string
        price: int
        // bare capability-less filter — never bypassable, stays in @SQLRestriction.
        filter this.price > 0
      }
      repository Products for Product {
        find recent(): Product[] where this.name != "" ignoring softDeletable
        find allRows(): Product[] ignoring *
        find normal(): Product[] where this.name != ""
      }
    }
  }
  api CatalogApi from Sales
  storage primary { type: postgres }
  resource catState { for: Catalog, kind: state, use: primary }
  deployable api {
    platform: java
    contexts: [Catalog]
    dataSources: [catState]
    serves: CatalogApi
    port: 8080
  }
}
