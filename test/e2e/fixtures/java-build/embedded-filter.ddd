// DEBT-02 — a capability `filter` on a `shape: embedded` aggregate (java).
// An embedded aggregate's root entity is a real JPA table: its root scalars
// (`code`, `isDeleted`) are columns, only the `contains` parts ride a jsonb
// column.  So a non-principal capability `filter` is a static SQL predicate —
// it rides Hibernate's `@SQLRestriction` on the root entity, exactly like the
// relational path (no in-app filtering needed, unlike the document store).
// Compiles the @SQLRestriction'd entity under `gradle testClasses bootJar`
// (the java-build gate).
system EmbFilter {
  subdomain D {
    context Shop {
      aggregate Order shape: embedded {
        code: string
        isDeleted: bool
        // soft-delete capability — every read hides a deleted order.
        filter !this.isDeleted
        contains items: Item[]
        entity Item { sku: string  qty: int }
        operation addItem(sku: string, qty: int) {
          items += Item { sku: sku, qty: qty }
        }
        operation softDelete() { isDeleted := true }
      }
      repository Orders for Order {
        find byCode(code: string): Order[] where this.code == code
      }
    }
  }
  api A from D
  storage primary { type: postgres }
  resource st { for: Shop, kind: state, use: primary }
  deployable embApi {
    platform: java
    contexts: [Shop]
    dataSources: [st]
    serves: A
    port: 8081
  }
}
