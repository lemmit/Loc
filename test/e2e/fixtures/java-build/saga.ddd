// Saga-state persistence on Java (workflow-debt-backend-parity.md, Java saga
// slice 1): a correlation-bearing workflow gets a JPA `@Entity` bound to the
// Flyway-owned saga table + a Spring Data repository.  The workflow is
// event-triggered (started by OrderPlaced, continued by ShipmentRequested), so
// it emits no command route (workflowEmitsCommandRoute) — only the saga-state
// persistence.  Exercises the @EmbeddedId correlation key + enum/scalar columns
// on the `gradle testClasses bootJar` gate.
system FulfillmentSys {
  subdomain Fulfillment {
    context Fulfillment {
      aggregate Order {
        customerId: string
        status: string
        operation place() {
          precondition status == "Draft"
          status := "Placed"
          emit OrderPlaced { order: id, at: now() }
        }
      }
      repository Orders for Order { }

      aggregate Shipment {
        orderRef: Order id
        status: string
        operation markTracked() { status := "Tracked" }
      }
      repository Shipments for Shipment { }

      enum FulfillmentStatus { AwaitingShipment, Tracked }

      event OrderPlaced { order: Order id, at: datetime }
      event ShipmentRequested { shipment: Shipment id, order: Order id, at: datetime }

      channel Lifecycle {
        carries: OrderPlaced, ShipmentRequested
        delivery: broadcast
        retention: ephemeral
      }

      workflow OrderFulfillment {
        orderId: Order id           // correlation field → @EmbeddedId
        attempts: int               // scalar saga state column
        status: FulfillmentStatus   // enum saga state column

        create(p: OrderPlaced) by p.order {
          let ship = Shipment.create({ orderRef: p.order, status: "Pending" })
          emit ShipmentRequested { shipment: ship.id, order: p.order, at: now() }
        }

        on(s: ShipmentRequested) by s.order {
          let ship = Shipments.getById(s.shipment)
          ship.markTracked()
        }
      }
    }
  }

  api FulfillmentApi from Fulfillment
  storage pg { type: postgres }
  resource fulfillmentState { for: Fulfillment, kind: state, use: pg }
  deployable api {
    platform: java
    contexts: [Fulfillment]
    dataSources: [fulfillmentState]
    serves: FulfillmentApi
    port: 8080
  }
}
