// A plain (non-returning) mutating operation whose `precondition` references the
// operation's ARGUMENT in the function form.  On the Ash foundation this lowers
// to an `update` action with a `validate fn changeset, _opts -> … end` clause —
// the callback supplies neither the argument nor `record`, so the validate body
// must bind `amount` via `Ash.Changeset.get_argument/2` (and `record =
// changeset.data`).  An unbound `amount` is an `undefined variable` that
// `mix compile --warnings-as-errors` rejects.  Compiled by
// `build-generated-elixir-ash` to pin the binding against real Ash 3.x.
system Banking {
  subdomain Ledger {
    context Ledger {
      aggregate Account ids guid {
        balance: money

        // `amount <= balance` is a cross-field predicate (arg + this-prop) → the
        // function form, not a single-field built-in validator.
        operation withdraw(amount: money) {
          precondition amount <= balance
          balance := balance - amount
        }
      }

      repository Accounts for Account { }
    }
  }

  api LedgerApi from Ledger
  storage pg { type: postgres }
  resource accountState { for: Ledger, kind: state, use: pg }

  deployable phoenixApp {
    platform: elixir
    contexts: [Ledger]
    dataSources: [accountState]
    serves: LedgerApi
    port: 4000
  }
}
