// Phoenix (LiveView) operation action-button gating under auth (D-AUTH-OIDC
// sibling — the action side; completes the Phoenix UI-gate row after the page
// guard and the sidebar menu-link gate).  An auth-required LiveView app whose
// Detail page hosts an `Action(c.confirm)` button on an operation carrying a
// currentUser-only `requires` gate: the emitted LiveView wraps that
// `<.button>` in a HEEx
// `<%= if ((@current_user.role == "manager")) do %> … <% end %>` against the
// `LiveAuth.on_mount`-assigned `@current_user`.  A second action on an op with
// no `requires` (`cancel`) stays unwrapped.  This fixture exists to compile
// that gated `<%= if %>` + `@current_user` markup under
// `mix compile --warnings-as-errors` against real Ash 3.x — the markup only
// fails at compile time, so the build gate is the real bar.
system Sales {
  user {
    id: string
    role: string
  }

  subdomain Sales {
    context Sales {
      aggregate Customer {
        name: string
        status: string
        operation confirm() {
          requires currentUser.role == "manager"
          status := "confirmed"
        }
        operation cancel() {
          status := "cancelled"
        }
      }
      repository Customers for Customer { }
    }
  }

  api SalesApi from Sales

  ui SalesAdmin {
    api Sales: SalesApi
    page Detail {
      route: "/customers/:id"
      body: QueryView {
        of: Sales.Customer.byId(id),
        single: true,
        loading: Loader {},
        empty: Empty { "Not found" },
        data: c => Toolbar {
          Action { c.confirm },
          Action { c.cancel }
        }
      }
    }
  }

  storage primary { type: postgres }
  resource salesState { for: Sales, kind: state, use: primary }

  deployable phoenixApp {
    platform: elixir { foundation: ash }
    contexts: [Sales]
    dataSources: [salesState]
    serves: SalesApi
    ui: SalesAdmin { Sales: phoenixApp }
    port: 4000
    auth: required
  }
}
