// Reified criterion-ref capability filters on the Phoenix/Ash backend
// (reified-criteria.md, the anonymous-`filter` row).  A `filter <Criterion>`
// capability reifies to an Ash boolean **calculation** that `base_filter`
// references — the platform-native analog of Hono's `<name>Criterion` fn —
// instead of inlining the predicate.  This fixture is the decisive check that
// Ash 3.x accepts a calculation reference inside `base_filter expr(...)` under
// `mix compile --warnings-as-errors`, across three shapes:
//
//   * `Active`        — a zero-arg criterion: renders `base_filter expr(active)`
//                       plus `calculate :active, :boolean, expr(not record.archived)`.
//   * `InRegion(...)` — a one-arg criterion called with a literal: renders
//                       `base_filter expr(in_region(region: "EU"))` plus a calc
//                       with `argument :region` bound via `^arg(:region)` — the
//                       decisive check that an argument-bearing calc is
//                       referenceable from base_filter.
//   * `!this.flagged` — a plain inline predicate (no criterion): stays inlined,
//                       proving the non-reified path is unaffected.
system CriterionFilterShop {
  subdomain Sales {
    context Orders {
      criterion Active of Order = !this.archived
      criterion InRegion(region: string) of Order = this.region == region

      aggregate Order ids guid {
        code: string
        region: string
        archived: bool
        flagged: bool

        filter Active
        filter InRegion("EU")
        filter !this.flagged
      }

      repository Orders for Order {}
    }
  }
  api OrdersApi from Sales
  ui OrdersAdmin with scaffold(subdomains: [Sales]) { }
  storage primary { type: postgres }
  resource ordersState { for: Orders, kind: state, use: primary }
  deployable phoenixApp {
    platform: elixir
    contexts: [Orders]
    dataSources: [ordersState]
    serves: OrdersApi
    ui: OrdersAdmin
    port: 4000
  }
}
