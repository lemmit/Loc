// Phoenix (LiveView) sidebar menu-link hiding under auth (D-AUTH-OIDC sibling).
// An auth-required LiveView app whose sidebar has a link to a page with a
// currentUser-only `requires` gate: the emitted sidebar wraps that link in a
// HEEx `<%= if (@current_user.role == "agent") do %> … <% end %>` against the
// layout-assigned `@current_user`.  This fixture exists to compile that gated
// `<%= if %>` + `@current_user` markup under `mix compile --warnings-as-errors`
// against real Ash 3.x — the markup only fails at compile time, so the build
// gate is the real bar.  An ungated page's link stays unwrapped.
system Helpdesk {
  user {
    id: string
    role: string
  }

  subdomain Support {
    context Tickets {
      aggregate Ticket with crudish {
        subject: string
        open: bool
      }
      repository Tickets for Ticket { }
    }
  }

  ui Console {
    page Admin {
      route: "/admin"
      requires currentUser.role == "agent"
      body: Stack { Heading("Admin", level: 1) }
    }
    page Public {
      route: "/public"
      body: Stack { Heading("Public", level: 1) }
    }
    menu {
      section "Console" {
        link Admin
        link Public
      }
    }
  }

  storage primary { type: postgres }
  resource ticketState { for: Tickets, kind: state, use: primary }

  api SupportApi from Support
  deployable phoenixApp {
    platform: elixir { foundation: ash }
    contexts: [Tickets]
    serves: SupportApi
    dataSources: [ticketState]
    ui: Console
    port: 4000
    auth: required
  }
}
