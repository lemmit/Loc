// Discriminated-union finds on the Phoenix/Ash backend — exercises P4d union
// emission (the controller `tag_<union>/1` serializer with one struct-pattern
// clause per variant → the cross-backend `%{type: tag, …}` wire) under
// `mix compile --warnings-as-errors` in the generated-elixir-ash CI matrix.
//
// The find returns an anonymous `Order or Cancel` union; the read action is a
// single-get on the repo's aggregate, and the controller tags the result.
// Producer-side variant selection is developer logic, so the tagger's catch-all
// raises — but the whole module compiles clean.
system UnionShop {
  subdomain Sales {
    context Orders {
      aggregate Order ids guid {
        code: string
        region: string
      }
      aggregate Cancel ids guid {
        reason: string
      }
      repository Orders for Order {
        find recent(): Order or Cancel
      }
    }
  }
  api OrdersApi from Sales
  ui OrdersAdmin with scaffold(subdomains: [Sales]) { }
  storage primary { type: postgres }
  resource ordersState { for: Orders, kind: state, use: primary }
  deployable phoenixApp {
    platform: elixir
    contexts: [Orders]
    dataSources: [ordersState]
    serves: OrdersApi
    ui: OrdersAdmin
    port: 4000
  }
}
