// Value-object collections (`Money[]`) on Phoenix/Ash: persisted as id-less
// relational CHILD TABLES (`invoice_line_items`, `invoice_surcharges`) — a
// `has_many` of a child Ash resource keyed `(invoice_id, ordinal)` with a
// synthetic uuid PK, managed via `manage_relationship` (replace-on-update).
// The synthetic id / parent FK / ordinal are stripped from the wire, so the
// array stays `[{amount,currency},…]`.  The single VO field (`total: Money`)
// STAYS an embedded jsonb attribute.  The VO invariant (`amount >= 0`) is
// enforced on BOTH the embedded single VO and every array element.
system Billing {
  subdomain Sales {
    context Invoicing {
      valueobject Money {
        amount: decimal
        currency: string
        invariant amount >= 0
      }
      aggregate Invoice with crudish {
        reference: string
        total: Money
        lineItems: Money[]
        surcharges: Money[]?
      }
      repository Invoices for Invoice { }
    }
  }
  api InvoicingApi from Sales
  storage primary { type: postgres }
  resource invoicingState { for: Invoicing, kind: state, use: primary }
  deployable phoenixApp {
    platform: elixir { foundation: ash }
    contexts: [Invoicing]
    dataSources: [invoicingState]
    serves: InvoicingApi
    port: 4000
  }
}
