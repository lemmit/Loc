system DaisyuiPack {
  subdomain Sales {
    context Sales {
      valueobject Money {
        amount: decimal
        currency: string
      }
      aggregate Customer {
        name: string
        derived display: string = name
        email: string
        creditLimit: Money
        invariant email.length > 0
        operation adjustCredit(amount: decimal) {
          precondition amount > 0
        }
      }
      repository Customers for Customer { }
    }
  }
  // shape(embedded): contained WishItem parts become Ash embedded
  // resources stored inline in a jsonb column on the wishlists row.
  // Hosted (backend) but not scaffolded into the UI, so this exercises
  // the embedded resource + migration + repository without LiveView
  // pages over an embedded array.
  subdomain Shopping {
    context Shopping {
      aggregate Wishlist shape(embedded) {
        owner: string
        label: string
        derived display: string = label
        contains items: WishItem[]
        invariant label.length > 0
        entity WishItem {
          sku: string
          invariant sku.length > 0
        }
      }
      repository Wishlists for Wishlist { }
    }
  }
  api SalesApi from Sales
  ui SalesAdmin with scaffold(subdomains: [Sales]) { }
  storage primary { type: postgres }
  resource salesState { for: Sales, kind: state, use: primary }
  resource shoppingState { for: Shopping, kind: state, use: primary }
  deployable phoenixApp {
    platform: elixir
    design: daisyui
    contexts: [Sales, Shopping]
    dataSources: [salesState, shoppingState]
    serves: SalesApi
    ui: SalesAdmin
    port: 4000
  }
}
