// Bucket E2 — Phoenix LiveView page statement coverage.  A custom page
// whose Button handlers exercise the StmtIR kinds the HEEx hoisted-handler
// `renderStmt` used to drop as `# TODO`:
//   - scalar `+=` / `-=` on a page-`state` field → pipe-`assign` arithmetic
//   - `precondition` → flash + halt the socket pipe
//   - `requires`     → forbidden flash
// The decisive check is that the emitted `handle_event/3` clauses (with the
// `|> assign(...)` / `|> then(fn socket -> if ... end)` pipe steps) compile
// under `mix compile --warnings-as-errors` against real Ash 3.x.
system PageStmtCoverage {
  subdomain M {
    context C {
      aggregate Counter with crudish {
        label: string
      }
      repository Counters for Counter { }
    }
  }
  api CoverageApi from M
  ui CoverageUi {
    page Landing {
      route: "/"
      state { count: int = 0 }
      body: Stack {
        Heading { "Counter" },
        Button { "inc", onClick: e => { count += 1 } },
        Button { "dec", onClick: e => { count -= 1 } },
        Button { "guard", onClick: e => { precondition count >= 0 } },
        Button { "auth", onClick: e => { requires count > 0 } }
      }
    }
  }
  storage primary { type: postgres }
  resource cState { for: C, kind: state, use: primary }
  deployable phoenixApp {
    platform: elixir
    contexts: [C]
    dataSources: [cState]
    serves: CoverageApi
    ui: CoverageUi
    port: 4000
  }
}
