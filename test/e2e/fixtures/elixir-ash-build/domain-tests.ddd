// Domain `test "..."` blocks on the Ash foundation — the DB-free rejection gate
// (Rec3 of docs/audits/test-parity-generated-backends.md).
//
// The Ash emitter (src/generator/elixir/tests-emit.ts) lowers the REJECTION
// half of the Loom test idiom to changeset-build `valid?` checks that run with
// NO database, because Ash validations + action `validate` clauses run when the
// changeset is built:
//
//   expect(Order.create({ customer: "" })).toThrow()
//     → refute Ash.Changeset.for_create(Order, :create, %{…}).valid?      (invariant)
//   expect(Money { amount: -1.0, currency: "USD" }).toThrow()
//     → refute Ash.Changeset.for_create(Money, :create, %{…}).valid?      (VO construction)
//   let o = Order.create({…confirmed});  expect(o.confirm()).toThrow()
//     → o = %Order{…};  refute Ash.Changeset.for_update(o, :confirm, %{}).valid?  (precondition)
//
// A pure value-object field read runs too; the happy-path post-operation STATE
// assertion stays `@tag :skip` (needs a persisted record / SQL.Sandbox).  The
// build harness runs `mix test` (DB-free) whenever a project carries
// `test/test_helper.exs`.  Verified green against real Ash 3.x.
system Shop {
  subdomain Sales {
    context Selling {
      valueobject Money {
        amount: money
        currency: string
        invariant amount >= 0.0
      }
      aggregate Order ids guid {
        customer: string
        status: string = "open"
        price: Money?
        invariant customer.length > 0
        operation confirm() {
          precondition status == "open"
          status := "confirmed"
        }

        // Invariant rejection — runs DB-free.
        test "a blank customer is rejected" {
          expect(Order.create({ customer: "", status: "open" })).toThrow()
        }
        // Value-object construction invariant — runs DB-free.
        test "a negative money is rejected" {
          expect(Money { amount: -1.0, currency: "USD" }).toThrow()
        }
        test "a valid money builds" {
          let m = Money { amount: 10.5, currency: "USD" }
          expect(m.currency).toBe("USD")
        }
        // Precondition rejection — the in-memory record violates it; runs DB-free.
        test "confirming a confirmed order is rejected" {
          let o = Order.create({ customer: "acme", status: "confirmed" })
          expect(o.confirm()).toThrow()
        }
        // Happy-path post-operation state — still @tag :skip on Ash (needs a DB).
        test "confirming an open order makes it confirmed" {
          let o = Order.create({ customer: "acme", status: "open" })
          o.confirm()
          expect(o.status).toBe("confirmed")
        }
      }
      repository Orders for Order { }
    }
  }
  api A from Sales
  storage pg { type: postgres }
  resource s { for: Selling, kind: state, use: pg }
  deployable phoenixApp {
    platform: elixir { foundation: ash }
    contexts: [Selling]
    dataSources: [s]
    serves: A
    port: 4000
  }
}
