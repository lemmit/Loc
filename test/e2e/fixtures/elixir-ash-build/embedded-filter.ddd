// DEBT-02 — a capability `filter` on a `shape(embedded)` aggregate (elixir/Ash).
// An embedded Ash resource's root attributes (`subject`, `is_deleted`) are real
// columns; only the `contains lines` parts ride an embedded resource.  So a
// non-principal capability `filter` rides the same `base_filter` the relational
// path emits (`base_filter expr(not is_deleted)`) — no in-app filtering.  The
// decisive check that Ash 3.x compiles a `base_filter` on a resource that also
// carries an `{:array, Line}` embedded attribute, under
// `mix compile --warnings-as-errors`.
system EmbFilter {
  subdomain Sales {
    context Docs {
      aggregate Doc shape(embedded) {
        subject: string
        isDeleted: bool
        // soft-delete capability — every read hides a deleted doc.
        filter !this.isDeleted
        contains lines: Line[]
        entity Line { text: string }
        operation addLine(text: string) {
          lines += Line { text: text }
        }
        operation softDelete() { isDeleted := true }
      }
      repository Docs for Doc {
        find bySubject(s: string): Doc[] where this.subject == s
      }
    }
  }
  storage primary { type: postgres }
  resource docsState { for: Docs, kind: state, use: primary }
  ui WebApp {}
  deployable phoenixApp {
    platform: elixir { foundation: ash }
    contexts: [Docs]
    dataSources: [docsState]
    ui: WebApp
    port: 4000
  }
}
