// D-PHOENIX-SURFACE phase 6c — a Phoenix backend that EMBEDS a React SPA.
//
// The keystone case the whole proposal unlocks: `platform: phoenix`
// (an Ash/JSON-API backend) `hosts:` a `ui { framework: react }`.  The
// orchestrator emits the Ash domain + `/api` controllers + OpenAPI (the
// LiveView pages are NOT emitted), plus the React project under
// `assets/`, plus the serve-wiring (endpoint `/app` Plug.Static, router
// `/app` SpaController fallback, multi-stage Dockerfile).
//
// This fixture's job in CI is the `mix compile --warnings-as-errors`
// gate: it proves the embedded-react Elixir side (endpoint + router +
// SpaController) compiles against real Ash 3.x — the one path the local
// fast suite can't exercise.  The React `assets/` half is generated by
// the same `generateReactForContexts` the react-build matrix already
// covers.
system PhoenixEmbedReact {
  subdomain Catalog {
    context Catalog {
      aggregate Product {
        name: string
        derived display: string = name
        price: decimal
        invariant name.length > 0
        operation reprice(to: decimal) {
          precondition to > 0
        }
      }
      repository Products for Product { }
    }
  }

  api CatalogApi from Catalog

  // The hosted UI declares `framework: react` — so the phoenix
  // deployable embeds it as a SPA rather than rendering LiveView.
  ui Storefront {
    framework: react
    page Products {
      route: "/products"
      title: "Products"
      body: Stack { Breadcrumbs { Anchor { "Home", to: "/" }, Text { "Products" } }, Toolbar { Heading { "Products", level: 2 }, Button { "New product", to: "/products/new", testid: "products-list-create" } }, QueryView { of: Product.all, loading: Skeleton { count: 5 }, error: Alert { "Couldn't load products" }, empty: Empty { "No products yet." }, data: rows => Paper { Table { Column { "ID", o => IdLink { o.id, of: Product } }, Column { "Name", o => Text { o.name } }, Column { "Price", o => Text { o.price } }, rows: rows, striped: true, highlight: true, sticky: true, rowTestid: r => "products-row-" + r.id } } }, testid: "products-list" }
    }
  }

  storage primary { type: postgres }
  resource catalogState { for: Catalog, kind: state, use: primary }

  deployable phoenixApp {
    platform: phoenix
    contexts: [Catalog]
    dataSources: [catalogState]
    serves: CatalogApi
    hosts: Storefront
    port: 4000
    design: mantine
  }
}
