// DEBT-01 — principal-referencing (tenancy) capability filter on Phoenix/Ash.
// `filter this.tenantId == currentUser.tenantId` compiles to an Ash
// `base_filter expr(tenant_id == ^actor(:tenant_id))`, and every read of the
// aggregate runs with `actor: current_user` (the request principal from the
// JWT, on `conn.assigns.current_user`) so the actor template resolves.  This
// fixture is the decisive check that Ash 3.x accepts an `^actor(:field)`
// reference inside `base_filter expr(...)` AND that the actor-threaded reads
// (CRUD list/get + the context view) compile under `mix compile
// --warnings-as-errors` against real Ash 3.x (the elixir-ash-build gate).
//
// Auth is wired exactly like auth-oidc.ddd (a proven-compiling path); the
// `tenantId` claim feeds the actor the base_filter binds.
system TenancyBank {
  user {
    id: string
    tenantId: string
  }

  auth {
    provider: keycloak
    oidc {
      issuer: env("OIDC_ISSUER")
      clientId: env("OIDC_CLIENT_ID")
    }
    claims: { tenantId: "tenant_id" }
  }

  subdomain Core {
    context Ledger {
      aggregate Account ids guid {
        tenantId: string
        balance: int
        // Always-on row scoping: every read of Account is constrained to the
        // requesting principal's tenant.
        filter this.tenantId == currentUser.tenantId
      }
      repository Accounts for Account {}

      // A context view sourced from the tenancy aggregate — exercises the
      // `Ash.read!(actor: current_user)` threading on the view read path.
      view RichAccounts = Account where balance >= 1000
    }
  }

  storage primary { type: postgres }
  resource ledgerState { for: Ledger, kind: state, use: primary }

  api LedgerApi from Core
  deployable phoenixApp {
    platform: elixir { foundation: ash }
    contexts: [Ledger]
    serves: LedgerApi
    dataSources: [ledgerState]
    port: 4000
    auth: required
  }
}
