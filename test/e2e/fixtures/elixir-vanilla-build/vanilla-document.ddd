// `shape: document` persistence on the vanilla foundation (DEBT-07).  The whole
// aggregate persists as ONE jsonb `data` blob in an `(id, data, version)` table
// (the canonical document table the migrations-builder already emits) instead
// of flattened columns.  The write path validates the domain fields through a
// SCHEMALESS Ecto changeset (cast + validate_required + invariant validators —
// the same contract the relational `base_changeset` runs) and stores the
// validated map; reads merge `data` back over the id.  Scalar custom finds
// (in-memory filter) and scalar named operations (body over the `data` map,
// persisted via the document repo's `update/2`) are emitted too (DEBT-07).
//
// Compiled by build-generated-elixir-vanilla so the document schema, the
// schemaless changeset, the (id, data, version) repository, the scalar finds,
// and the scalar named-op context fns actually pass
// `mix compile --warnings-as-errors` against plain Ecto.
system Carting {
  subdomain Sales {
    context Carts {
      // A value object + an enum exercise the non-primitive (de)serialise path
      // through the jsonb blob.
      valueobject Money { amount: int  currency: string }
      enum CartStatus { open, checkedOut }
      error AlreadyClosed { message: string }

      aggregate Cart shape: document with crudish {
        reference: string
        status: CartStatus
        subtotal: Money
        itemCount: int
        invariant itemCount >= 0

        // A pure function on a document aggregate compiles over the jsonb `data`
        // map too (DEBT-07) — reads `data["status"]`, callable from op guards.
        function isOpen(): bool = status == open

        // Scalar named operations (DEBT-07) — run over the jsonb `data` map,
        // including a function call and a value-object-subfield read.
        operation addItem() {
          precondition isOpen()
          precondition subtotal.amount >= 0
          itemCount := itemCount + 1
        }
        operation checkOut() {
          precondition status == open
          status := checkedOut
        }

        // A RETURNING op (exception-less `: A or B`, DEBT-07) — the tagged tuple
        // the controller translates to HTTP; the fall-through success projects the
        // in-memory wire, an error variant maps to RFC-7807.
        operation tryCheckOut(): Cart or AlreadyClosed {
          return AlreadyClosed { message: "cart already checked out" }
        }
      }
      // Scalar custom finds (DEBT-07) — in-memory filter over loaded rows.
      repository Carts for Cart {
        find byReference(reference: string): Cart? where this.reference == reference
        find checkedOutOnes(): Cart[] where this.status == checkedOut
      }
    }
  }
  api CartsApi from Sales
  storage pg { type: postgres }
  resource cartState { for: Carts, kind: state, use: pg }
  deployable api {
    platform: elixir
    contexts: [Carts]
    dataSources: [cartState]
    serves: CartsApi
    port: 4000
  }
}
