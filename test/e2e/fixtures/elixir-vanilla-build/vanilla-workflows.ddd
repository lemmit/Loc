// Slice 5c body-lowering follow-up — exercises `factory-let` and
// `op-call` body lowering on a vanilla workflow.  The fixture's
// `createAndComplete` workflow creates a Task then immediately calls
// its `markDone` operation, so the body lowers to a `with`-chain over
// `Context.create_task(%{...})` + `Context.mark_done_task(t, %{})`.
// Validated by the elixir-vanilla-build.yml mix-compile gate.
system Tasks {
  subdomain Productivity {
    context Tracker {
      aggregate Task with crudish {
        title: string
        done: bool

        operation markDone() {
          done := true
        }
      }
      repository Tasks for Task { }

      // Empty body — exercises the SHAPE-only emit path.
      workflow markAllDone transactional {
        create() { }
      }

      // Body-lowering exercise — factory-let + op-call.  Param-reference
      // lowering (workflow create-params surfacing inside the body) is
      // a separate follow-up slice; today the create body uses literals.
      workflow createAndComplete transactional {
        create() {
          let t = Task.create({ title: "Untitled", done: false })
          t.markDone()
        }
      }

      // Guard + expr-let exercise — covers `precondition`, `requires`,
      // and `expr-let` lowering.  Each becomes a `with`-clause in the
      // lowered `run_inner/1` chain; the failure tags propagate through
      // the with-chain to the controller (422 / 403 RFC 7807 responses).
      workflow guardedCreate transactional {
        create() {
          precondition true
          requires true
          let placeholder = "Untitled"
          let t = Task.create({ title: placeholder, done: false })
          t.markDone()
        }
      }
    }
  }
  api TrackerApi from Productivity
  storage primary { type: postgres }
  resource trackerState { for: Tracker, kind: state, use: primary }
  deployable api {
    platform: elixir { foundation: vanilla }
    contexts: [Tracker]
    dataSources: [trackerState]
    serves: TrackerApi
    port: 4000
  }
}
