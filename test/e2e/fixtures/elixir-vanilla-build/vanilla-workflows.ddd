// Slice 5c fixture — exercises vanilla workflow EXECUTION emission.
// Drives the workflow module emitter (vanilla/workflow-execution-emit.ts)
// + the named-operation context-emit prerequisite + the
// WorkflowsController + spliced routes through the elixir-vanilla-build
// mix-compile gate.  Body lowering for individual statement kinds is
// incremental; this fixture verifies the SHAPE compiles under
// --warnings-as-errors.
system Tasks {
  subdomain Productivity {
    context Tracker {
      aggregate Task with crudish {
        title: string
        done: bool

        operation markDone() {
          done := true
        }
      }
      repository Tasks for Task { }

      workflow markAllDone transactional {
        create() { }
      }
    }
  }
  api TrackerApi from Productivity
  storage primary { type: postgres }
  resource trackerState { for: Tracker, kind: state, use: primary }
  deployable api {
    platform: elixir { foundation: vanilla }
    contexts: [Tracker]
    dataSources: [trackerState]
    serves: TrackerApi
    port: 4000
  }
}
