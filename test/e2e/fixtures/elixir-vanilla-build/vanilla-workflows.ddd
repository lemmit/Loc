// Slice 5c body-lowering follow-up — exercises `factory-let` and
// `op-call` body lowering on a vanilla workflow.  The fixture's
// `createAndComplete` workflow creates a Task then immediately calls
// its `markDone` operation, so the body lowers to a `with`-chain over
// `Context.create_task(%{...})` + `Context.mark_done_task(t, %{})`.
// Validated by the elixir-vanilla-build.yml mix-compile gate.
system Tasks {
  subdomain Productivity {
    context Tracker {
      aggregate Task with crudish {
        title: string
        done: bool
        priority: int?
        labels: string[]

        operation markDone() {
          done := true
        }

        // Exception-less returning op — exercises Bucket E1 coverage of the
        // returning-op body's collection mutations (`add`/`remove`) AND a bare
        // `call` statement, all in one body.  `relabel` appends then drops a
        // label, makes a bare call (a no-op on vanilla, which emits no
        // aggregate-function helpers), and falls through to the `Task` success
        // variant.  The compile gate proves all three lower to compilable
        // Elixir under --warnings-as-errors (previously the `call` # TODO'd).
        operation relabel(label: string): Task or Rejected {
          labels += label
          labels -= label
          noop()
        }

        // Domain function decl — accepted by the parser; on vanilla the helper
        // is not emitted onto the schema module, so a bare `call` to it lowers
        // to a discarding no-op (see operation-returns-emit `call` arm).
        function noop(): int = 1
      }
      error Rejected { reason: string }
      // A custom-find — exercises Slice 8 (repository custom-find emission +
      // context defdelegate).  Convention-find: no explicit `where`,
      // so the params match aggregate property names.
      // `byDone(done: bool): Task[]` lowers to a
      // `def by_done(done)` fn on the repository module +
      // `defdelegate by_done_task(done), as: :by_done` on the context.
      repository Tasks for Task {
        find byDone(done: bool): Task[]
      }

      // Empty body — exercises the SHAPE-only emit path.
      workflow markAllDone transactional {
        create() { }
      }

      // Body-lowering exercise — factory-let + op-call with literal
      // create-fields (the simplest mutating shape).
      workflow createAndComplete transactional {
        create() {
          let t = Task.create({ title: "Untitled", done: false, labels: ["init"] })
          t.markDone()
        }
      }

      // Guard + expr-let + param-surfacing exercise — covers
      // `precondition`, `requires`, `expr-let`, AND a referenced
      // create-param.  The `initialTitle` param surfaces as a leading
      // `%{"initial_title" => initial_title} = params` destructure off the
      // run/1 map, then flows into the precondition guard and the factory
      // create — proving the bound local compiles under
      // `--warnings-as-errors` (a bare unbound ref would not).
      workflow guardedCreate transactional {
        create(initialTitle: string) {
          precondition initialTitle.length > 0
          requires true
          let normalised = initialTitle
          let t = Task.create({ title: normalised, done: false, labels: ["init"] })
          t.markDone()
        }
      }

      // repo-let exercise — loads an existing aggregate by id then mutates
      // it.  `Tasks.getById(taskId)` lowers to a
      // `{:ok, t} <- Context.get_task(task_id)` with-clause off the
      // find_by_id facade; a missing record short-circuits to
      // `{:error, :not_found}` (controller → 404).  Proves the loaded
      // local + the id param-surfacing compile under --warnings-as-errors.
      workflow completeExisting transactional {
        create(taskId: Task id) {
          let t = Tasks.getById(taskId)
          t.markDone()
        }
      }

      // emit exercise — broadcasts a domain event over Phoenix.PubSub
      // INSIDE the with-chain's do-branch (skipped on rollback).  Proves
      // the `Events.<Name>` struct module + the broadcast line compile
      // cleanly against the real Phoenix.PubSub + the orchestrator-emitted
      // event struct.
      event TaskFinished { task: Task id, at: datetime }
      workflow finishExisting transactional {
        create(taskId: Task id) {
          let t = Tasks.getById(taskId)
          t.markDone()
          emit TaskFinished { task: taskId, at: now() }
        }
      }

      // resource-call exercise — a bare resource-op statement form
      // (`files.put(key, body)`).  Lowers to a discarded adapter call
      // (`_ = Api.Resources.S3.files_put(...)`) inside the with-chain's
      // do-branch, against the shared Phoenix resource adapter module.
      // Validates that the resource helper module + its ex_aws_s3 hex dep
      // pipeline compile under --warnings-as-errors.  Non-transactional
      // because the validator (loom.workflow-tx-effect) forbids external
      // side effects inside a transactional span.
      workflow archiveTask {
        create(taskId: Task id) {
          files.put("archive/seed", "{}")
        }
      }

      // retrieval — a named Ecto query bundle.  Lowers to
      // `lib/api/tracker/retrievals/done_tasks.ex` with
      // `def run(d, opts \\\\ [])` building
      // `from(record in Api.Tracker.Task, where: record.done == ^d) |> Repo.all()`
      // plus a context defdelegate `run_done_tasks_task(d, opts \\\\ [])`.
      retrieval DoneTasks(d: bool) of Task {
        where: this.done == d
        sort:  [title asc]
      }

      // repo-run + for-each exercise — page a named retrieval, then
      // iterate the result and mutate each element.  Lowers to:
      //   {:ok, xs} <- Context.run_done_tasks_task(d, offset: 0, limit: 100),
      //   {:ok, _} <- Enum.reduce_while(xs, {:ok, nil}, fn x, _acc ->
      //     case Context.mark_done_task(x, %{}) do
      //       {:ok, updated} -> {:cont, {:ok, updated}}
      //       err -> {:halt, err}
      //     end
      //   end)
      // The reduce_while bubbles the first per-element failure up the
      // with-chain.  Non-transactional (this is the final body-lowering
      // slice; pairing with `transactional` is a separate behavioural
      // test, not a syntactic gate).
      workflow finalizeBatch {
        create(d: bool) {
          let xs = Tasks.run(DoneTasks(d), page: { offset: 0, limit: 100 })
          for x in xs {
            x.markDone()
          }
        }
      }

      // Bucket E1 — for-each body with MORE than a bare op-call.  The loop
      // body mixes an `op-call` with an `emit`, so it lowers through a
      // per-iteration `with`-chain (the op-call as a fallible `<-` clause, the
      // broadcast in the do-branch) instead of the flat `case` form.  Gates
      // that the broader for-each body compiles under --warnings-as-errors.
      workflow finalizeBatchEmitting {
        create(d: bool) {
          let xs = Tasks.run(DoneTasks(d), page: { offset: 0, limit: 100 })
          for x in xs {
            x.markDone()
            emit TaskFinished { task: x.id, at: now() }
          }
        }
      }

      // Reusable predicate for the if-let lookup below.
      criterion Pending(flag: bool) of Task = this.done == flag

      // Bucket E1 — if-let with branch bodies BEYOND a bare op-call.  The
      // then-branch runs an op-call + an emit; the else-branch creates a fresh
      // aggregate (factory-let).  Both branches lower the full statement set.
      workflow findOrCreate transactional {
        create(flag: bool) {
          if let t = Tasks.find(Pending(flag)) {
            t.markDone()
            emit TaskFinished { task: t.id, at: now() }
          } else {
            let fresh = Task.create({ title: "fallback", done: false, labels: ["init"] })
          }
        }
      }
    }
  }
  api TrackerApi from Productivity {
    httpStatus Rejected -> 409
  }
  storage primary { type: postgres }
  storage objects { type: s3, config: { bucket: "loom-test" } }
  resource trackerState { for: Tracker, kind: state, use: primary }
  resource files       { for: Tracker, kind: objectStore, use: objects }
  deployable api {
    platform: elixir
    contexts: [Tracker]
    dataSources: [trackerState, files]
    serves: TrackerApi
    port: 4000
  }
}
