// Slice 5c body-lowering follow-up ‚Äî exercises `factory-let` and
// `op-call` body lowering on a vanilla workflow.  The fixture's
// `createAndComplete` workflow creates a Task then immediately calls
// its `markDone` operation, so the body lowers to a `with`-chain over
// `Context.create_task(%{...})` + `Context.mark_done_task(t, %{})`.
// Validated by the elixir-vanilla-build.yml mix-compile gate.
system Tasks {
  subdomain Productivity {
    context Tracker {
      aggregate Task with crudish {
        title: string
        done: bool

        operation markDone() {
          done := true
        }
      }
      repository Tasks for Task { }

      // Empty body ‚Äî exercises the SHAPE-only emit path.
      workflow markAllDone transactional {
        create() { }
      }

      // Body-lowering exercise ‚Äî factory-let + op-call with literal
      // create-fields (the simplest mutating shape).
      workflow createAndComplete transactional {
        create() {
          let t = Task.create({ title: "Untitled", done: false })
          t.markDone()
        }
      }

      // Guard + expr-let + param-surfacing exercise ‚Äî covers
      // `precondition`, `requires`, `expr-let`, AND a referenced
      // create-param.  The `initialTitle` param surfaces as a leading
      // `%{"initial_title" => initial_title} = params` destructure off the
      // run/1 map, then flows into the precondition guard and the factory
      // create ‚Äî proving the bound local compiles under
      // `--warnings-as-errors` (a bare unbound ref would not).
      workflow guardedCreate transactional {
        create(initialTitle: string) {
          precondition initialTitle.length > 0
          requires true
          let normalised = initialTitle
          let t = Task.create({ title: normalised, done: false })
          t.markDone()
        }
      }

      // repo-let exercise ‚Äî loads an existing aggregate by id then mutates
      // it.  `Tasks.getById(taskId)` lowers to a
      // `{:ok, t} <- Context.get_task(task_id)` with-clause off the
      // find_by_id facade; a missing record short-circuits to
      // `{:error, :not_found}` (controller ‚Üí 404).  Proves the loaded
      // local + the id param-surfacing compile under --warnings-as-errors.
      workflow completeExisting transactional {
        create(taskId: Task id) {
          let t = Tasks.getById(taskId)
          t.markDone()
        }
      }

      // emit exercise ‚Äî broadcasts a domain event over Phoenix.PubSub
      // INSIDE the with-chain's do-branch (skipped on rollback).  Proves
      // the `Events.<Name>` struct module + the broadcast line compile
      // cleanly against the real Phoenix.PubSub + the orchestrator-emitted
      // event struct.
      event TaskFinished { task: Task id, at: datetime }
      workflow finishExisting transactional {
        create(taskId: Task id) {
          let t = Tasks.getById(taskId)
          t.markDone()
          emit TaskFinished { task: taskId, at: now() }
        }
      }

      // resource-call exercise ‚Äî a bare resource-op statement form
      // (`files.put(key, body)`).  Lowers to a discarded adapter call
      // (`_ = Api.Resources.S3.files_put(...)`) inside the with-chain's
      // do-branch, against the shared Phoenix resource adapter module.
      // Validates that the resource helper module + its ex_aws_s3 hex dep
      // pipeline compile under --warnings-as-errors.  Non-transactional
      // because the validator (loom.workflow-tx-effect) forbids external
      // side effects inside a transactional span.
      workflow archiveTask {
        create(taskId: Task id) {
          files.put("archive/seed", "{}")
        }
      }

      // retrieval exercise ‚Äî a named Ecto query bundle with a typed
      // param.  Lowers to `lib/api/tracker/retrievals/done_tasks.ex`
      // with a `def run(d, opts \\\\ [])` that builds
      // `from(record in Api.Tracker.Task, where: record.done == ^d) |> Repo.all()`
      // and a defdelegate on the context facade
      // (`run_done_tasks_task(d, opts \\\\ [])`).  Workflow `repo-run`
      // lowering is a follow-up slice; this slice's gate is just that
      // the emitted module + delegate compile under --warnings-as-errors.
      retrieval DoneTasks(d: bool) of Task {
        where: this.done == d
        sort:  [title asc]
      }
    }
  }
  api TrackerApi from Productivity
  storage primary { type: postgres }
  storage objects { type: s3, config: { bucket: "loom-test" } }
  resource trackerState { for: Tracker, kind: state, use: primary }
  resource files       { for: Tracker, kind: objectStore, use: objects }
  deployable api {
    platform: elixir { foundation: vanilla }
    contexts: [Tracker]
    dataSources: [trackerState, files]
    serves: TrackerApi
    port: 4000
  }
}
