// Custom-find HTTP surface.  Compiled by build-generated-elixir-vanilla so the
// emitted `GET /<plural>/<find>` controller actions — list (map each result),
// single (one-or-nil), and param-less (`_params`) — pass
// `mix compile --warnings-as-errors`.  A union find stays internal-only.
system Catalog {
  subdomain Core {
    context Shop {
      aggregate Order with crudish {
        customerId: string
        total: int
      }
      repository Orders for Order {
        find byCustomer(customerId: string): Order[] where this.customerId == customerId
        find latest(): Order?
      }
    }
  }
  api CatalogApi from Core
  storage pg { type: postgres }
  resource orderState { for: Shop, kind: state, use: pg }
  deployable api {
    platform: elixir
    contexts: [Shop]
    dataSources: [orderState]
    serves: CatalogApi
    port: 4000
  }
}
