// DEBT-02 — a capability `filter` on a `shape(embedded)` aggregate (elixir,
// `foundation: vanilla`).  An embedded aggregate's root is a real Ecto schema
// backed by a Postgres table: its root scalars (`code`, `archived`) are real
// columns, so the non-principal capability `filter` AND-s into every root read
// via `from(record in <Agg>, where: ...)` exactly like the relational path
// (`vanillaCapabilityFilter` is shape-agnostic).  Compiled by
// build-generated-elixir-vanilla under `mix compile --warnings-as-errors`.
//
// NOTE: this exercises the embedded-shape *gate* + filter emission on scalar
// roots.  Entity `contains` parts on a vanilla embedded aggregate are a
// separate, pre-existing gap (the vanilla schema emitter folds value objects to
// `:map` but drops entity containments) — out of scope for the filter slice and
// tracked under DEBT-02's vanilla-embedded follow-up.
system VanillaEmbFilter {
  subdomain Core {
    context Shop {
      aggregate Order shape(embedded) {
        code: string
        archived: bool
        // Soft-delete style scoping — must reach every read below.
        filter !this.archived
        operation archive() { archived := true }
      }
      repository Orders for Order {
        find byCode(code: string): Order[] where this.code == code
      }
      view ActiveOrders = Order where code != ""
    }
  }
  api CatalogApi from Core
  storage pg { type: postgres }
  resource orderState { for: Shop, kind: state, use: pg }
  deployable api {
    platform: elixir { foundation: vanilla }
    contexts: [Shop]
    dataSources: [orderState]
    serves: CatalogApi
    port: 4000
  }
}
