// daisyui design pack + scaffold + shape: embedded on the vanilla foundation —
// relocated from the former daisyui-pack fixture (it was already
// `foundation: vanilla` there; moved here so it survives the ash-build directory
// deletion).  Exercises `design: daisyui`, scaffolded LiveView pages, a derived
// field, a value object, and a `shape: embedded` containment array.
system DaisyuiPack {
  subdomain Sales {
    context Sales {
      valueobject Money {
        amount: decimal
        currency: string
      }
      aggregate Customer {
        name: string
        derived display: string = name
        email: string
        creditLimit: Money
        invariant email.length > 0
        operation adjustCredit(amount: decimal) {
          precondition amount > 0
        }
      }
      repository Customers for Customer { }
    }
  }
  subdomain Shopping {
    context Shopping {
      aggregate Wishlist shape: embedded {
        owner: string
        label: string
        derived display: string = label
        contains items: WishItem[]
        invariant label.length > 0
        entity WishItem {
          sku: string
          invariant sku.length > 0
        }
      }
      repository Wishlists for Wishlist { }
    }
  }
  api SalesApi from Sales
  ui SalesAdmin with scaffold(subdomains: [Sales]) { }
  storage primary { type: postgres }
  resource salesState { for: Sales, kind: state, use: primary }
  resource shoppingState { for: Shopping, kind: state, use: primary }
  deployable phoenixApp {
    platform: elixir
    design: daisyui
    contexts: [Sales, Shopping]
    dataSources: [salesState, shoppingState]
    serves: SalesApi
    ui: SalesAdmin
    port: 4000
  }
}
