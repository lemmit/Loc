// Lifecycle stamps on the VANILLA (plain Ecto/Phoenix, non-Ash) foundation.
// `with auditable` adds the managed `createdAt`/`updatedAt`/`createdBy`/`updatedBy`
// audit fields + the onCreate/onUpdate stamps (createdAt/updatedAt := now(),
// createdBy/updatedBy := currentUser).  The vanilla codegen now APPLIES these:
// each becomes an `Ecto.Changeset.put_change` pipe line on the changeset right
// before `Repo.insert`/`Repo.update` (the analogue of the Ash
// `force_change_attribute ... change` block).  `now()` → `DateTime.utc_now()`;
// `currentUser` → the principal id read off the threaded `current_user` map
// (`current_user.id`, nil-safe) — `current_user` is pulled off `conn.assigns`
// (the Auth plug populates it; `auth: required` is mandated for a principal
// stamp) and threaded through `create_order`/`update_order` into the repository.
//
// The audit `created_at`/`updated_at` become REAL schema fields (so put_change
// is valid) and the managed `created_by`/`updated_by` are excluded from the
// changeset cast.  Compiled under `mix compile --warnings-as-errors`.
system VanillaAudit {
  user { id: guid  name: string }

  subdomain D {
    context Shop {
      aggregate Order with auditable, crudish { code: string }
      repository Orders for Order { }
    }
  }

  api A from D
  storage primary { type: postgres }
  resource shopSt { for: Shop, kind: state, use: primary }
  deployable api {
    platform: elixir
    contexts: [Shop]
    dataSources: [shopSt]
    serves: A
    port: 4000
    auth: required
  }
}
