// DEBT-02 Slice A — a PRINCIPAL-referencing capability filter
// (`filter this.tenantId == currentUser.tenantId`) on a `shape: embedded`
// aggregate, on the VANILLA (plain Ecto) foundation.  An embedded aggregate's
// root scalars (`tenant_id`, `code`) are real columns; only the `contains
// items` parts ride an embedded schema.  Previously this combination was GATED
// by `loom.context-filter-unsupported`; Slice A lifts the gate and reuses the
// relational-principal path — `record.tenant_id == ^(current_user &&
// current_user.tenant_id)` is threaded through every root read, with
// `current_user` threaded from `conn.assigns` (the Auth plug the validator
// requires when a principal filter is present).  A nil actor pins to `nil`
// (fail-closed → no rows, never a cross-tenant leak).
//
// Decisive check that the actor-threaded vanilla reads on an EMBEDDED aggregate
// compile under `mix compile --warnings-as-errors` (the elixir-vanilla-build
// gate).  Auth is wired like the relational `vanilla-tenancy.ddd` sibling.
// (`shape: document` + principal stays gated — Slice B.)
system EmbTenancy {
  user {
    id: string
    tenantId: string
  }

  auth {
    provider: keycloak
    oidc {
      issuer: env("OIDC_ISSUER")
      clientId: env("OIDC_CLIENT_ID")
    }
    claims: { tenantId: "tenant_id" }
  }

  subdomain D {
    context Shop {
      aggregate Order shape: embedded {
        tenantId: string
        code: string
        // Always-on row scoping by the requesting principal's tenant.
        filter this.tenantId == currentUser.tenantId
        contains items: Item[]
        entity Item { sku: string  qty: int }
        operation addItem(sku: string, qty: int) {
          items += Item { sku: sku, qty: qty }
        }
      }
      repository Orders for Order {
        find byCode(code: string): Order[] where this.code == code
      }
    }
  }

  api A from D
  storage primary { type: postgres }
  resource st { for: Shop, kind: state, use: primary }
  deployable api {
    platform: elixir
    contexts: [Shop]
    dataSources: [st]
    serves: A
    port: 4000
    auth: required
  }
}
