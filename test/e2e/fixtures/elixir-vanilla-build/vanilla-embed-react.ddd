// A vanilla (plain Ecto) Phoenix backend that EMBEDS a React SPA — port of
// the former elixir-embed-react fixture.  `platform: elixir` `hosts:` a
// `ui { framework: react }`: the orchestrator emits the domain + `/api`
// controllers + OpenAPI (no LiveView pages), plus the React project under
// `assets/`, plus the serve-wiring (endpoint `/app` Plug.Static, router `/app`
// SpaController fallback, multi-stage Dockerfile).
system PhoenixEmbedReact {
  subdomain Catalog {
    context Catalog {
      aggregate Product {
        name: string
        derived display: string = name
        price: decimal
        invariant name.length > 0
        operation reprice(to: decimal) {
          precondition to > 0
        }
      }
      repository Products for Product { }
    }
  }

  api CatalogApi from Catalog

  ui Storefront {
    framework: react
    page Products {
      route: "/products"
      title: "Products"
      body: Stack { Breadcrumbs { Anchor { "Home", to: "/" }, Text { "Products" } }, Toolbar { Heading { "Products", level: 2 }, Button { "New product", to: "/products/new", testid: "products-list-create" } }, QueryView { of: Product.all, loading: Skeleton { count: 5 }, error: Alert { "Couldn't load products" }, empty: Empty { "No products yet." }, data: rows => Paper { Table { Column { "ID", o => IdLink { o.id, of: Product } }, Column { "Name", o => Text { o.name } }, Column { "Price", o => Text { o.price } }, rows: rows, striped: true, highlight: true, sticky: true, rowTestid: r => "products-row-" + r.id } } }, testid: "products-list" }
    }
  }

  storage primary { type: postgres }
  resource catalogState { for: Catalog, kind: state, use: primary }

  deployable phoenixApp {
    platform: elixir
    contexts: [Catalog]
    dataSources: [catalogState]
    serves: CatalogApi
    hosts: Storefront
    port: 4000
    design: mantine
  }
}
