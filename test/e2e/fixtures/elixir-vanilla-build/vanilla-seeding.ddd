// Database seeding (`seed`) on the vanilla (plain Ecto) backend — port of
// the former seeding fixture.  Scalar + enum fields only, so the vanilla
// create-action seed path (priv/repo/seeds.exs) compiles trivially under
// `mix compile --warnings-as-errors`.
system Seeding {
  subdomain Catalog {
    context Catalog {
      enum Tier { Free, Pro }

      aggregate Widget with crudish {
        name: string
        size: int
        tier: Tier
        invariant size >= 0
        derived display: string = name
      }

      repository Widgets for Widget { }

      seed default {
        Widget { name: "Alpha", size: 1, tier: Free }
        Widget { name: "Beta", size: 2, tier: Pro }
      }
      seed demo {
        Widget { name: "Gamma", size: 3, tier: Pro }
      }
    }
  }

  api CatalogApi from Catalog
  storage primary { type: postgres }
  resource catalogState { for: Catalog, kind: state, use: primary }

  deployable api {
    platform: elixir { foundation: vanilla }
    contexts: [Catalog]
    dataSources: [catalogState]
    serves: CatalogApi
    port: 4000
  }
}
