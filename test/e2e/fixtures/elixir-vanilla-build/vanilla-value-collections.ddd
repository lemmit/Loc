// Value-object collections (`Money[]`) on the vanilla Ecto/Phoenix foundation:
// persisted as id-less relational CHILD TABLES (`invoice_line_items`,
// `invoice_surcharges`) — a `has_many` of a child Ecto schema keyed
// `(invoice_id, ordinal)` with a synthetic binary_id PK, cast via `cast_assoc`
// with `on_replace: :delete` (replace-on-update).  The synthetic id / parent FK
// / ordinal are stripped from the wire (`@derive Jason.Encoder, only:`), so the
// array stays `[{amount,currency},…]`.  The single VO field (`total: Money`)
// STAYS a plain `:map` (jsonb) column.  The VO invariant (`amount >= 0`) is
// enforced on BOTH the single VO (`validate_vo`) and every array element.
system Billing {
  subdomain Sales {
    context Invoicing {
      valueobject Money {
        amount: decimal
        currency: string
        invariant amount >= 0
      }
      aggregate Invoice with crudish {
        reference: string
        total: Money
        lineItems: Money[]
        surcharges: Money[]?
      }
      repository Invoices for Invoice { }
    }
  }
  api InvoicingApi from Sales
  storage primary { type: postgres }
  resource invoicingState { for: Invoicing, kind: state, use: primary }
  deployable api {
    platform: elixir
    contexts: [Invoicing]
    dataSources: [invoicingState]
    serves: InvoicingApi
    port: 4000
  }
}
