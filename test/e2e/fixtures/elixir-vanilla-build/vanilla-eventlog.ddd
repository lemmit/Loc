// Event sourcing on `foundation: vanilla` (D-VANILLA-ES-HOME, T2.b / P4.1-2).
// Compiled by `build-generated-elixir-vanilla` so the from-scratch ES emit —
// the in-memory struct, the `<Agg>EventLog` Ecto schema, the `<Agg>Fold`
// (apply_event/2 + from_events/2), the event-store repository (load+fold reads,
// gap-free append), and the emit→append→fold command runners + ES controller —
// actually passes `mix compile --warnings-as-errors`, not just the structure tests.
system Ledger {
  subdomain Core {
    context Accounts {
      event Opened { account: Account id, owner: string }
      event Deposited { account: Account id, amount: int }
      event Withdrawn { account: Account id, amount: int }

      aggregate Account ids guid persistedAs(eventLog) {
        owner: string
        balance: int

        create open(owner: string) {
          emit Opened { account: id, owner: owner }
        }

        operation deposit(amount: int) {
          precondition amount > 0
          emit Deposited { account: id, amount: amount }
        }

        operation withdraw(amount: int) {
          precondition amount > 0
          precondition balance >= amount
          emit Withdrawn { account: id, amount: amount }
        }

        apply(e: Opened) {
          owner := e.owner
          balance := 0
        }

        apply(e: Deposited) {
          balance := balance + e.amount
        }

        apply(e: Withdrawn) {
          balance := balance - e.amount
        }
      }

      repository Accounts for Account {
        find byOwner(owner: string): Account? where this.owner == owner
      }
    }
  }

  api LedgerApi from Core
  storage pg { type: postgres }
  resource accountsLog { for: Accounts, kind: eventLog, use: pg }

  deployable api {
    platform: elixir
    contexts: [Accounts]
    dataSources: [accountsLog]
    serves: LedgerApi
    port: 4000
  }
}
