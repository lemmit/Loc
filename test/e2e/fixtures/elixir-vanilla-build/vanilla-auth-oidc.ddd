// OIDC turnkey auth on Phoenix (D-AUTH-OIDC) — an `auth { oidc }` block makes
// the generated Auth plug a REAL OIDC verifier (joken + joken_jwks against the
// issuer's JWKS), pulls {:joken, ...} + {:joken_jwks, ...} + :inets/:ssl into
// mix.exs, and adds the /auth/me session probe.  This fixture compiles all of
// that under `mix compile --warnings-as-errors` against plain Ecto/Phoenix
// (the vanilla build gate).
system Helpdesk {
  user {
    id: string
    roles: string[]
    email: string
  }

  auth {
    provider: keycloak
    oidc {
      issuer: env("OIDC_ISSUER")
      clientId: env("OIDC_CLIENT_ID")
      // audience exercises the verifier's aud check (parity with the other
      // backends' ValidateAudience) — compile-gated here.
      audience: "vanilla-api"
    }
    claims: { roles: "realm_access.roles", email: "email" }
  }

  subdomain Support {
    context Tickets {
      aggregate Ticket with crudish {
        subject: string
        open: bool
      }
      repository Tickets for Ticket { }
    }
  }

  storage primary { type: postgres }
  resource ticketState { for: Tickets, kind: state, use: primary }

  api SupportApi from Support
  deployable phoenixApp {
    platform: elixir
    contexts: [Tickets]
    serves: SupportApi
    dataSources: [ticketState]
    port: 4000
    auth: required
  }
}
