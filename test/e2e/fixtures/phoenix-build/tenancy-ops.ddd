// DEBT-01 follow-up — actor threading through the two read paths the first
// elixir/Ash slice deferred: context **retrievals** invoked from a workflow
// (`Repo.run`) and **`or`-union returning operations** (`Ash.get`).  Both read
// the tenancy aggregate, so both run under its
// `base_filter expr(tenant_id == ^actor(:tenant_id))` and must pass the request
// actor — else `^actor` is nil and the read is fail-closed (no rows).  This
// fixture compiles both threaded reads under `mix compile --warnings-as-errors`
// against real Ash 3.x (the elixir-ash-build gate).
//
// Auth is wired like auth-oidc.ddd (a proven-compiling path); the `tenantId`
// claim feeds the actor the base_filter binds.
system TenancyOps {
  user {
    id: string
    tenantId: string
  }

  auth {
    provider: keycloak
    oidc {
      issuer: env("OIDC_ISSUER")
      clientId: env("OIDC_CLIENT_ID")
    }
    claims: { tenantId: "tenant_id" }
  }

  subdomain Core {
    context Ledger {
      error NotFound { resource: string }

      criterion Rich(min: int) of Account = balance >= min

      aggregate Account ids guid {
        tenantId: string
        balance: int
        verified: bool

        // Tenancy scoping — applies to every read, including the retrieval and
        // the returning op below.
        filter this.tenantId == currentUser.tenantId

        operation verify() { verified := true }

        // Return-dominant `or`-union returning op: its generic action loads the
        // record via `Ash.get` (under the base_filter) and returns a scalar.
        // Exercises `Ash.get(__MODULE__, id, actor: context.actor)`.
        operation balanceOf(): int or NotFound { return balance }
      }

      repository Accounts for Account {}

      // Context retrieval invoked from the workflow below (`Repo.run`).
      retrieval RichAccounts(min: int) of Account {
        where: Rich(min)
        sort:  [balance desc]
      }

      // Workflow `for` loop over a paged `Repo.run` — exercises
      // `run_rich_accounts_account!(min, page: [...], actor: current_user)`.
      workflow verifyRich {
        create(min: int) {
          let matched = Accounts.run(RichAccounts(min), page: { offset: 0, limit: 100 })
          for a in matched {
            a.verify()
          }
        }
      }
    }
  }

  storage primary { type: postgres }
  resource ledgerState { for: Ledger, kind: state, use: primary }

  api LedgerApi from Core
  deployable phoenixApp {
    platform: phoenix { foundation: ash }
    contexts: [Ledger]
    serves: LedgerApi
    dataSources: [ledgerState]
    port: 4000
    auth: required
  }
}
