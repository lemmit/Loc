system Roster {
  subdomain Roster {
    context Roster {
      aggregate Pokemon {
        species: string
        derived display: string = species
        level: int
        invariant level >= 1
        invariant level <= 100
      }
      aggregate Trainer {
        name: string
        derived display: string = name
        party: Pokemon id[]
        caught: Pokemon id[]
        verified: bool
        // Owned containment (has_many) — exercises the retrieval load plan:
        // `ByName`'s default-whole load eager-fetches it as
        // `prepare build(load: [:badges])` under the real `mix compile` gate.
        contains badges: Badge[]
        entity Badge {
          name: string
        }
        invariant party.count <= 6
        operation verify() { verified := true }
        operation addToParty(pokemon: Pokemon id) {
          precondition party.count < 6
          party += pokemon
          caught += pokemon
        }
        operation removeFromParty(pokemon: Pokemon id) {
          precondition party.count > 0
          party -= pokemon
        }
      }
      repository Trainers for Trainer {
        find holdingInParty(pokemon: Pokemon id): Trainer[]
            where this.party.contains(pokemon)
      }
      // Named query bundle (retrieval.md) — exercises the Ash read-action
      // emission (filter via ^arg + sort via prepare build + offset
      // pagination + default-whole `prepare build(load: [:badges])`) under
      // the real `mix compile` gate.
      criterion NamedLike(needle: string) of Trainer = name == needle
      retrieval ByName(needle: string) of Trainer {
        where: NamedLike(needle)
        sort:  [name asc]
      }
      // Exercises the workflow `for` loop (Enum.reduce_while over a paged
      // Repo.run) under the real `mix compile` gate.
      workflow verifyByName {
        create(needle: string) {
          let matched = Trainers.run(ByName(needle), page: { offset: 0, limit: 100 })
          for t in matched {
            t.verify()
          }
        }
      }
    }
  }
  api RosterApi from Roster
  ui RosterAdmin with scaffold(subdomains: [Roster]) { }
  storage primary { type: postgres }
  resource rosterState { for: Roster, kind: state, use: primary }
  deployable phoenixApp {
    platform: phoenix
    contexts: [Roster]
    dataSources: [rosterState]
    serves: RosterApi
    ui: RosterAdmin
    port: 4000
  }
}
