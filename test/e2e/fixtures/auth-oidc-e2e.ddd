// OIDC runtime e2e (D-AUTH-OIDC): a Hono backend behind a bundled dev
// Keycloak.  The test boots the compose stack, gets a real token for the
// seeded `demo` user via the password grant, and asserts the generated
// OIDC verifier validates it (JWKS) and maps the claims onto User.
system Helpdesk {
  user {
    id: string
    roles: string[]
    email: string
  }

  auth {
    provider: keycloak
    oidc {
      issuer: env("OIDC_ISSUER")
      clientId: env("OIDC_CLIENT_ID")
    }
    claims: { roles: "realm_access.roles", email: "email" }
  }

  subdomain Support {
    context Tickets {
      aggregate Ticket with crudish {
        subject: string
        open: bool
      }
      repository Tickets for Ticket { }
    }
  }

  storage primary { type: postgres }
  resource ticketState { for: Tickets, kind: state, use: primary }

  api SupportApi from Support
  deployable api {
    platform: node
    contexts: [Tickets]
    serves: SupportApi
    dataSources: [ticketState]
    port: 3000
    auth: required
  }
}
