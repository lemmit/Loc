// DEBT-02 Slice B — a PRINCIPAL-referencing capability filter
// (`filter this.tenantId == currentUser.tenantId`) on a `shape: document`
// aggregate, on the Hono/Drizzle (node) backend.  A document aggregate stores
// every field in one `data` jsonb column, so the predicate can't be a SQL
// column clause — it's applied in-app over the rehydrated aggregate on every
// read.  The principal reference can't be a static predicate either, so the
// repository binds `const currentUser = requireCurrentUser();` (fail-closed —
// throws when unauthenticated) and AND-s the principal predicate into each
// in-app document read.  Previously this combination was GATED by
// `loom.context-filter-unsupported`; Slice B lifts the gate.
//
// Generated via `generate system` (the user block + auth/middleware.ts are
// system-level); this gate compiles the emitted document repository + the
// requireCurrentUser import end-to-end.
system DocTenancy {
  user { id: string  tenantId: string }

  subdomain D {
    context Shop {
      aggregate Order shape: document {
        tenantId: string
        code: string
        // Always-on row scoping: every read of Order is constrained to the
        // requesting principal's tenant.
        filter this.tenantId == currentUser.tenantId
        operation rename(code: string) { code := code }
      }
      repository Orders for Order {
        find byCode(code: string): Order[] where this.code == code
      }
    }
  }

  api A from D
  storage primary { type: postgres }
  resource st { for: Shop, kind: state, use: primary }
  deployable api {
    platform: node
    contexts: [Shop]
    dataSources: [st]
    serves: A
    auth: required
    port: 4100
  }
}
