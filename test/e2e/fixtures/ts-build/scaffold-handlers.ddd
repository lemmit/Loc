// M-T5.10 handler-param rewrite — compile gate for the SCAFFOLDED explicit
// application/transport layer.  `with scaffoldHandlers` synthesises a
// commandHandler/queryHandler per create / operation / find / get-by-id /
// destroy, each taking a single `command`/`query` RECORD param (`cmd.<field>` /
// `query.<field>`) and — for reads — declaring a `<Agg>Response` return; the
// matching routes bind them.  A Money-typed operation param stresses the
// value-object wire-schema closure on the request-record path.  No example or
// corpus `.ddd` exercised a scaffolded record-param handler before this fixture,
// so the per-PR tsc gate had a blind spot here.
system HandlerScaffold {
  subdomain Sales {
    context Ordering with scaffoldHandlers {
      valueobject Money {
        amount: decimal
        currency: string
        invariant amount >= 0
      }
      enum Priority { low  high }

      aggregate Order {
        code: string
        status: string
        priority: Priority
        total: Money
        create(code: string) { code := code  status := "new"  priority := Priority.low  total := Money { amount: 0, currency: "USD" } }
        operation reprice(newTotal: Money) { total := newTotal }
        operation escalate(level: Priority) { priority := level }
        operation cancel() { status := "cancelled" }
        destroy { }
      }
      repository Orders for Order {
        find byStatus(status: string): Order[] where this.status == status
        find byPriority(level: Priority): Order[] where this.priority == level
      }
    }
  }
  api SalesApi with scaffoldApi(of: Sales)
  storage pg { type: postgres }
  resource st { for: Ordering, kind: state, use: pg }
  deployable api { platform: node  contexts: [Ordering]  dataSources: [st]  serves: SalesApi  port: 5001 }
}
