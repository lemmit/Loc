// Compile-gate fixture for the `ignoring` filter-bypass clause (named-filter-
// bypass.md §11) on node/Hono.  node honors a bypass by OMITTING the bypassed
// capability's predicate from the Drizzle `and(...)` chain; `ignoring *` drops
// every capability predicate.  This pins that the bypass read sites a
// `generate ts` project emits — repository finds — type-check
// under strict tsc.  `softDeletable` is the built-in prelude capability (adds
// `isDeleted`/`deletedAt` + a `!this.isDeleted` read filter).
context Shop {
  aggregate Order with softDeletable {
    total: int
  }

  repository Orders for Order {
    find recent(): Order[] where this.total > 0 ignoring softDeletable
    find allRows(): Order[] ignoring *
    find normal(): Order[] where this.total > 0
  }
}
