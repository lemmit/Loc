// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`architecture.c4 > emits the expected LikeC4 model for examples/acme.ddd 1`] = `
"// Loom architecture model (LikeC4) — generated from the IR, do not edit by hand.
// System: Acme

specification {
  element system
  element container
  element component
  element database
}

model {
  Acme = system 'Acme' {
    description 'Loom-generated system'
    api = container 'api' {
      technology 'dotnet'
      Products = component 'Products'
      Orders = component 'Orders'
      Customers = component 'Customers'
    }
    catalogWeb = container 'catalogWeb' {
      technology 'node'
      Products = component 'Products'
      Customers = component 'Customers'
    }
    catalogApi = container 'catalogApi' {
      technology 'dotnet'
      Products = component 'Products'
      Customers = component 'Customers'
    }
    webApp = container 'webApp' {
      technology 'static'
    }
    db = database 'PostgreSQL'

    api -> db 'reads / writes'
    catalogWeb -> db 'reads / writes'
    catalogApi -> db 'reads / writes'
    webApp -> api 'calls'
  }
}

views {
  view index {
    title 'Acme — landscape'
    include *
  }
  view of Acme {
    title 'Acme — containers'
    include *
  }
}"
`;
