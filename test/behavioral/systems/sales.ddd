// Shared behavioural system — the Sales domain, ONE platform-agnostic source
// (`platform: __PLATFORM__`) that every backend runner token-swaps and boots.
// It replaces the five hand-forked copies (corpus-{python,java,dotnet,elixir}/
// sales.ddd + web/src/examples/sales-system.ddd's backend) that had drifted
// apart; the runners derive it here, so "same test, all targets" is one file.
//
// Its `test e2e` create→read round-trips exercise the behavioural RS-rules:
// camelCase multi-word keys both directions (RS-1 externalRef/customerId/
// placedAt), enum declared casing (RS-2), no leaked columns (RS-3), temporal
// round-trip (RS-4 placedAt), bool create default (RS-6 active), value-object
// survival (RS-7 price), association round-trip (RS-8 lines).  The pure-domain
// `test` blocks are the unit tier (in-memory operations + precondition/invariant
// violations, DB-free).
//
// RS-4 uses `toBeSameInstant` — instant equality that forgives wire timestamp
// FORMAT (a backend serialising `…00.0000000Z` still equals the canonical
// `…00Z`) while still catching a real difference in time.  .NET canonicalises
// today (RST-9), so plain `toBe` would also pass; the instant matcher keeps the
// single shared assertion robust to any future serializer drift.

system Sales {

  subdomain Sales {
    context Sales {

      enum OrderStatus { Draft, Confirmed, Shipped, Cancelled }

      valueobject Money {
        amount: decimal
        currency: string
        invariant amount >= 0
        invariant currency.length == 3
      }

      event OrderConfirmed { order: Order id, at: datetime }

      aggregate Customer with crudish {
        name: string
        email: string
        externalRef: string
        active: bool = true
        invariant email.length > 0
        derived display: string = name
      }

      aggregate Product with crudish {
        sku: string
        price: Money
        invariant sku.length > 0
        derived display: string = sku
      }

      aggregate Order with crudish {
        customerId: Customer id
        status: OrderStatus
        placedAt: datetime
        contains lines: OrderLine[]

        invariant lines.count > 0 when status == Confirmed

        function isMutable(): bool = status == Draft

        operation addLine(productId: Product id, qty: int) {
          precondition isMutable()
          precondition qty > 0
          lines += OrderLine { productId: productId, quantity: qty }
        }

        operation confirm() {
          precondition isMutable()
          precondition lines.count > 0
          status := Confirmed
          emit OrderConfirmed { order: id, at: now() }
        }

        entity OrderLine {
          productId: Product id
          quantity: int
          invariant quantity > 0
        }

        test "adding a line then confirming yields a confirmed order" {
          let order = Order.create({
            customerId: "00000000-0000-0000-0000-000000000001",
            status: Draft,
            placedAt: "2024-01-01T00:00:00Z"
          })
          order.addLine("00000000-0000-0000-0000-000000000002", 2)
          order.confirm()
          expect(order.status).toBe(Confirmed)
          expect(order.lines.count).toBe(1)
        }

        test "lines cannot be added once the order is confirmed" {
          let order = Order.create({
            customerId: "00000000-0000-0000-0000-000000000001",
            status: Draft,
            placedAt: "2024-01-01T00:00:00Z"
          })
          order.addLine("00000000-0000-0000-0000-000000000002", 2)
          order.confirm()
          expect(order.addLine("00000000-0000-0000-0000-000000000002", 1)).toThrow()
        }

        test "an order cannot be confirmed with no lines" {
          let order = Order.create({
            customerId: "00000000-0000-0000-0000-000000000001",
            status: Draft,
            placedAt: "2024-01-01T00:00:00Z"
          })
          expect(order.confirm()).toThrow()
        }
      }

      repository Customers for Customer { }
      repository Products for Product { }
      repository Orders for Order { }
    }
  }

  storage primary { type: postgres }
  resource salesState { for: Sales, kind: state, use: primary }

  deployable api {
    platform: __PLATFORM__
    contexts: [Sales]
    dataSources: [salesState]
    port: 8000
  }

  // RS-7 (value-object survives round-trip) + RS-3 (no leaked columns).
  test e2e "create a product and read it back" against api {
    let p = api.products.create({ sku: "WIDGET-1", price: { amount: 9.99, currency: "USD" } })
    let read = api.products.getById(p)
    expect(read.sku).toBe("WIDGET-1")
  }

  // RS-6 (bool create default materialises at the wire boundary): `active` is
  // omitted on create and must read back `true`, not a zero-value false/null.
  // RS-1 (multi-word wire key both directions): `externalRef` is sent camelCase
  // and must persist (snake `external_ref`) and read back camelCase.
  test e2e "create a customer: bool default + multi-word key round-trip" against api {
    let c = api.customers.create({ name: "Defaulter", email: "def@acme.test", externalRef: "ext-42" })
    let read = api.customers.getById(c)
    expect(read.active).toBe(true)
    expect(read.externalRef).toBe("ext-42")
  }

  // RS-1 (camelCase keys both directions: customerId/placedAt) + RS-2 (enum
  // declared casing "Draft") + RS-4 (temporal round-trip placedAt, instant-equal).
  test e2e "create an order and read it back" against api {
    let cust = api.customers.create({ name: "Buyer", email: "buyer@acme.test", externalRef: "ext-b1" })
    let ord = api.orders.create({ customerId: cust.id, status: "Draft", placedAt: "2024-01-01T00:00:00Z" })
    let read = api.orders.getById(ord)
    expect(read.status).toBe("Draft")
    expect(read.placedAt).toBeSameInstant("2024-01-01T00:00:00Z")
  }

  // RS-8 (association round-trip via an operation) + RS-2 (enum "Confirmed").
  test e2e "create, add a line to, and confirm an order" against api {
    let prod = api.products.create({ sku: "WIDGET-2", price: { amount: 5.00, currency: "USD" } })
    let cust = api.customers.create({ name: "Buyer2", email: "buyer2@acme.test", externalRef: "ext-b2" })
    let ord = api.orders.create({ customerId: cust.id, status: "Draft", placedAt: "2024-01-01T00:00:00Z" })
    api.orders.addLine(ord, { productId: prod.id, qty: 3 })
    api.orders.confirm(ord)
    let read = api.orders.getById(ord)
    expect(read.status).toBe("Confirmed")
    expect(read.lines.length).toBe(1)
  }
}
