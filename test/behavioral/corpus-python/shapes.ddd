// RST-8 behavioral-tier fixture — alternative persistence SHAPES
// (`shape: document` + `shape: embedded`), retargeted from
// examples/document.ddd to a single `platform: python` (FastAPI) backend.
// A relational Customer coexists with a document-shaped Cart (the whole
// aggregate as one opaque JSONB blob) and an embedded-shaped Wishlist
// (queryable root row + contained parts folded into a JSONB column). Two
// jsonb-storing emitter paths the plain-relational fixtures never hit.
//
// RS-rules the `test e2e` create→(op)→read round-trips assert on Python:
//   RS-7  a value object (Money on a document CartItem) serializes into the
//         jsonb blob on create and the aggregate reads back without crashing
//         on the rehydrated VO (the test-expr grammar has no `items[0]`
//         indexing, so the subfield is exercised on the write+rehydrate path,
//         asserted via `items.length`).
//   RS-8  contained parts mutated via an op persist through the jsonb column
//         and read back (`items += …` on both document and embedded).
//   RS-2  enum declared casing survives the jsonb blob (`CartStatus` → "Open").

system ShapesPy {

  subdomain Shopping {
    context Shopping {

      enum CartStatus { Open, CheckedOut }

      valueobject Money {
        amount: decimal
        currency: string
        invariant amount >= 0
        invariant currency.length == 3
      }

      aggregate Customer {
        name: string
        invariant name.length > 0
        create(name: string) { name := name }
      }

      // shape: document: the whole aggregate (root + contained items) is one
      // opaque JSONB blob (`id, data, version`).
      aggregate Cart shape: document {
        customerId: Customer id
        status: CartStatus
        contains items: CartItem[]

        create(customerId: Customer id, status: CartStatus) {
          customerId := customerId
          status := status
        }

        invariant items.count >= 0

        function isOpen(): bool = status == Open

        operation addItem(sku: string, qty: int, price: Money) {
          precondition isOpen()
          precondition qty > 0
          items += CartItem { sku: sku, quantity: qty, unitPrice: price }
        }

        entity CartItem {
          sku: string
          quantity: int
          unitPrice: Money
          invariant quantity > 0
        }
      }

      // shape: embedded: root (customerId, label) stays queryable columns; the
      // contained WishItem parts fold into a JSONB column.
      aggregate Wishlist shape: embedded {
        customerId: Customer id
        label: string
        contains items: WishItem[]

        invariant label.length > 0

        create(customerId: Customer id, label: string) {
          customerId := customerId
          label := label
        }

        operation addItem(sku: string) {
          items += WishItem { sku: sku }
        }

        entity WishItem {
          sku: string
          invariant sku.length > 0
        }
      }

      repository Customers for Customer { }
      repository Carts for Cart { }
      repository Wishlists for Wishlist { }
    }
  }

  storage primary { type: postgres }
  resource shoppingState { for: Shopping, kind: state, use: primary }

  deployable api {
    platform: python
    contexts: [Shopping]
    dataSources: [shoppingState]
    port: 8000
  }

  // RS-7 (Money VO subfields survive the document jsonb blob) + RS-8
  // (contained CartItem persists through the blob) + RS-2 (enum "Open").
  test e2e "create a document Cart, add an item, read the jsonb blob back" against api {
    let cust = api.customers.create({ name: "Buyer" })
    let cart = api.carts.create({ customerId: cust.id, status: "Open" })
    api.carts.addItem(cart, { sku: "WIDGET-1", qty: 2, price: { amount: 9.99, currency: "USD" } })
    let read = api.carts.getById(cart)
    expect(read.status).toBe("Open")
    expect(read.items.length).toBe(1)
  }

  // RS-8 (embedded-shape contained WishItem folds into the jsonb column and
  // reads back) — the root columns stay queryable, the parts round-trip.
  test e2e "create an embedded Wishlist, add an item, read it back" against api {
    let cust = api.customers.create({ name: "Wisher" })
    let wl = api.wishlists.create({ customerId: cust.id, label: "Birthday" })
    api.wishlists.addItem(wl, { sku: "GADGET-9" })
    let read = api.wishlists.getById(wl)
    expect(read.label).toBe("Birthday")
    expect(read.items.length).toBe(1)
  }
}
