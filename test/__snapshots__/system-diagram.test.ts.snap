      agg_Catalog_Products_Product["Product"]
      vo_Catalog_Products_Money[/"Money"/]
      repo_Catalog_Products_Products[("Products")]
    end
  end
  subgraph mod_Sales["📦 Sales"]
    direction TB
    subgraph ctx_Sales_Orders["Orders"]
      agg_Sales_Orders_Order["Order"]
      evt_Sales_Orders_OrderConfirmed(["OrderConfirmed"])
      repo_Sales_Orders_Orders[("Orders")]
    end
  end
  subgraph mod_CustomerMgmt["📦 CustomerMgmt"]
    direction TB
    subgraph ctx_CustomerMgmt_Customers["Customers"]
      agg_CustomerMgmt_Customers_Customer["Customer"]
      repo_CustomerMgmt_Customers_Customers[("Customers")]
    end
  end
  subgraph deployables["🚀 Deployables"]
    direction TB
    deploy_api{{"api · dotnet"}}
    deploy_catalogWeb{{"catalogWeb · hono"}}
    deploy_catalogApi{{"catalogApi · dotnet"}}
    deploy_webApp{{"webApp · static"}}
  end
  agg_Catalog_Products_Product -->|repo| repo_Catalog_Products_Products
  agg_Sales_Orders_Order -->|repo| repo_Sales_Orders_Orders
  agg_CustomerMgmt_Customers_Customer -->|repo| repo_CustomerMgmt_Customers_Customers
  deploy_api --> mod_Catalog
  deploy_api --> mod_Sales
  deploy_api --> mod_CustomerMgmt
  deploy_catalogWeb --> mod_Catalog
  deploy_catalogWeb --> mod_CustomerMgmt
  deploy_catalogApi --> mod_Catalog
  deploy_catalogApi --> mod_CustomerMgmt
  deploy_webApp --> mod_Catalog
  deploy_webApp --> mod_Sales
  deploy_webApp --> mod_CustomerMgmt
  deploy_webApp -.->|calls| deploy_api"
`;
