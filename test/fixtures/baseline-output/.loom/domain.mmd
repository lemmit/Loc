%% Loom domain diagram — generated from the IR, do not edit by hand.
%% System: Acme
classDiagram
  direction LR
  %% Catalog / Products
  class Money {
    <<value>>
    +decimal amount
    +string currency
  }
  class Product {
    <<aggregate>>
    +Id~Product~ id
    +string sku
    +Money price
    +int version
    +string /display
    +string /inspect
    +update(sku, price)
  }
  class Products {
    <<repository>>
    +all() Product paged
    +bySku(sku) Product?
  }
  %% Sales / Orders
  class OrderStatus {
    <<enumeration>>
    +Draft
    +Confirmed
    +Shipped
    +Cancelled
  }
  class OrderConfirmed {
    <<event>>
    +Id~Order~ order
    +datetime at
  }
  class Order {
    <<aggregate>>
    +Id~Order~ id
    +string customerId
    +OrderStatus status
    +datetime placedAt
    +int version
    +string /inspect
    +isMutable() bool
    +addLine(productId, qty)
    +confirm()
    +update(customerId, status, placedAt)
  }
  class OrderLine {
    <<entity>>
    +Id~Product~ productId
    +int quantity
  }
  class Orders {
    <<repository>>
    +all() Order paged
    +byCustomer(customerId) Order[]
  }
  %% CustomerMgmt / Customers
  class Customer {
    <<aggregate>>
    +Id~Customer~ id
    +string username
    +string email
    +int age
    +int version
    +string /display
    +string /inspect
    +update(username, email, age)
  }
  class Customers {
    <<repository>>
    +all() Customer paged
    +byEmail(email) Customer?
  }
  Product ..> Money : uses
  Products ..> Product : manages
  OrderConfirmed ..> Order : ref
  Order ..> OrderStatus : uses
  Order *-- "*" OrderLine : lines
  Order ..> OrderConfirmed : emits
  OrderLine ..> Product : ref
  Orders ..> Order : manages
  Customers ..> Customer : manages
