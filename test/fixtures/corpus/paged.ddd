// Pagination: `find ... paged` returns the Paged<T> envelope.
system PagedShop {
  subdomain Sales {
    context Orders {
      aggregate Order with crudish { code: string  region: string }
      repository Orders for Order {
        find recent(): Order paged
        find inRegion(region: string): Order paged where this.region == region
      }
    }
  }
  api OrdersApi from Sales
  storage primary { type: postgres }
  resource ordersState { for: Orders, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Orders]
    dataSources: [ordersState]
    serves: OrdersApi
    port: 4000
  }

  test e2e "paged find returns the envelope" against d {
    api.orders.create({ code: "P1", region: "NA" })
    api.orders.create({ code: "P2", region: "NA" })
    let p = api.orders.recent()
    expect(p.items.length).toBe(2)
  }
}
