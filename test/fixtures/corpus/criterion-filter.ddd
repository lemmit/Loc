// Reusable criterion (criterion.md): a zero-arg and an arg-bearing criterion
// used both as capability filters and as a parameterised find criterion.
system Crit {
  subdomain Sales {
    context Orders {
      criterion Active of Order = !this.archived
      criterion InRegion(region: string) of Order = this.region == region
      aggregate Order with crudish {
        code: string
        region: string
        archived: bool
        filter Active
        filter InRegion("EU")
      }
      repository Orders for Order {
        find recent(): Order[] where this.archived == false
      }
    }
  }
  api OrdersApi from Sales
  storage primary { type: postgres }
  resource ordersState { for: Orders, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Orders]
    dataSources: [ordersState]
    serves: OrdersApi
    port: 4000
  }

  test e2e "recent excludes archived orders" against d {
    let a = api.orders.create({ code: "C1", region: "EU", archived: false })
    let read = api.orders.getById(a)
    expect(read.code).toBe("C1")
    api.orders.create({ code: "C2", region: "EU", archived: true })
    let list = api.orders.recent()
    expect(list.length).toBe(1)
  }
}
