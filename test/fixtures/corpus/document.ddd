// shape: document: whole aggregate tree round-trips one jsonb column.
system DocSys {
  subdomain Cms {
    context Cms {
      aggregate Article shape: document, with crudish {
        title: string
        viewCount: int
        contains sections: Section[]
        entity Section { heading: string  body: string }
        operation addSection(heading: string, body: string) {
          sections += Section { heading: heading, body: body }
        }
        operation bump() { viewCount := viewCount + 1 }
      }
      repository Articles for Article {
        find popular(min: int): Article[] where this.viewCount >= min
      }
    }
  }
  api CmsApi from Cms
  storage primary { type: postgres }
  resource cmsState { for: Cms, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Cms]
    dataSources: [cmsState]
    serves: CmsApi
    port: 4000
  }

  test e2e "document aggregate round-trips the jsonb tree" against d {
    let a = api.articles.create({ title: "T1", viewCount: 0 })
    api.articles.addSection(a, { heading: "H", body: "B" })
    let read = api.articles.getById(a)
    expect(read.title).toBe("T1")
  }
}
