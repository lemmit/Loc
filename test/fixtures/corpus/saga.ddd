// In-process event dispatch / saga (channels.md) with persisted correlation.
system FulfillmentSaga {
  subdomain Fulfillment {
    context Fulfillment {
      aggregate Order with crudish {
        customerId: string
        status: string
        operation place() {
          precondition status == "Draft"
          status := "Placed"
          emit OrderPlaced { order: id, at: now() }
        }

        // Pure-domain (unit) test — a scalar-status transition GATED by a
        // precondition: a Draft order places (status flips), a non-Draft order
        // is rejected (`toThrow`).  Adds precondition-rejection coverage that
        // core-domain lacks; the `emit` effect is stripped in the pure core.
        test "place transitions a draft order and rejects a non-draft one" {
          let o = Order.create({ customerId: "C1", status: "Draft" })
          expect(o.status).toBe("Draft")
          o.place()
          expect(o.status).toBe("Placed")
          let bad = Order.create({ customerId: "C2", status: "Shipped" })
          expect(bad.place()).toThrow()
        }
      }
      repository Orders for Order { }
      aggregate Shipment {
        orderRef: Order id
        status: string
        operation markTracked() { status := "Tracked" }
      }
      repository Shipments for Shipment {
        find byOrder(order: Order id): Shipment? where this.orderRef == order
      }
      event OrderPlaced { order: Order id, at: datetime }
      event ShipmentRequested { shipment: Shipment id, order: Order id, at: datetime }
      channel Lifecycle {
        carries: OrderPlaced, ShipmentRequested
        delivery: broadcast
        retention: ephemeral
      }
      workflow OrderFulfillment {
        orderId: Order id
        attempts: int
        create(p: OrderPlaced) by p.order {
          let ship = Shipment.create({ orderRef: p.order, status: "Pending" })
          emit ShipmentRequested { shipment: ship.id, order: p.order, at: now() }
        }
        on(s: ShipmentRequested) by s.order {
          let ship = Shipments.getById(s.shipment)
          ship.markTracked()
        }
      }
    }
  }
  api FulfillmentApi from Fulfillment
  storage pg { type: postgres }
  resource fulfillmentState { for: Fulfillment, kind: state, use: pg }
  deployable d {
    platform: __PLATFORM__
    contexts: [Fulfillment]
    dataSources: [fulfillmentState]
    serves: FulfillmentApi
    port: 4000
  }

  // In-process synchronous cascade: place() emits OrderPlaced → the workflow
  // creates a Shipment (Pending) + emits ShipmentRequested → on() marks it
  // Tracked.  If dispatch is synchronous, the shipment is Tracked by read time.
  test e2e "saga cascade creates and tracks a shipment" against d {
    let ord = api.orders.create({ customerId: "c1", status: "Draft" })
    api.orders.place(ord)
    let ship = api.shipments.byOrder({ order: ord.id })
    expect(ship.status).toBe("Tracked")
  }
}
