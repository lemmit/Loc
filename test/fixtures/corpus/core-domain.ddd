// Core domain surface: enum, value object, event, aggregate with containment,
// a derived field, an invariant, an operation, and a custom find.
system CoreShop {
  subdomain Sales {
    context Orders {
      enum Status { Draft, Placed, Cancelled }
      valueobject Money { amount: decimal  currency: string }
      event OrderPlaced { code: string }
      aggregate Order with crudish {
        code: string
        status: Status
        total: Money
        contains lines: Line[]
        entity Line { sku: string  qty: int }
        derived isDraft: bool = status == Status.Draft
        invariant total.amount >= 0
        operation place() { status := Status.Placed }
        operation addLine(sku: string, qty: int) { lines += Line { sku: sku, qty: qty } }

        // Pure-domain (unit) test — exercised on every backend's unit tier.
        // Stresses enum construction, a `Money` value-object literal (decimal),
        // a collection containment (`lines` folds a Line), an enum-valued
        // matcher, a decimal matcher, and a derived-field read (`o.isDraft`) —
        // the cross-backend coercion surface.  All five backends expose the
        // derived as a domain accessor (elixir via the B18 pure-core accessor).
        test "place transitions a draft order and folds a line" {
          let o = Order.create({ code: "CD1", status: Draft, total: Money { amount: 10.00, currency: "USD" } })
          expect(o.isDraft).toBe(true)
          o.addLine("S1", 2)
          o.place()
          expect(o.status).toBe(Placed)
          expect(o.isDraft).toBe(false)
          expect(o.lines.count).toBe(1)
          expect(o.total.amount).toBe(10.00)
        }
      }
      repository Orders for Order {
        find byStatus(s: Status): Order[] where this.status == s
      }
    }
  }
  api OrdersApi from Sales
  storage primary { type: postgres }
  resource ordersState { for: Orders, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Orders]
    dataSources: [ordersState]
    serves: OrdersApi
    port: 4000
  }

  test e2e "core domain: create, add line, place, read" against d {
    let o = api.orders.create({ code: "CD1", status: "Draft", total: { amount: 10.00, currency: "USD" } })
    api.orders.addLine(o, { sku: "S1", qty: 2 })
    api.orders.place(o)
    let read = api.orders.getById(o)
    expect(read.status).toBe("Placed")
  }
}
