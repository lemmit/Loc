// Seeding (database-seeding.md): default / demo / wired-raw datasets.
system Seeding {
  subdomain Catalog {
    context Catalog {
      enum Tier { Free, Pro }
      aggregate Widget with crudish {
        name: string
        size: int
        tier: Tier
        invariant size >= 0
        derived display: string = name
      }
      aggregate Gadget with crudish {
        widgetId: Widget id
        label: string
      }
      repository Widgets for Widget { }
      repository Gadgets for Gadget { }
      seed default {
        Widget { name: "Alpha", size: 1, tier: Free }
        Widget { name: "Beta", size: 2, tier: Pro }
      }
      seed demo { Widget { name: "Gamma", size: 3, tier: Pro } }
      seed wired raw {
        Widget { id: "11111111-1111-1111-1111-111111111111", name: "Anchor", size: 4, tier: Free }
        Gadget { id: "22222222-2222-2222-2222-222222222222", widgetId: "11111111-1111-1111-1111-111111111111", label: "g1" }
      }
    }
  }
  api CatalogApi from Catalog
  storage primary { type: postgres }
  resource catalogState { for: Catalog, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Catalog]
    dataSources: [catalogState]
    serves: CatalogApi
    port: 4000
  }

  test e2e "seeded catalog is created and readable" against d {
    let w = api.widgets.create({ name: "Delta", size: 9, tier: "Free" })
    let read = api.widgets.getById(w)
    expect(read.name).toBe("Delta")
  }
}
