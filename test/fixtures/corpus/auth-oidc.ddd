// OIDC authentication (auth.md): an OIDC provider config + a `requires`-guarded
// operation; `auth: required` emits the verifier + principal middleware.
system Helpdesk {
  user {
    id: string
    role: string
    email: string
    permissions: string[]
  }
  auth {
    provider: keycloak
    oidc {
      issuer: env("OIDC_ISSUER")
      clientId: env("OIDC_CLIENT_ID")
    }
    sessions: cookie
    claims: { role: "realm_access.roles" }
  }
  subdomain Support {
    context Tickets {
      aggregate Ticket with crudish {
        subject: string
        open: bool
        operation close() {
          requires currentUser.role == "agent"
          open := false
        }
      }
      repository Tickets for Ticket { }
    }
  }
  storage primary { type: postgres }
  resource ticketState { for: Tickets, kind: state, use: primary }
  api SupportApi from Support
  deployable d {
    platform: __PLATFORM__
    contexts: [Tickets]
    serves: SupportApi
    dataSources: [ticketState]
    port: 4000
    auth: required
  }

  // Unlike the dev-stub cluster, this system has an `auth {}` block → the
  // generated OIDC verifier validates a real bearer JWT against the issuer's
  // JWKS.  The behavioural harness stands up an in-process mock issuer
  // (test/behavioral/oidc-mock.mjs) in place of Keycloak and forwards a signed
  // token via E2E_BEARER_TOKEN whose `realm_access.roles == "agent"` satisfies
  // `requires currentUser.role == "agent"`.  The real JWT path runs end to end:
  // discovery → JWKS → signature/issuer verify → claim projection → guard.  A
  // backend whose verifier rejects the valid token, or mis-maps the role claim,
  // fails to close the ticket and the read still shows `open == true`.
  test e2e "OIDC-verified agent principal satisfies the requires-guarded op" against d {
    let t = api.tickets.create({ subject: "SSO broken", open: true })
    api.tickets.close(t)
    let read = api.tickets.getById(t)
    expect(read.open).toBe(false)
  }
}
