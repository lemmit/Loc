// `when` canCommand state gate (criterion.md): the operation evaluates the
// predicate before mutating and auto-exposes a GET can-query companion.
system WhenShop {
  subdomain Sales {
    context Orders {
      enum OrderStatus { Draft, Shipped, Cancelled }
      aggregate Order with crudish {
        code: string
        status: OrderStatus
        operation cancel() when this.status != OrderStatus.Shipped && this.status != OrderStatus.Cancelled {
          status := OrderStatus.Cancelled
        }
      }
      repository Orders for Order { }
    }
  }
  api A from Sales
  storage primary { type: postgres }
  resource st { for: Orders, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Orders]
    dataSources: [st]
    serves: A
    port: 4000
  }

  // Behavioural proof of the `when` gate: the same authored suite runs on every
  // backend via the shared HTTP-dispatch harness (one source, N targets).
  test e2e "cancel is state-gated: a shipped order cannot be cancelled" against d {
    // a Draft order is cancellable — the gate's predicate holds
    let ok = api.orders.create({ code: "A1", status: "Draft" })
    api.orders.cancel(ok)
    // a Shipped order is not — the `when` predicate fails → 409 Conflict
    let shipped = api.orders.create({ code: "A2", status: "Shipped" })
    expect(api.orders.cancel(shipped)).toThrow(409)
  }
}
