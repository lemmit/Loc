// Read-model views (views.md): a where-filtered projection over an aggregate.
system Viewing {
  subdomain Sales {
    context Orders {
      enum Status { Draft, Placed, Cancelled }
      aggregate Order with crudish {
        code: string
        status: Status
        total: int
      }
      repository Orders for Order { }
      view BigOrders = Order where total >= 1000
      view SmallOrders = Order where total < 100
    }
  }
  api OrdersApi from Sales
  storage primary { type: postgres }
  resource ordersState { for: Orders, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Orders]
    dataSources: [ordersState]
    serves: OrdersApi
    port: 4000
  }

  // Each context-level view is served as a parameterless GET under
  // `api.views.<name>()` → `Order[]` (the `${apiBasePath}/views/<snake>` route).
  // Seed three orders straddling both thresholds — a mid-value order (500) falls
  // in NEITHER view — and assert each `where` projects exactly its subset.  The
  // test-expr grammar has no array indexing, so we assert on `.length`.
  test e2e "where-filtered views project their matching subset" against d {
    api.orders.create({ code: "BIG", status: "Placed", total: 1500 })
    api.orders.create({ code: "MID", status: "Placed", total: 500 })
    api.orders.create({ code: "SMALL", status: "Draft", total: 50 })
    let bigs = api.views.bigOrders()
    expect(bigs.length).toBe(1)
    let smalls = api.views.smallOrders()
    expect(smalls.length).toBe(1)
  }
}
