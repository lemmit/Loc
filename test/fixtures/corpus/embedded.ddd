// shape: embedded: queryable root row, containments fold into jsonb columns.
system EmbSys {
  subdomain Shop {
    context Shop {
      aggregate Order shape: embedded, with crudish {
        customer: string
        total: money
        contains lines: LineItem[]
        entity LineItem { sku: string  qty: int }
        operation addLine(sku: string, qty: int) { lines += LineItem { sku: sku, qty: qty } }
        operation retotal(amount: money) { total := amount }
      }
      repository Orders for Order {
        find byCustomer(name: string): Order[] where this.customer == name
      }
    }
  }
  api ShopApi from Shop
  storage primary { type: postgres }
  resource shopState { for: Shop, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Shop]
    dataSources: [shopState]
    serves: ShopApi
    port: 4000
  }

  // An embedded aggregate keeps a queryable root row; its `lines` collection
  // containment folds into a jsonb column, and the `money` primitive rides
  // through as a decimal string.  Create, append a line via the op, then read
  // the whole tree back — asserting the containment fold (lines.length) and the
  // root scalar (customer) both round-trip across every backend.
  test e2e "embedded aggregate folds its containment collection into the jsonb row" against d {
    let o = api.orders.create({ customer: "acme", total: "99.50" })
    api.orders.addLine(o, { sku: "A1", qty: 3 })
    let read = api.orders.getById(o)
    expect(read.customer).toBe("acme")
    expect(read.lines.length).toBe(1)
  }
}
