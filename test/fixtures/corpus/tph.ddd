// Table-per-hierarchy (TPH / sharedTable) inheritance (inheritance.md): an
// abstract base + concretes share one kind-discriminated table.  Distinct from
// the `inheritance` feature (which pairs TPH with TPC) — this is the focused
// TPH-only canonical fixture the per-backend TPH gates + the java TPH unit test
// assert against.
system TPH {
  subdomain D {
    context Fleet {
      abstract aggregate Vehicle {
        name: string
        capacity: int
      }
      aggregate Car extends Vehicle with crudish {
        doors: int
        operation refit(d: int) { doors := d }
      }
      aggregate Truck extends Vehicle with crudish {
        payloadKg: int
      }
      repository Cars for Car { }
      repository Trucks for Truck { }
    }
  }
  api A from D
  storage primary { type: postgres }
  resource st { for: Fleet, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Fleet]
    dataSources: [st]
    serves: A
    port: 4000
  }

  test e2e "TPH concrete create round-trips" against d {
    let c = api.cars.create({ name: "Sedan", capacity: 5, doors: 4 })
    let read = api.cars.getById(c)
    expect(read.name).toBe("Sedan")
    expect(read.doors).toBe(4)
  }
}
