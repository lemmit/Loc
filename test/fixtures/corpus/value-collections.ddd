// Value-object array (`Money[]`) stored inline (no child table).
system Billing {
  subdomain Sales {
    context Invoicing {
      valueobject Money { amount: decimal  currency: string }
      aggregate Invoice with crudish {
        reference: string
        lineItems: Money[]
        surcharges: Money[]?
      }
      repository Invoices for Invoice { }
    }
  }
  api InvoicingApi from Sales
  storage primary { type: postgres }
  resource invoicingState { for: Invoicing, kind: state, use: primary }
  deployable d {
    platform: __PLATFORM__
    contexts: [Invoicing]
    dataSources: [invoicingState]
    serves: InvoicingApi
    port: 4000
  }

  test e2e "value-object array survives round-trip" against d {
    let inv = api.invoices.create({ reference: "INV-1", lineItems: [{ amount: 9.99, currency: "USD" }, { amount: 5.00, currency: "USD" }] })
    let read = api.invoices.getById(inv)
    expect(read.reference).toBe("INV-1")
    expect(read.lineItems.length).toBe(2)
  }
}
