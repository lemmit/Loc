# syntax=docker/dockerfile:1
# Auto-generated.
#
# Angular diverges from the Vite frontends: `ng build` emits a static
# bundle to `dist/browser` (the pack's angular.json pins `outputPath` so
# this path is stable), served by the emitted `server.mjs` — a tiny static
# host with history-API fallback (client-side deep links → index.html) AND a
# same-origin `/api` reverse proxy, so the bundle's relative `/api` reaches the
# backend SERVICE under compose / k8s instead of this server's own origin.

FROM node:24-alpine AS build
WORKDIR /app
# Optional proxy CAs — drop *.crt files into ./certs/ to make npm
# trust them.  The directory always exists (with a .gitkeep), so
# this COPY is a no-op when no CAs are configured.
COPY certs/ /usr/local/share/ca-certificates/
RUN cat /usr/local/share/ca-certificates/*.crt 2>/dev/null >> /etc/ssl/cert.pem || true
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/cert.pem NPM_CONFIG_CAFILE=/etc/ssl/cert.pem
COPY package.json package-lock.json* ./
RUN npm ci || npm install
COPY . .
RUN npm run build

FROM node:24-alpine AS runtime
WORKDIR /app
ENV PORT=3000
COPY --from=build /app/dist/browser ./browser
COPY --from=build /app/server.mjs ./server.mjs
EXPOSE 3000
# server.mjs: static + SPA fallback + same-origin `/api` proxy
# (VITE_API_PROXY_TARGET → the backend service).  A bare static server (`serve`)
# can't proxy, so the bundle's relative `/api` would never reach the backend.
CMD ["node", "server.mjs"]
